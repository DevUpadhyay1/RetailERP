@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<partial name="_StatusMessage" for="StatusMessage" />

<!-- ── Profile header ── -->
<div class="d-flex align-items-center gap-3 mb-4 pb-3 border-bottom">
    <div class="d-flex align-items-center justify-content-center rounded-circle"
         style="width:64px;height:64px;background:#dbeafe;color:#3b82f6;font-size:1.6rem;flex-shrink:0;">
        <i class="bi bi-person-fill"></i>
    </div>
    <div>
        <h5 class="mb-0 fw-semibold">@(Model.Input.DisplayName ?? Model.Username)</h5>
        <div class="text-muted small">@Model.Email</div>
        <span class="badge bg-primary bg-opacity-10 text-primary mt-1" style="font-size:.72rem;">@Model.Role</span>
    </div>
</div>

<!-- ── Edit form ── -->
<form id="profile-form" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

    <div class="row g-3">
        <div class="col-12">
            <label class="form-label">Username</label>
            <input asp-for="Username" class="form-control" disabled />
            <div class="form-text">Your username cannot be changed.</div>
        </div>

        <div class="col-12">
            <label asp-for="Input.DisplayName" class="form-label"></label>
            <input asp-for="Input.DisplayName" class="form-control" placeholder="e.g., John Doe" />
            <span asp-validation-for="Input.DisplayName" class="text-danger"></span>
            <div class="form-text">This name is shown in the sidebar and topbar.</div>
        </div>

        <div class="col-md-6">
            <label asp-for="Input.PhoneNumber" class="form-label"></label>
            <input asp-for="Input.PhoneNumber" class="form-control" type="tel" maxlength="10" minlength="10" pattern="[6-9][0-9]{9}" placeholder="e.g. 9876543210" />
            <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label class="form-label">Email</label>
            <input value="@Model.Email" class="form-control" disabled />
            <div class="form-text"><a asp-page="./Email">Change email</a></div>
        </div>

        <div class="col-12">
            <hr class="my-1" />
            <div class="d-flex gap-2">
                <button id="update-profile-button" type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Save Changes
                </button>
                <a asp-page="./ChangePassword" class="btn btn-outline-secondary">
                    <i class="bi bi-key me-1"></i>Change Password
                </a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('profile-form').addEventListener('submit', function (e) {
            var ph = document.getElementById('Input_PhoneNumber').value.trim();
            if (ph.length > 0 && !/^[6-9][0-9]{9}$/.test(ph)) {
                e.preventDefault();
                var span = document.querySelector('[data-valmsg-for="Input.PhoneNumber"]');
                if (span) { span.textContent = 'Enter a valid 10-digit mobile number starting with 6-9.'; }
            }
        });
    </script>
}
