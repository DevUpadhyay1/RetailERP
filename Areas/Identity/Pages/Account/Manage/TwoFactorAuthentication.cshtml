@page
@model RetailERP.Areas.Identity.Pages.Account.Manage.TwoFactorAuthenticationModel
@{ ViewData["Title"] = "Two-Factor Authentication"; }

<h4><i class="bi bi-shield-lock"></i> Two-Factor Authentication (2FA)</h4>

@if (Model.Is2faEnabled)
{
    <div class="alert alert-success">
        <i class="bi bi-check-circle"></i> <strong>2FA is enabled.</strong> Your account is protected with TOTP authenticator.
    </div>

    @if (Model.RecoveryCodesLeft > 0)
    {
        <p>You have <strong>@Model.RecoveryCodesLeft</strong> recovery codes left.</p>
    }

    <form method="post" asp-page-handler="Disable" class="mt-3">
        <button class="btn btn-outline-danger">Disable 2FA</button>
    </form>
}
else
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle"></i> <strong>2FA is not enabled.</strong> 
        Enable two-factor authentication for enhanced security.
    </div>

    <a asp-page="./EnableAuthenticator" class="btn btn-primary">
        <i class="bi bi-phone"></i> Set Up Authenticator App
    </a>
}
