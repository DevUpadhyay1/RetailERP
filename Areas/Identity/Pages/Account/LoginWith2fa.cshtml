@page
@model LoginWith2faModel

@{
    ViewData["Title"] = "Two-Factor Authentication";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Two-Factor Authentication — RetailERP</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body {
            font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
            margin: 0; min-height: 100vh;
            -webkit-font-smoothing: antialiased;
        }
        h1,h2,h3,h4,h5,h6,.brand-font { font-family: 'Outfit', sans-serif; }
        .auth-split { display: flex; min-height: 100vh; }
        .auth-brand {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 60%, #0f172a 100%);
            color: #fff;
            display: flex; flex-direction: column; justify-content: center; align-items: center;
            padding: 48px;
            position: relative;
            overflow: hidden;
        }
        .auth-brand::before {
            content: '';
            position: absolute;
            width: 450px; height: 450px;
            background: radial-gradient(circle, rgba(79,70,229,.2) 0%, transparent 70%);
            top: -120px; right: -120px;
            border-radius: 50%;
        }
        .auth-brand::after {
            content: '';
            position: absolute;
            width: 350px; height: 350px;
            background: radial-gradient(circle, rgba(14,165,233,.12) 0%, transparent 70%);
            bottom: -100px; left: -80px;
            border-radius: 50%;
        }
        .auth-brand > div { position: relative; z-index: 1; }
        .auth-form-side {
            display: flex; flex-direction: column; justify-content: center; align-items: center;
            padding: 48px;
            background: #f8fafc;
        }
        .auth-card {
            width: 100%; max-width: 420px;
            background: #fff;
            border-radius: 20px;
            padding: 40px 36px;
            box-shadow: 0 4px 24px rgba(0,0,0,.06);
            border: 1px solid #e2e8f0;
        }
        .shield-icon {
            width: 72px; height: 72px;
            background: linear-gradient(135deg, #4f46e5, #7c3aed);
            border-radius: 20px;
            display: flex; align-items: center; justify-content: center;
            font-size: 2rem; color: #fff;
            margin: 0 auto 24px;
            box-shadow: 0 8px 24px rgba(79,70,229,.3);
        }
        .form-control-modern {
            border-radius: 12px;
            padding: 14px 16px;
            font-size: .95rem;
            border: 1.5px solid #e2e8f0;
            transition: all .2s;
            text-align: center;
            font-weight: 600;
            font-size: 1.5rem;
            letter-spacing: .5em;
        }
        .form-control-modern:focus {
            border-color: #4f46e5;
            box-shadow: 0 0 0 4px rgba(79,70,229,.1);
        }
        .btn-auth {
            background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
            color: #fff; border: none; border-radius: 12px;
            padding: 14px 28px; font-weight: 600;
            font-size: .95rem; width: 100%;
            transition: all .3s cubic-bezier(0.4,0,0.2,1);
        }
        .btn-auth:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 24px rgba(79,70,229,.35);
            color: #fff;
        }
        .info-box {
            background: #f0f4ff;
            border: 1px solid #c7d2fe;
            border-radius: 12px;
            padding: 14px 16px;
            font-size: .85rem;
            color: #3730a3;
        }
        @@media (max-width: 991.98px) {
            .auth-brand { display: none; }
            .auth-form-side { padding: 24px 16px; }
        }
    </style>
</head>
<body>
    <div class="auth-split">
        <!-- Left brand panel -->
        <div class="auth-brand col-lg-5 d-none d-lg-flex">
            <div class="text-center" style="max-width: 400px;">
                <div style="width:64px;height:64px;background:linear-gradient(135deg,#4f46e5,#7c3aed);border-radius:16px;display:flex;align-items:center;justify-content:center;margin:0 auto 24px;box-shadow:0 8px 24px rgba(79,70,229,.35);">
                    <i class="bi bi-layers-half" style="font-size:1.6rem;color:#fff;"></i>
                </div>
                <h2 class="brand-font fw-bold mb-2" style="font-size:1.8rem;">RetailERP</h2>
                <p class="text-white-50 mb-5" style="font-size:.95rem;">Enterprise Business Platform</p>

                <div class="text-start mx-auto" style="max-width: 340px;">
                    <div class="d-flex align-items-center gap-3 mb-4 p-3 rounded-3" style="background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);">
                        <div style="width:44px;height:44px;background:rgba(34,197,94,.15);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                            <i class="bi bi-shield-lock-fill" style="color:#22c55e;font-size:1.1rem;"></i>
                        </div>
                        <div>
                            <div class="fw-semibold" style="font-size:.88rem;">Two-Factor Security</div>
                            <div class="text-white-50" style="font-size:.78rem;">Extra layer of protection for your account</div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-3 mb-4 p-3 rounded-3" style="background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);">
                        <div style="width:44px;height:44px;background:rgba(59,130,246,.15);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                            <i class="bi bi-phone-fill" style="color:#3b82f6;font-size:1.1rem;"></i>
                        </div>
                        <div>
                            <div class="fw-semibold" style="font-size:.88rem;">Authenticator App</div>
                            <div class="text-white-50" style="font-size:.78rem;">Use Google Authenticator or Microsoft Authenticator</div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);">
                        <div style="width:44px;height:44px;background:rgba(234,179,8,.15);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                            <i class="bi bi-lock-fill" style="color:#eab308;font-size:1.1rem;"></i>
                        </div>
                        <div>
                            <div class="fw-semibold" style="font-size:.88rem;">End-to-End Encrypted</div>
                            <div class="text-white-50" style="font-size:.78rem;">Your data stays safe and private</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right form panel -->
        <div class="auth-form-side col-lg-7">
            <div class="auth-card">
                <div class="shield-icon">
                    <i class="bi bi-shield-lock-fill"></i>
                </div>

                <h3 class="brand-font fw-bold text-center mb-2">Verify Your Identity</h3>
                <p class="text-muted text-center mb-4" style="font-size:.9rem;">
                    Enter the 6-digit code from your authenticator app to continue.
                </p>

                <div class="info-box mb-4">
                    <i class="bi bi-info-circle-fill me-1"></i>
                    Open your authenticator app and enter the code displayed for your RetailERP account.
                </div>

                <form method="post">
                    <input type="hidden" name="RememberMe" value="@Model.RememberMe" />
                    <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small rounded-3" role="alert"></div>

                    <div class="mb-4">
                        <label asp-for="Input.TwoFactorCode" class="form-label fw-semibold" style="font-size:.85rem;">Authentication Code</label>
                        <input asp-for="Input.TwoFactorCode" autocomplete="off" class="form-control form-control-modern"
                               placeholder="● ● ● ● ● ●" maxlength="7" autofocus />
                        <span asp-validation-for="Input.TwoFactorCode" class="text-danger small"></span>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="Input.RememberMachine" class="form-check-input" style="border-radius:4px;" />
                        <label asp-for="Input.RememberMachine" class="form-check-label" style="font-size:.88rem;">
                            Remember this device
                        </label>
                    </div>

                    <button type="submit" class="btn btn-auth mb-3">
                        <i class="bi bi-check-circle me-2"></i>Verify & Sign In
                    </button>
                </form>

                <div class="text-center mt-3">
                    <a href="/Identity/Account/Login" class="text-decoration-none" style="font-size:.88rem;color:#4f46e5;">
                        <i class="bi bi-arrow-left me-1"></i>Back to Login
                    </a>
                </div>

                <div class="text-center mt-2">
                    <a asp-page="./LoginWithRecoveryCode" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none" style="font-size:.88rem;color:#0f766e;">
                        <i class="bi bi-key me-1"></i>Use a recovery code instead
                    </a>
                </div>
            </div>

            <p class="text-muted text-center mt-4" style="font-size:.78rem;">
                &copy; @DateTime.Now.Year RetailERP &middot; Enterprise Business Platform
            </p>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>
