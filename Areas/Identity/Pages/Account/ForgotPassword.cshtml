@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot your password?";
}

<h1>@ViewData["Title"]</h1>
<h2>Enter your email.</h2>
<hr />
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-6">
            <div class="mb-3">
                <h2 class="mb-0">Forgot password</h2>
                <div class="text-muted">We’ll send a reset link</div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label"></label>
                            <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="name@company.com" />
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            Send reset link
                        </button>

                        <div class="mt-3 small text-muted">
                            <a asp-page="./Login" class="link-primary text-decoration-none">Back to login</a>
                        </div>
                    </form>
                </div>
            </div>

            <partial name="_ValidationScriptsPartial" />
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
