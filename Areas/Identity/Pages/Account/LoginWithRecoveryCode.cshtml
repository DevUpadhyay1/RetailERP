@page
@model LoginWithRecoveryCodeModel

@{
    ViewData["Title"] = "Recovery Code Sign-In";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Recovery Code Sign-In - RetailERP</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@500;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body {
            font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
            min-height: 100vh;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background: radial-gradient(circle at 20% 20%, #dbeafe 0%, #f8fafc 40%, #eef2ff 100%);
        }

        .card-shell {
            width: 100%;
            max-width: 460px;
            border-radius: 18px;
            border: 1px solid #e2e8f0;
            box-shadow: 0 8px 30px rgba(15, 23, 42, 0.1);
            background: #ffffff;
            padding: 34px 30px;
        }

        .brand-font {
            font-family: 'Outfit', sans-serif;
        }

        .recovery-input {
            text-align: center;
            letter-spacing: .12em;
            font-weight: 600;
            border-radius: 12px;
            border: 1.5px solid #cbd5e1;
            padding: 12px 14px;
        }

        .recovery-input:focus {
            border-color: #0f766e;
            box-shadow: 0 0 0 4px rgba(15, 118, 110, 0.12);
        }

        .btn-recovery {
            border: none;
            border-radius: 12px;
            width: 100%;
            background: linear-gradient(135deg, #0f766e 0%, #0e7490 100%);
            color: #fff;
            font-weight: 600;
            padding: 12px 18px;
        }

        .btn-recovery:hover {
            color: #fff;
            filter: brightness(1.02);
        }
    </style>
</head>
<body>
    <div class="card-shell">
        <div class="text-center mb-4">
            <div class="mx-auto mb-3 d-flex align-items-center justify-content-center" style="width:64px;height:64px;border-radius:16px;background:linear-gradient(135deg,#0f766e,#0e7490);box-shadow:0 8px 20px rgba(15,118,110,.28)">
                <i class="bi bi-key-fill text-white" style="font-size:1.6rem"></i>
            </div>
            <h3 class="brand-font mb-2">Use Recovery Code</h3>
            <p class="text-muted mb-0" style="font-size:.92rem;">
                Enter one of your backup recovery codes to complete sign-in.
            </p>
        </div>

        <form method="post">
            <input type="hidden" asp-for="ReturnUrl" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small rounded-3" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Input.RecoveryCode" class="form-label fw-semibold" style="font-size:.85rem;"></label>
                <input asp-for="Input.RecoveryCode" class="form-control recovery-input" autocomplete="off" placeholder="xxxx-xxxx" />
                <span asp-validation-for="Input.RecoveryCode" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-recovery mb-3">
                <i class="bi bi-box-arrow-in-right me-2"></i>Sign In With Recovery Code
            </button>
        </form>

        <div class="text-center">
            <a href="/Identity/Account/LoginWith2fa" class="text-decoration-none" style="font-size:.88rem;color:#0f766e;">
                <i class="bi bi-arrow-left me-1"></i>Back to authenticator code
            </a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>
