@page
@model LoginModel

@{
    ViewData["Title"] = "Sign in";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign in — RetailERP</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body { font-family: 'Segoe UI', system-ui, -apple-system, sans-serif; margin: 0; min-height: 100vh; }
        .auth-split { display: flex; min-height: 100vh; }
        .auth-brand {
            background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
            color: #fff;
            display: flex; flex-direction: column; justify-content: center; align-items: center;
            padding: 48px;
        }
        .auth-brand .feature-icon {
            width: 44px; height: 44px; border-radius: 10px;
            display: flex; align-items: center; justify-content: center; font-size: 1.1rem; flex-shrink: 0;
        }
        .auth-form-side {
            display: flex; flex-direction: column; justify-content: center; align-items: center;
            padding: 48px 32px; background: #f8fafc;
        }
    </style>
</head>
<body>
    <div class="auth-split">
        <!-- ═══ LEFT: Brand panel ═══ -->
        <div class="auth-brand col-lg-5 d-none d-lg-flex">
            <div style="max-width:380px;">
                <div class="d-flex align-items-center gap-2 mb-4">
                    <div class="d-flex align-items-center justify-content-center rounded-2"
                         style="width:40px;height:40px;background:#3b82f6;color:#fff;font-size:1.1rem;">
                        <i class="bi bi-box-seam"></i>
                    </div>
                    <span class="fw-bold fs-4">RetailERP</span>
                </div>

                <h2 class="fw-bold mb-2" style="font-size:1.6rem;">Manage your retail store with confidence</h2>
                <p class="text-white-50 mb-4">Inventory, sales, purchases, stock transfers and audit logs — all from one clean dashboard.</p>

                <div class="vstack gap-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="feature-icon" style="background:rgba(59,130,246,.2);color:#60a5fa;"><i class="bi bi-boxes"></i></div>
                        <div>
                            <div class="fw-semibold">Inventory</div>
                            <div class="text-white-50 small">Stock on hand, ledger, transfers, low stock alerts</div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <div class="feature-icon" style="background:rgba(16,185,129,.2);color:#34d399;"><i class="bi bi-receipt"></i></div>
                        <div>
                            <div class="fw-semibold">Sales & Invoicing</div>
                            <div class="text-white-50 small">Create invoices, auto-deduct stock on post</div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <div class="feature-icon" style="background:rgba(245,158,11,.2);color:#fbbf24;"><i class="bi bi-people"></i></div>
                        <div>
                            <div class="fw-semibold">CRM & Suppliers</div>
                            <div class="text-white-50 small">Customers, suppliers, employees</div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <div class="feature-icon" style="background:rgba(139,92,246,.2);color:#a78bfa;"><i class="bi bi-shield-check"></i></div>
                        <div>
                            <div class="fw-semibold">Audit & Reports</div>
                            <div class="text-white-50 small">Full action log, sales reports, role-based access</div>
                        </div>
                    </div>
                </div>

                <div class="mt-5 pt-4 border-top" style="border-color:rgba(255,255,255,.12) !important;">
                    <div class="text-white-50 small">&copy; @DateTime.Now.Year RetailERP. Built with ASP.NET Core &amp; Bootstrap.</div>
                </div>
            </div>
        </div>

        <!-- ═══ RIGHT: Login form ═══ -->
        <div class="auth-form-side col-12 col-lg-7">
            <div style="width:100%;max-width:420px;">
                <!-- Mobile brand -->
                <div class="d-lg-none text-center mb-4">
                    <div class="d-inline-flex align-items-center gap-2">
                        <div class="d-flex align-items-center justify-content-center rounded-2"
                             style="width:36px;height:36px;background:#3b82f6;color:#fff;font-size:1rem;">
                            <i class="bi bi-box-seam"></i>
                        </div>
                        <span class="fw-bold fs-5">RetailERP</span>
                    </div>
                </div>

                <div class="mb-4">
                    <h2 class="fw-bold mb-1">Welcome back</h2>
                    <p class="text-muted mb-0">Sign in to your account to continue</p>
                </div>

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger py-2 small">@Model.ErrorMessage</div>
                }

                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label fw-medium"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="bi bi-envelope text-muted"></i></span>
                            <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="name@company.com" />
                        </div>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <label asp-for="Input.Password" class="form-label fw-medium mb-0"></label>
                            <a asp-page="./ForgotPassword" class="small text-decoration-none">Forgot password?</a>
                        </div>
                        <div class="input-group mt-1">
                            <span class="input-group-text bg-white"><i class="bi bi-lock text-muted"></i></span>
                            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="••••••••" />
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="form-check mb-3">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label class="form-check-label small" asp-for="Input.RememberMe">Remember me</label>
                    </div>

                    <button id="login-submit" type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Sign in
                    </button>
                </form>

                <div class="text-center mt-4 pt-3 border-top">
                    <span class="text-muted small">Don't have an account?</span>
                    @if (Model.RegistrationOpen)
                    {
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="small fw-medium text-decoration-none ms-1">Create account</a>
                    }
                    else
                    {
                        <span class="small text-muted ms-1">Contact your administrator.</span>
                    }
                </div>

                <div class="text-center mt-3">
                    <a href="/" class="small text-muted text-decoration-none"><i class="bi bi-arrow-left me-1"></i>Back to home</a>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
