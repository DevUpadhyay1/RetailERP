@page
@model LoginModel

@{
    ViewData["Title"] = "Sign in";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign in — RetailERP</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body {
            font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
            margin: 0; min-height: 100vh;
            -webkit-font-smoothing: antialiased;
        }
        .auth-split { display: flex; min-height: 100vh; }
        .auth-brand {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 60%, #0f172a 100%);
            color: #fff;
            display: flex; flex-direction: column; justify-content: center; align-items: center;
            padding: 48px;
            position: relative;
            overflow: hidden;
        }
        .auth-brand::before {
            content: '';
            position: absolute;
            width: 400px; height: 400px;
            background: radial-gradient(circle, rgba(59,130,246,.15) 0%, transparent 70%);
            top: -100px; right: -100px;
            border-radius: 50%;
        }
        .auth-brand::after {
            content: '';
            position: absolute;
            width: 300px; height: 300px;
            background: radial-gradient(circle, rgba(139,92,246,.1) 0%, transparent 70%);
            bottom: -80px; left: -60px;
            border-radius: 50%;
        }
        .auth-brand > div { position: relative; z-index: 1; }
        .auth-brand .feature-icon {
            width: 44px; height: 44px; border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem; flex-shrink: 0;
            transition: transform .2s ease;
        }
        .feature-row:hover .feature-icon { transform: scale(1.1); }
        .auth-form-side {
            display: flex; flex-direction: column; justify-content: center; align-items: center;
            padding: 48px 32px; background: #f8fafc;
        }
        .auth-brand-logo {
            width: 44px; height: 44px; border-radius: 12px;
            background: #3b82f6; color: #fff;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.2rem;
            box-shadow: 0 4px 12px rgba(59,130,246,.35);
        }
        .form-control { border-radius: .5rem; }
        .form-control:focus { border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,.15); }
        .input-group-text { border-radius: .5rem 0 0 .5rem; }
        .btn-primary { background: #3b82f6; border-color: #3b82f6; border-radius: .5rem; }
        .btn-primary:hover { background: #2563eb; border-color: #2563eb; }
        .btn:active { transform: scale(.97); }
    </style>
</head>
<body>
    <div class="auth-split">
        <div class="auth-brand col-lg-5 d-none d-lg-flex">
            <div style="max-width:400px;">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="auth-brand-logo">
                        <i class="bi bi-box-seam"></i>
                    </div>
                    <span class="fw-bold fs-3">RetailERP</span>
                </div>

                <h2 class="fw-bold mb-2" style="font-size:1.7rem;line-height:1.3;">Manage your retail store with confidence</h2>
                <p class="mb-4" style="color:rgba(255,255,255,.55);line-height:1.6;">Inventory, sales, purchases, stock transfers and audit logs — all from one clean dashboard.</p>

                <div class="vstack gap-3">
                    <div class="d-flex align-items-center gap-3 feature-row">
                        <div class="feature-icon" style="background:rgba(59,130,246,.15);color:#60a5fa;"><i class="bi bi-boxes"></i></div>
                        <div>
                            <div class="fw-semibold">Inventory</div>
                            <div style="color:rgba(255,255,255,.45);font-size:.85rem;">Stock on hand, ledger, transfers, low stock alerts</div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-3 feature-row">
                        <div class="feature-icon" style="background:rgba(16,185,129,.15);color:#34d399;"><i class="bi bi-receipt"></i></div>
                        <div>
                            <div class="fw-semibold">Sales & Invoicing</div>
                            <div style="color:rgba(255,255,255,.45);font-size:.85rem;">Create invoices, auto-deduct stock on post</div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-3 feature-row">
                        <div class="feature-icon" style="background:rgba(245,158,11,.15);color:#fbbf24;"><i class="bi bi-people"></i></div>
                        <div>
                            <div class="fw-semibold">CRM & Suppliers</div>
                            <div style="color:rgba(255,255,255,.45);font-size:.85rem;">Customers, suppliers, employees</div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-3 feature-row">
                        <div class="feature-icon" style="background:rgba(139,92,246,.15);color:#a78bfa;"><i class="bi bi-shield-check"></i></div>
                        <div>
                            <div class="fw-semibold">Audit & Reports</div>
                            <div style="color:rgba(255,255,255,.45);font-size:.85rem;">Full action log, sales reports, role-based access</div>
                        </div>
                    </div>
                </div>

                <div class="mt-5 pt-4" style="border-top:1px solid rgba(255,255,255,.08);">
                    <div style="color:rgba(255,255,255,.35);font-size:.8rem;">&copy; @DateTime.Now.Year RetailERP. Built with ASP.NET Core & Bootstrap.</div>
                </div>
            </div>
        </div>

        <div class="auth-form-side col-12 col-lg-7">
            <div style="width:100%;max-width:420px;">
                <div class="d-lg-none text-center mb-4">
                    <div class="d-inline-flex align-items-center gap-2">
                        <div class="auth-brand-logo" style="width:36px;height:36px;font-size:1rem;border-radius:10px;">
                            <i class="bi bi-box-seam"></i>
                        </div>
                        <span class="fw-bold fs-5">RetailERP</span>
                    </div>
                </div>

                <div class="mb-4">
                    <h2 class="fw-bold mb-1" style="font-size:1.5rem;">Welcome back</h2>
                    <p class="text-muted mb-0">Sign in to your account to continue</p>
                </div>

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger py-2 small d-flex align-items-center gap-2">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        @Model.ErrorMessage
                    </div>
                }

                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label fw-medium" style="font-size:.85rem;"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="bi bi-envelope text-muted"></i></span>
                            <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="name@company.com" />
                        </div>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <label asp-for="Input.Password" class="form-label fw-medium mb-0" style="font-size:.85rem;"></label>
                            <a asp-page="./ForgotPassword" class="small text-decoration-none" style="color:#3b82f6;">Forgot password?</a>
                        </div>
                        <div class="input-group mt-1">
                            <span class="input-group-text bg-white"><i class="bi bi-lock text-muted"></i></span>
                            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="••••••••" />
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="form-check mb-3">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label class="form-check-label small" asp-for="Input.RememberMe">Remember me</label>
                    </div>

                    <button id="login-submit" type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Sign in
                    </button>
                </form>

                <div class="text-center mt-4 pt-3 border-top">
                    <span class="text-muted small">Don't have an account?</span>
                    @if (Model.RegistrationOpen)
                    {
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="small fw-medium text-decoration-none ms-1" style="color:#3b82f6;">Create account</a>
                    }
                    else
                    {
                        <span class="small text-muted ms-1">Contact your administrator.</span>
                    }
                </div>

                <div class="text-center mt-3">
                    <a href="/" class="small text-muted text-decoration-none"><i class="bi bi-arrow-left me-1"></i>Back to home</a>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
