@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<h1>@ViewData["Title"]</h1>
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">
            <div class="d-flex justify-content-between align-items-end mb-3">
                <div>
                    <h2 class="mb-0">Sign in</h2>
                    <div class="text-muted">RetailERP • Secure access</div>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-lg-6">
                    <div class="card shadow-sm border-0">
                        <div class="card-body p-4">
                            <form id="account" method="post">
                                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3" role="alert"></div>

                                <div class="mb-3">
                                    <label asp-for="Input.Email" class="form-label"></label>
                                    <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="name@company.com" />
                                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Input.Password" class="form-label"></label>
                                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="••••••••" />
                                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                                </div>

                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div class="form-check">
                                        <input class="form-check-input" asp-for="Input.RememberMe" />
                                        <label class="form-check-label" asp-for="Input.RememberMe"></label>
                                    </div>
                                    <a id="forgot-password" asp-page="./ForgotPassword" class="link-primary text-decoration-none">
                                        Forgot password?
                                    </a>
                                </div>

                                <button id="login-submit" type="submit" class="btn btn-primary w-100">
                                    Log in
                                </button>

                                <div class="mt-3 small text-muted">
                                    New here?
                                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="link-primary text-decoration-none">
                                        Create an account
                                    </a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="card border-0 bg-light shadow-sm">
                        <div class="card-body p-4">
                            <h5 class="mb-2">What you can do</h5>
                            <ul class="mb-0 text-muted">
                                <li>Inventory: Items, Warehouses, Stock</li>
                                <li>Sales: Invoice Register</li>
                                <li>HR: Employees</li>
                                <li>Reports: Outstanding</li>
                            </ul>
                            <hr class="my-4" />
                            <div class="text-muted small">
                                Tip: Use a demo admin account for presentation (Seeder).
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <partial name="_ValidationScriptsPartial" />
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
