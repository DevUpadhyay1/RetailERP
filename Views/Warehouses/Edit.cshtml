@model RetailERP.Data.Entities.Warehouse

@{
    ViewData["Title"] = "Edit Warehouse";
}

<div class="vstack gap-3" style="max-width:720px;">
    <div class="d-flex align-items-center justify-content-between">
        <h2 class="mb-0">Edit Warehouse</h2>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back to List
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="WarehouseId" />
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="StoreId" class="form-label">Store</label>
                        <select asp-for="StoreId" class="form-select" asp-items="@(ViewData["StoreId"] as SelectList)">
                            <option value="">(Not linked)</option>
                        </select>
                        <span asp-validation-for="StoreId" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Address" class="form-label"></label>
                        <input asp-for="Address" class="form-control" />
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <hr class="my-1" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Save</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
