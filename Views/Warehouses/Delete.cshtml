@model RetailERP.Data.Entities.Warehouse

@{
    ViewData["Title"] = "Delete Warehouse";
}

<div class="vstack gap-3" style="max-width:720px;">
    <div class="d-flex align-items-center justify-content-between">
        <h2 class="mb-0">Delete Warehouse</h2>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back to List
        </a>
    </div>

    <div class="alert alert-warning d-flex align-items-center gap-2 mb-0">
        <i class="bi bi-exclamation-triangle"></i>
        Are you sure you want to permanently delete this warehouse?
    </div>

    <div class="card border-danger border-opacity-50 shadow-sm">
        <div class="card-body p-4">
            <dl class="row mb-0">
                <dt class="col-sm-3 text-muted">Name</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Name)</dd>
                <dt class="col-sm-3 text-muted">Store</dt>
                <dd class="col-sm-9">@(Model.Store == null ? "—" : (Model.Store.StoreCode + " – " + Model.Store.Name))</dd>
                <dt class="col-sm-3 text-muted">Address</dt>
                <dd class="col-sm-9 mb-0">@(Model.Address ?? "—")</dd>
            </dl>
        </div>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="WarehouseId" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Confirm Delete</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
