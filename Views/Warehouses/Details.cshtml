@model RetailERP.Data.Entities.Warehouse

@{
    ViewData["Title"] = "Warehouse Details";
}

<div class="vstack gap-3" style="max-width:720px;">
    <div class="d-flex align-items-center justify-content-between">
        <h2 class="mb-0">Warehouse Details</h2>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back to List
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <dl class="row mb-0">
                <dt class="col-sm-3 text-muted">Name</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Name)</dd>
                <dt class="col-sm-3 text-muted">Store</dt>
                <dd class="col-sm-9">@(Model.Store == null ? "—" : (Model.Store.StoreCode + " – " + Model.Store.Name))</dd>
                <dt class="col-sm-3 text-muted">Address</dt>
                <dd class="col-sm-9 mb-0">@(Model.Address ?? "—")</dd>
            </dl>
        </div>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model?.WarehouseId" class="btn btn-primary btn-sm"><i class="bi bi-pencil me-1"></i>Edit</a>
        <a asp-action="Delete" asp-route-id="@Model?.WarehouseId" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash me-1"></i>Delete</a>
    </div>
</div>
