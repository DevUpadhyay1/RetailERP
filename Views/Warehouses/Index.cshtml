@model IEnumerable<RetailERP.Data.Entities.Warehouse>

@{
    ViewData["Title"] = "Warehouses";
    var q = (ViewData["q"] as string) ?? "";
    var sort = (ViewData["sort"] as string) ?? "name";
    var dir = (ViewData["dir"] as string) ?? "asc";
    var pageNumber = (ViewData["page"] as int?) ?? 1;
    var pageSize = (ViewData["pageSize"] as int?) ?? 20;
    var total = (ViewData["total"] as int?) ?? 0;
    var from = (ViewData["from"] as int?) ?? 0;
    var to = (ViewData["to"] as int?) ?? 0;
    var totalPages = (ViewData["totalPages"] as int?) ?? 1;
    var rows = Model ?? Enumerable.Empty<RetailERP.Data.Entities.Warehouse>();

    string ToggleDir(string nextSort)
    {
        if (!string.Equals(sort, nextSort, StringComparison.OrdinalIgnoreCase)) return "asc";
        return string.Equals(dir, "asc", StringComparison.OrdinalIgnoreCase) ? "desc" : "asc";
    }
}

<div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h2 class="mb-0">@ViewData["Title"]</h2>
            <div class="text-muted small">Showing @from-@to of @total</div>
        </div>

        <a class="btn btn-primary" asp-action="Create">
            + Add Warehouse
        </a>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <form method="get" class="row g-2 align-items-center">
                <div class="col-md-6">
                    <input name="q" value="@q" class="form-control"
                           placeholder="Search by Name or Address..." />
                </div>

                <input type="hidden" name="sort" value="@sort" />
                <input type="hidden" name="dir" value="@dir" />
                <input type="hidden" name="pageSize" value="@pageSize" />

                <div class="col-auto">
                    <button class="btn btn-outline-secondary" type="submit">Search</button>
                </div>

                <div class="col-auto">
                    <a class="btn btn-outline-dark" asp-action="Index">Reset</a>
                </div>

                <div class="col-auto ms-auto">
                    <span class="badge bg-light text-dark border">
                        Updated: @DateTime.Now.ToString("dd-MMM-yyyy")
                    </span>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (total == 0)
            {
                <div class="p-4">
                    <div class="alert alert-warning mb-0">
                        No warehouses found.
                        <a asp-action="Create" class="alert-link">Create your first warehouse</a>.
                    </div>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>
                                    <a class="text-decoration-none" asp-action="Index" asp-route-q="@q" asp-route-sort="name" asp-route-dir="@ToggleDir("name")" asp-route-page="1" asp-route-pageSize="@pageSize">Name</a>
                                </th>
                                <th>
                                    <a class="text-decoration-none" asp-action="Index" asp-route-q="@q" asp-route-sort="store" asp-route-dir="@ToggleDir("store")" asp-route-page="1" asp-route-pageSize="@pageSize">Store</a>
                                </th>
                                <th>
                                    <a class="text-decoration-none" asp-action="Index" asp-route-q="@q" asp-route-sort="address" asp-route-dir="@ToggleDir("address")" asp-route-page="1" asp-route-pageSize="@pageSize">Address</a>
                                </th>
                                <th class="text-end" style="width: 170px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var w in rows)
                            {
                                <tr>
                                    <td class="fw-semibold">@w.Name</td>
                                    <td>@(w.Store == null ? "-" : (w.Store.StoreCode + " - " + w.Store.Name))</td>
                                    <td>@(string.IsNullOrWhiteSpace(w.Address) ? "-" : w.Address)</td>
                                    <td class="text-end">
                                        <div class="btn-group">
                                            <a class="btn btn-sm btn-outline-primary"
                                               asp-action="Edit" asp-route-id="@w.WarehouseId">Edit</a>

                                            <a class="btn btn-sm btn-outline-secondary"
                                               asp-action="Details" asp-route-id="@w.WarehouseId">View</a>

                                            <a class="btn btn-sm btn-outline-danger"
                                               asp-action="Delete" asp-route-id="@w.WarehouseId">Delete</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 p-3 border-top">
                    <div class="text-muted small">Page @pageNumber of @totalPages</div>

                    <form method="get" class="d-flex align-items-center gap-2">
                        <input type="hidden" name="q" value="@q" />
                        <input type="hidden" name="sort" value="@sort" />
                        <input type="hidden" name="dir" value="@dir" />
                        <input type="hidden" name="page" value="1" />
                        <label class="text-muted small">Rows</label>
                        <select class="form-select form-select-sm" name="pageSize" onchange="this.form.submit()" style="width: 110px;">
                            <option value="10" selected="@(pageSize==10)">10</option>
                            <option value="20" selected="@(pageSize==20)">20</option>
                            <option value="50" selected="@(pageSize==50)">50</option>
                        </select>
                    </form>

                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(pageNumber <= 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="Index" asp-route-q="@q" asp-route-sort="@sort" asp-route-dir="@dir" asp-route-page="@(pageNumber-1)" asp-route-pageSize="@pageSize">Prev</a>
                            </li>
                            @for (var p = Math.Max(1, pageNumber - 2); p <= Math.Min(totalPages, pageNumber + 2); p++)
                            {
                                <li class="page-item @(p == pageNumber ? "active" : "")">
                                    <a class="page-link" asp-action="Index" asp-route-q="@q" asp-route-sort="@sort" asp-route-dir="@dir" asp-route-page="@p" asp-route-pageSize="@pageSize">@p</a>
                                </li>
                            }
                            <li class="page-item @(pageNumber >= totalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="Index" asp-route-q="@q" asp-route-sort="@sort" asp-route-dir="@dir" asp-route-page="@(pageNumber+1)" asp-route-pageSize="@pageSize">Next</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    </div>
