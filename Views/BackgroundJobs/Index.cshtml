@{
    ViewData["Title"] = "Background Jobs Monitor";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h2 class="mb-0"><i class="bi bi-gear-wide-connected me-2"></i>Background Jobs Monitor</h2>
        <small class="text-muted">Sprint 9 — Real-time workers status &amp; queue health</small>
    </div>
    <button class="btn btn-outline-secondary" onclick="location.reload()"><i class="bi bi-arrow-clockwise me-1"></i>Refresh</button>
</div>

<!-- Worker Status Cards -->
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body text-center">
                <div class="rounded-circle bg-success bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width:56px;height:56px;">
                    <i class="bi bi-envelope-arrow-up fs-3 text-success"></i>
                </div>
                <h6 class="text-muted mb-1">Email Worker</h6>
                <span class="badge bg-success fs-6">Running</span>
                <p class="text-muted small mt-2 mb-0">Processes queued emails via SMTP in background</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body text-center">
                <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width:56px;height:56px;">
                    <i class="bi bi-arrow-repeat fs-3 text-primary"></i>
                </div>
                <h6 class="text-muted mb-1">Sync Queue Worker</h6>
                <span class="badge bg-success fs-6">Running</span>
                <p class="text-muted small mt-2 mb-0">Processes pending sync entries every 60 seconds</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body text-center">
                <div class="rounded-circle bg-warning bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width:56px;height:56px;">
                    <i class="bi bi-exclamation-triangle fs-3 text-warning"></i>
                </div>
                <h6 class="text-muted mb-1">Stock Alert Worker</h6>
                <span class="badge bg-success fs-6">Running</span>
                <p class="text-muted small mt-2 mb-0">Checks low-stock items every 15 minutes</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body text-center">
                <div class="rounded-circle bg-info bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width:56px;height:56px;">
                    <i class="bi bi-calendar-check fs-3 text-info"></i>
                </div>
                <h6 class="text-muted mb-1">EOD Auto Worker</h6>
                <span class="badge bg-success fs-6">Running</span>
                <p class="text-muted small mt-2 mb-0">Auto-generates EOD reports at 10:00 PM IST</p>
            </div>
        </div>
    </div>
</div>

<!-- Queue Stats -->
<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="card shadow-sm border-0">
            <div class="card-header fw-semibold"><i class="bi bi-arrow-repeat me-2"></i>Sync Queue</div>
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-4">
                        <div class="display-6 fw-bold text-warning">@ViewBag.SyncPending</div>
                        <div class="text-muted small">Pending</div>
                    </div>
                    <div class="col-4">
                        <div class="display-6 fw-bold text-success">@ViewBag.SyncSynced</div>
                        <div class="text-muted small">Synced</div>
                    </div>
                    <div class="col-4">
                        <div class="display-6 fw-bold text-danger">@ViewBag.SyncConflict</div>
                        <div class="text-muted small">Conflicts</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card shadow-sm border-0">
            <div class="card-header fw-semibold"><i class="bi bi-clipboard-data me-2"></i>Daily Stats</div>
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-6">
                        <div class="display-6 fw-bold text-primary">@ViewBag.TodayEodReports</div>
                        <div class="text-muted small">EOD Reports Today</div>
                    </div>
                    <div class="col-6">
                        <div class="display-6 fw-bold text-danger">@ViewBag.LowStockItems</div>
                        <div class="text-muted small">Low Stock Items</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- SignalR Connection Status -->
<div class="card shadow-sm border-0">
    <div class="card-header fw-semibold"><i class="bi bi-broadcast me-2"></i>Real-Time Connection (SignalR)</div>
    <div class="card-body">
        <div class="d-flex align-items-center gap-3">
            <span id="signalr-indicator" class="rounded-circle bg-secondary" style="width:14px;height:14px;display:inline-block;"></span>
            <span id="signalr-status" class="text-muted">Connecting…</span>
        </div>
        <div id="signalr-events" class="mt-3" style="max-height:300px;overflow-y:auto;"></div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.7/dist/browser/signalr.min.js"></script>
    <script>
        (function () {
            const indicator = document.getElementById('signalr-indicator');
            const statusEl = document.getElementById('signalr-status');
            const eventsEl = document.getElementById('signalr-events');

            const connection = new signalR.HubConnectionBuilder()
                .withUrl('/hubs/retail')
                .withAutomaticReconnect()
                .build();

            function setStatus(color, text) {
                indicator.className = 'rounded-circle bg-' + color;
                indicator.style.cssText = 'width:14px;height:14px;display:inline-block;';
                statusEl.textContent = text;
            }

            function addEvent(icon, msg) {
                const div = document.createElement('div');
                div.className = 'small border-bottom py-1';
                div.innerHTML = `<i class="bi ${icon} me-1"></i>${msg} <span class="text-muted float-end">${new Date().toLocaleTimeString()}</span>`;
                eventsEl.prepend(div);
            }

            connection.onreconnecting(() => setStatus('warning', 'Reconnecting…'));
            connection.onreconnected(() => setStatus('success', 'Connected'));
            connection.onclose(() => setStatus('danger', 'Disconnected'));

            connection.on('BillCompleted', data => addEvent('bi-cart-check text-success', `POS Bill ${data.billNo} completed — ₹${data.grandTotal.toLocaleString('en-IN')}`));
            connection.on('StockAlert', data => addEvent('bi-exclamation-triangle text-warning', `${data.count} items below reorder level`));
            connection.on('EodReportGenerated', data => addEvent('bi-calendar-check text-info', `EOD report generated for store on ${data.reportDate}`));
            connection.on('InvoicePosted', data => addEvent('bi-receipt text-primary', `Invoice ${data.invoiceNo} posted — ₹${data.grandTotal.toLocaleString('en-IN')}`));

            connection.start()
                .then(() => setStatus('success', 'Connected'))
                .catch(err => { setStatus('danger', 'Connection failed'); console.error(err); });
        })();
    </script>
}
