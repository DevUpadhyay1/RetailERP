@model IEnumerable<RetailERP.Data.Entities.Item>

@{
    ViewData["Title"] = "Items";
    var q = (ViewData["q"] as string) ?? "";
    var active = (ViewData["active"] as bool?);
    var sort = (ViewData["sort"] as string) ?? "sku";
    var dir = (ViewData["dir"] as string) ?? "asc";
    var pageNumber = (ViewData["page"] as int?) ?? 1;
    var pageSize = (ViewData["pageSize"] as int?) ?? 20;
    var total = (ViewData["total"] as int?) ?? 0;
    var from = (ViewData["from"] as int?) ?? 0;
    var to = (ViewData["to"] as int?) ?? 0;
    var totalPages = (ViewData["totalPages"] as int?) ?? 1;
    var rows = Model ?? Enumerable.Empty<RetailERP.Data.Entities.Item>();

    string ToggleDir(string nextSort)
    {
        if (!string.Equals(sort, nextSort, StringComparison.OrdinalIgnoreCase)) return "asc";
        return string.Equals(dir, "asc", StringComparison.OrdinalIgnoreCase) ? "desc" : "asc";
    }
}

<div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h2 class="mb-0">@ViewData["Title"]</h2>
            <div class="text-muted small">Showing @from-@to of @total</div>
        </div>

        <div class="d-flex gap-2">
            <a class="btn btn-outline-primary" asp-controller="ItemOnboarding" asp-action="Index">
                Import / Starter Pack
            </a>
            <a class="btn btn-primary" asp-action="Create">
                + Add Item
            </a>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <form method="get" class="row g-2 align-items-center">
                <div class="col-md-6">
                    <input name="q" value="@q" class="form-control"
                           placeholder="Search by SKU or Name..." />
                </div>

                <div class="col-md-3">
                    <select class="form-select" name="active">
                        <option value="" selected="@(active is null)">All statuses</option>
                        <option value="true" selected="@(active is true)">Active</option>
                        <option value="false" selected="@(active is false)">Inactive</option>
                    </select>
                </div>

                <input type="hidden" name="sort" value="@sort" />
                <input type="hidden" name="dir" value="@dir" />
                <input type="hidden" name="pageSize" value="@pageSize" />

                <div class="col-auto">
                    <button class="btn btn-outline-secondary" type="submit">Apply</button>
                </div>

                <div class="col-auto">
                    <a class="btn btn-outline-dark" asp-action="Index">Reset</a>
                </div>

            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (total == 0)
            {
                <div class="p-4">
                    <div class="alert alert-warning mb-0">
                        No items found.
                        <a asp-action="Create" class="alert-link">Create your first item</a>.
                    </div>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>
                                    <a class="text-decoration-none" asp-action="Index" asp-route-q="@q" asp-route-active="@active" asp-route-sort="sku" asp-route-dir="@ToggleDir("sku")" asp-route-page="1" asp-route-pageSize="@pageSize">SKU</a>
                                </th>
                                <th>
                                    <a class="text-decoration-none" asp-action="Index" asp-route-q="@q" asp-route-active="@active" asp-route-sort="name" asp-route-dir="@ToggleDir("name")" asp-route-page="1" asp-route-pageSize="@pageSize">Name</a>
                                </th>
                                <th>Barcode</th>
                                <th>Unit</th>
                                <th>
                                    <a class="text-decoration-none" asp-action="Index" asp-route-q="@q" asp-route-active="@active" asp-route-sort="category" asp-route-dir="@ToggleDir("category")" asp-route-page="1" asp-route-pageSize="@pageSize">Category</a>
                                </th>
                                <th class="text-end">
                                    <a class="text-decoration-none" asp-action="Index" asp-route-q="@q" asp-route-active="@active" asp-route-sort="price" asp-route-dir="@ToggleDir("price")" asp-route-page="1" asp-route-pageSize="@pageSize">Unit Price</a>
                                </th>
                                <th class="text-end">MRP</th>
                                <th class="text-end">GST %</th>
                                <th>HSN</th>
                                <th class="text-end">Reorder (Min Stock)</th>
                                <th>
                                    <a class="text-decoration-none" asp-action="Index" asp-route-q="@q" asp-route-active="@active" asp-route-sort="status" asp-route-dir="@ToggleDir("status")" asp-route-page="1" asp-route-pageSize="@pageSize">Status</a>
                                </th>
                                <th class="text-end" style="width: 170px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in rows)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.SKU</td>
                                    <td>@item.Name</td>
                                    <td>@(string.IsNullOrWhiteSpace(item.Barcode) ? "—" : item.Barcode)</td>
                                    <td>@(item.Unit?.Name ?? "—")</td>
                                    <td>@(item.Category?.Name ?? "—")</td>
                                    <td class="text-end">@item.UnitPrice.ToString("0.00")</td>
                                    <td class="text-end">@(item.MRP.HasValue ? item.MRP.Value.ToString("0.00") : "—")</td>
                                    <td class="text-end">@(item.GstPercent.HasValue ? item.GstPercent.Value.ToString("0.##") : "—")</td>
                                    <td>@(string.IsNullOrWhiteSpace(item.HsnCode) ? "—" : item.HsnCode)</td>
                                    <td class="text-end">@item.ReorderLevel</td>
                                    <td>
                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group">
                                            <a class="btn btn-sm btn-outline-primary"
                                               asp-action="Edit" asp-route-id="@item.ItemId">Edit</a>

                                            <a class="btn btn-sm btn-outline-secondary"
                                               asp-action="Details" asp-route-id="@item.ItemId">View</a>

                                            <a class="btn btn-sm btn-outline-danger"
                                               asp-action="Delete" asp-route-id="@item.ItemId">Delete</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 p-3 border-top">
                    <div class="text-muted small">Page @pageNumber of @totalPages</div>

                    <form method="get" class="d-flex align-items-center gap-2">
                        <input type="hidden" name="q" value="@q" />
                        <input type="hidden" name="active" value="@active" />
                        <input type="hidden" name="sort" value="@sort" />
                        <input type="hidden" name="dir" value="@dir" />
                        <input type="hidden" name="page" value="1" />
                        <label class="text-muted small">Rows</label>
                        <select class="form-select form-select-sm" name="pageSize" onchange="this.form.submit()" style="width: 110px;">
                            <option value="10" selected="@(pageSize==10)">10</option>
                            <option value="20" selected="@(pageSize==20)">20</option>
                            <option value="50" selected="@(pageSize==50)">50</option>
                        </select>
                    </form>

                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(pageNumber <= 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="Index" asp-route-q="@q" asp-route-active="@active" asp-route-sort="@sort" asp-route-dir="@dir" asp-route-page="@(pageNumber-1)" asp-route-pageSize="@pageSize">Prev</a>
                            </li>
                            @for (var p = Math.Max(1, pageNumber - 2); p <= Math.Min(totalPages, pageNumber + 2); p++)
                            {
                                <li class="page-item @(p == pageNumber ? "active" : "")">
                                    <a class="page-link" asp-action="Index" asp-route-q="@q" asp-route-active="@active" asp-route-sort="@sort" asp-route-dir="@dir" asp-route-page="@p" asp-route-pageSize="@pageSize">@p</a>
                                </li>
                            }
                            <li class="page-item @(pageNumber >= totalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="Index" asp-route-q="@q" asp-route-active="@active" asp-route-sort="@sort" asp-route-dir="@dir" asp-route-page="@(pageNumber+1)" asp-route-pageSize="@pageSize">Next</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    </div>
