@model IEnumerable<RetailERP.Data.Entities.Item>

@{
    ViewData["Title"] = "Items";
    var q = (ViewData["q"] as string) ?? "";
    var count = Model?.Count() ?? 0;
}

<div class="container-fluid py-3">

    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h2 class="mb-0">@ViewData["Title"]</h2>
            <div class="text-muted small">Total: @count record(s)</div>
        </div>

        <a class="btn btn-primary" asp-action="Create">
            + Add Item
        </a>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <form method="get" class="row g-2 align-items-center">
                <div class="col-md-6">
                    <input name="q" value="@q" class="form-control"
                           placeholder="Search by SKU or Name..." />
                </div>

                <div class="col-auto">
                    <button class="btn btn-outline-secondary" type="submit">Search</button>
                </div>

                <div class="col-auto">
                    <a class="btn btn-outline-dark" asp-action="Index">Reset</a>
                </div>

                <div class="col-auto ms-auto">
                    <span class="badge text-bg-light border">
                        Updated: @DateTime.Now.ToString("dd-MMM-yyyy")
                    </span>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (count == 0)
            {
                <div class="p-4">
                    <div class="alert alert-warning mb-0">
                        No items found.
                        <a asp-action="Create" class="alert-link">Create your first item</a>.
                    </div>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>SKU</th>
                                <th>Name</th>
                                <th class="text-end">Unit Price</th>
                                <th class="text-end">Reorder</th>
                                <th>Status</th>
                                <th class="text-end" style="width: 170px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.SKU</td>
                                    <td>@item.Name</td>
                                    <td class="text-end">@item.UnitPrice.ToString("0.00")</td>
                                    <td class="text-end">@item.ReorderLevel</td>
                                    <td>
                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group">
                                            <a class="btn btn-sm btn-outline-primary"
                                               asp-action="Edit" asp-route-id="@item.ItemId">Edit</a>

                                            <a class="btn btn-sm btn-outline-secondary"
                                               asp-action="Details" asp-route-id="@item.ItemId">View</a>

                                            <a class="btn btn-sm btn-outline-danger"
                                               asp-action="Delete" asp-route-id="@item.ItemId">Delete</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

</div>