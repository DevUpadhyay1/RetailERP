@model RetailERP.Data.Entities.Item

@{
    ViewData["Title"] = "Item Details";
}

<div class="vstack gap-3" style="max-width:980px;">
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <h2 class="mb-0">Item Details</h2>
            <div class="text-muted small">@Model.SKU • @Model.Name</div>
        </div>
        <a class="btn btn-outline-secondary btn-sm" asp-action="Index"><i class="bi bi-arrow-left me-1"></i>Back to List</a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="text-muted small">SKU</div>
                    <div class="fw-semibold">@Model.SKU</div>
                </div>
                <div class="col-md-8">
                    <div class="text-muted small">Name</div>
                    <div class="fw-semibold">@Model.Name</div>
                </div>

                <div class="col-md-4">
                    <div class="text-muted small">Barcode</div>
                    <div>@(string.IsNullOrWhiteSpace(Model.Barcode) ? "—" : Model.Barcode)</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small">Unit</div>
                    <div>@(Model.Unit?.Name ?? "—")</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small">Category</div>
                    <div>@(Model.Category?.Name ?? "—")</div>
                </div>

                <div class="col-md-4">
                    <div class="text-muted small">Unit Price</div>
                    <div>@Model.UnitPrice.ToString("0.00")</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small">MRP</div>
                    <div>@(Model.MRP.HasValue ? Model.MRP.Value.ToString("0.00") : "—")</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small">Purchase Price</div>
                    <div>@(Model.PurchasePrice.HasValue ? Model.PurchasePrice.Value.ToString("0.00") : "—")</div>
                </div>

                <div class="col-md-4">
                    <div class="text-muted small">GST %</div>
                    <div>@(Model.GstPercent.HasValue ? Model.GstPercent.Value.ToString("0.##") : "—")</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small">HSN</div>
                    <div>@(string.IsNullOrWhiteSpace(Model.HsnCode) ? "—" : Model.HsnCode)</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small">Reorder Level</div>
                    <div>@Model.ReorderLevel</div>
                </div>

                <div class="col-md-4">
                    <div class="text-muted small">Status</div>
                    <div>
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </div>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.ItemId"><i class="bi bi-pencil me-1"></i>Edit</a>
                <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.ItemId"><i class="bi bi-trash me-1"></i>Delete</a>
            </div>
        </div>
    </div>
</div>
