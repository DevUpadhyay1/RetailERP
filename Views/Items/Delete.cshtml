@model RetailERP.Data.Entities.Item

@{
    ViewData["Title"] = "Delete Item";
    var hasReferences = (ViewData["HasReferences"] as bool?) ?? false;
}

<div class="vstack gap-3" style="max-width:980px;">
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <h2 class="mb-0">Delete Item</h2>
            <div class="text-muted small">This action cannot be undone</div>
        </div>
        <a class="btn btn-outline-secondary btn-sm" asp-action="Index"><i class="bi bi-arrow-left me-1"></i>Back to List</a>
    </div>

    <div class="alert alert-warning" role="alert">
        You are about to permanently delete: <strong>@Model.SKU</strong> — @Model.Name
    </div>

    @if (TempData["Err"] is string err)
    {
        <div class="alert alert-danger" role="alert">@err</div>
    }
    @if (TempData["Ok"] is string ok)
    {
        <div class="alert alert-success" role="alert">@ok</div>
    }

    @if (hasReferences)
    {
        <div class="alert alert-danger" role="alert">
            This item cannot be deleted because it is referenced by stock/transactions.
            Use <strong>Edit</strong> and set <strong>IsActive = false</strong> instead.
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="text-muted small">Barcode</div>
                    <div>@(string.IsNullOrWhiteSpace(Model.Barcode) ? "—" : Model.Barcode)</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small">Unit</div>
                    <div>@(Model.Unit?.Name ?? "—")</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small">Category</div>
                    <div>@(Model.Category?.Name ?? "—")</div>
                </div>

                <div class="col-md-4">
                    <div class="text-muted small">Unit Price</div>
                    <div>@Model.UnitPrice.ToString("0.00")</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small">MRP</div>
                    <div>@(Model.MRP.HasValue ? Model.MRP.Value.ToString("0.00") : "—")</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small">Purchase Price</div>
                    <div>@(Model.PurchasePrice.HasValue ? Model.PurchasePrice.Value.ToString("0.00") : "—")</div>
                </div>

                <div class="col-md-4">
                    <div class="text-muted small">GST %</div>
                    <div>@(Model.GstPercent.HasValue ? Model.GstPercent.Value.ToString("0.##") : "—")</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small">HSN</div>
                    <div>@(string.IsNullOrWhiteSpace(Model.HsnCode) ? "—" : Model.HsnCode)</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small">Reorder Level</div>
                    <div>@Model.ReorderLevel</div>
                </div>
            </div>

            <form asp-action="Delete" method="post" class="mt-4 d-flex gap-2">
                <input type="hidden" asp-for="ItemId" />
                <button type="submit" class="btn btn-danger" @(hasReferences ? "disabled" : "")><i class="bi bi-trash me-1"></i>Delete</button>
                <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.ItemId"><i class="bi bi-pencil me-1"></i>Edit</a>
                <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
