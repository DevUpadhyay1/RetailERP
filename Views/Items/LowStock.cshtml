@model List<RetailERP.Controllers.ItemsController.LowStockRow>
@{
    ViewData["Title"] = "Low Stock";
}

<div class="vstack gap-3">
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <h2 class="mb-0">Low Stock</h2>
            <div class="text-muted small">Items at or below reorder level</div>
        </div>
        <a class="btn btn-outline-secondary btn-sm" asp-controller="Stocks" asp-action="Index"><i class="bi bi-arrow-left me-1"></i>Stock On Hand</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width:140px;">SKU</th>
                            <th>Item</th>
                            <th class="text-end" style="width:140px;">On Hand</th>
                            <th class="text-end" style="width:160px;">Reorder Level</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr><td colspan="4" class="text-center text-muted py-4"><i class="bi bi-check-circle me-1"></i>All items are above reorder level</td></tr>
                        }
                        else
                        {
                            @foreach (var r in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@r.SKU</td>
                                    <td>@r.Name</td>
                                    <td class="text-end">
                                        @if (r.OnHand <= 0)
                                        {
                                            <span class="badge bg-danger">@r.OnHand.ToString("0.##")</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">@r.OnHand.ToString("0.##")</span>
                                        }
                                    </td>
                                    <td class="text-end">@r.ReorderLevel.ToString("0.##")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>