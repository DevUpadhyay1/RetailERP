@{
    ViewData["Title"] = "New Loyalty Card";
}

@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger alert-dismissible fade show">@err <button class="btn-close" data-bs-dismiss="alert"></button></div>
}

<h4 class="mb-3"><i class="bi bi-star me-2"></i>Create Loyalty Card</h4>

<div class="card shadow-sm" style="max-width:500px;">
    <div class="card-body">
        <form method="post" asp-action="Create">
            <div class="mb-3">
                <label class="form-label">Customer</label>
                <select name="customerId" class="form-select" required>
                    <option value="">— Select customer —</option>
                    @foreach (var item in (SelectList)ViewBag.Customers)
                    {
                        <option value="@item.Value">@item.Text</option>
                    }
                </select>
                <div class="form-text">Only customers without a loyalty card are shown.</div>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Create Card</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
            </div>
        </form>
    </div>
</div>
