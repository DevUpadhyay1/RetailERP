@using Microsoft.AspNetCore.Identity
@using RetailERP.Data.Identity
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "Dashboard";

    var roleLabel =
        User.IsInRole("SuperAdmin") ? "SuperAdmin" :
        User.IsInRole("Admin") ? "Admin" :
        User.IsInRole("Manager") ? "Manager" :
        User.IsInRole("Inventory") ? "Inventory" :
        User.IsInRole("Cashier") ? "Cashier" :
        User.IsInRole("Finance") ? "Finance" :
        "User";

    static string InferNiceName(string? displayName, string? userName, string? email, string? fallback)
    {
        var preferred = displayName;
        if (string.IsNullOrWhiteSpace(preferred)) preferred = userName;
        if (string.IsNullOrWhiteSpace(preferred)) preferred = email;
        if (string.IsNullOrWhiteSpace(preferred)) preferred = fallback;
        preferred ??= "";
        var at = preferred.IndexOf('@');
        if (at > 0) preferred = preferred[..at];
        preferred = preferred.Replace('.', ' ').Replace('_', ' ').Trim();
        return string.IsNullOrWhiteSpace(preferred) ? "User" : preferred;
    }

    var currentUser = await UserManager.GetUserAsync(User);
    var displayName = InferNiceName(currentUser?.DisplayName, currentUser?.UserName, currentUser?.Email, User.Identity?.Name);

    var hour = DateTime.Now.Hour;
    var greeting = hour < 12 ? "Good morning" : hour < 17 ? "Good afternoon" : "Good evening";
}

<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4 position-relative" style="z-index: 1050;">
    <div class="header-content">
        <h2 class="mb-1 fw-bold brand-font">@greeting, @displayName</h2>
        <div class="text-white-50 small fw-medium">
            @DateTime.Now.ToString("dddd, dd MMMM yyyy") &middot;
            Role: <span class="badge bg-primary bg-opacity-75" style="letter-spacing:0.05em;text-transform:uppercase;">@roleLabel</span>
        </div>
    </div>
    <div class="d-flex flex-wrap gap-2 header-content">
        @if (User.IsInRole("Admin") || User.IsInRole("Manager") || User.IsInRole("Cashier") || User.IsInRole("Finance"))
        {
            <a class="btn btn-primary shadow-sm" asp-controller="Invoices" asp-action="Create" style="border-radius: 8px;"><i class="bi bi-receipt me-1"></i>New Sale</a>
            <a class="btn btn-warning shadow-sm" asp-controller="Pos" asp-action="StartQuick" style="border-radius: 8px; color: #78350f;"><i class="bi bi-display me-1"></i>POS Bill</a>
        }
        @if (User.IsInRole("Admin") || User.IsInRole("Manager") || User.IsInRole("Inventory") || User.IsInRole("Finance"))
        {
            <a class="btn btn-outline-light" asp-controller="Purchases" asp-action="Create" style="border-radius: 8px; backdrop-filter: blur(4px);"><i class="bi bi-bag-plus me-1"></i>Purchase</a>
        }
        <div class="btn-group">
            <button class="btn btn-outline-light dropdown-toggle" data-bs-toggle="dropdown" type="button" style="border-radius: 8px; backdrop-filter: blur(4px);"><i class="bi bi-lightning-charge me-1"></i>Quick Add</button>
            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" style="border-radius:12px; overflow:hidden;">
                <li><a class="dropdown-item py-2" asp-controller="Items" asp-action="Create"><i class="bi bi-upc-scan me-2 text-primary"></i>Item Master</a></li>
                <li><a class="dropdown-item py-2" asp-controller="Customers" asp-action="Create"><i class="bi bi-person-plus me-2 text-success"></i>Customer</a></li>
                @if (User.IsInRole("Admin") || User.IsInRole("Manager") || User.IsInRole("Inventory"))
                {
                    <li><a class="dropdown-item py-2" asp-controller="Suppliers" asp-action="Create"><i class="bi bi-truck me-2 text-warning"></i>Supplier</a></li>
                }
            </ul>
        </div>
    </div>
</div>

<div class="dashboard-toolbar">
    <button id="btn-lock-toggle" class="btn btn-sm btn-outline-secondary" title="Lock / Unlock dashboard editing">
        <i class="bi bi-unlock me-1"></i><span>Lock</span>
    </button>
    <button id="btn-add-widget" class="btn btn-sm btn-outline-primary edit-mode-btn"><i class="bi bi-plus-circle me-1"></i>Add Widget</button>
    <select id="dashboard-month-filter" class="form-select form-select-sm" style="width:auto;min-width:180px;">
        <option value="0">Current Month</option>
        <option value="-1">Previous Month</option>
        <option value="-2">2 Months Ago</option>
        <option value="-3">3 Months Ago</option>
        <option value="-6">6 Months Ago</option>
    </select>
    <select id="dashboard-value-scale" class="form-select form-select-sm" style="width:auto;min-width:190px;">
        <option value="auto">Scale: Auto</option>
        <option value="exact">Scale: Exact Value</option>
        <option value="hundred">Scale: Hundred (x100)</option>
        <option value="thousand">Scale: Thousand (K)</option>
        <option value="lakh">Scale: Lakh (L)</option>
        <option value="crore">Scale: Crore (Cr)</option>
    </select>
    <button id="btn-refresh-all" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-clockwise me-1"></i>Refresh All</button>
    <select id="dashboard-export-section" class="form-select form-select-sm" style="width:auto;min-width:170px;">
        <option value="all">Export: All Sections</option>
        <option value="sales">Sales</option>
        <option value="pos">POS</option>
        <option value="purchases">Purchases</option>
        <option value="returns">Returns</option>
        <option value="payments">Payments</option>
        <option value="inventory">Inventory</option>
    </select>
    <a id="btn-export-monthly" class="btn btn-sm btn-outline-success" href="/Home/ExportMonthlyData?monthOffset=-1&amp;section=all">
        <i class="bi bi-file-earmark-excel me-1"></i>Download Month Excel
    </a>
    <button id="btn-reset-layout" class="btn btn-sm btn-outline-danger edit-mode-btn"><i class="bi bi-arrow-counterclockwise me-1"></i>Reset Layout</button>
    <span class="text-muted small ms-2 edit-mode-hint"><i class="bi bi-arrows-move me-1"></i>Drag headers to rearrange &middot; Resize from corners</span>
</div>

<div class="grid-stack" id="dashboard-grid"></div>

<div id="widget-picker-overlay" class="widget-picker-overlay"
     onclick="document.getElementById('widget-picker-overlay').classList.remove('show');document.getElementById('widget-picker').classList.remove('show');"></div>
<div id="widget-picker" class="widget-picker">
    <div class="widget-picker-header">
        <span><i class="bi bi-columns-gap me-2"></i>Add Widget</span>
        <button id="picker-close" type="button"
                onclick="document.getElementById('widget-picker-overlay').classList.remove('show');document.getElementById('widget-picker').classList.remove('show');">
            <i class="bi bi-x-lg"></i>
        </button>
    </div>
    <div id="picker-body" class="widget-picker-body"></div>
</div>

@Html.AntiForgeryToken()

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/gridstack@10.3.1/dist/gridstack.min.css" rel="stylesheet" />
    <link href="~/css/dashboard.css" rel="stylesheet" asp-append-version="true" />
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/gridstack@10.3.1/dist/gridstack-all.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/apexcharts@5/dist/apexcharts.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.7/dist/browser/signalr.min.js"></script>
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
}
