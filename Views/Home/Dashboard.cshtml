@model RetailERP.Models.DashboardVm
@{
    ViewData["Title"] = "Dashboard";

    var roleLabel =
        User.IsInRole("Admin") ? "Admin" :
        User.IsInRole("Manager") ? "Manager" :
        User.IsInRole("Inventory") ? "Inventory" :
        User.IsInRole("Cashier") ? "Cashier" :
        "User";
}

<div class="d-flex justify-content-between align-items-end mb-3">
    <div>
        <h2 class="mb-0">Dashboard</h2>
        <div class="text-muted">Overview of operations</div>
    </div>
</div>

<div class="alert alert-light border d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
    <div>
        <div class="fw-semibold">Welcome, @User.Identity?.Name</div>
        <div class="text-muted small">Role: @roleLabel</div>
    </div>

    <div class="d-flex flex-wrap gap-2">
        @if (User.IsInRole("Admin") || User.IsInRole("Manager") || User.IsInRole("Cashier"))
        {
            <a class="btn btn-sm btn-primary" asp-controller="Invoices" asp-action="Index">New Invoice</a>
        }
        @if (User.IsInRole("Admin") || User.IsInRole("Manager") || User.IsInRole("Inventory"))
        {
            <a class="btn btn-sm btn-outline-primary" asp-controller="Stocks" asp-action="Index">View Stock</a>
            <a class="btn btn-sm btn-outline-primary" asp-controller="StockTransfers" asp-action="Create">Transfer Stock</a>
        }
    </div>
</div>

<div class="row g-3">
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="text-muted small">Items</div>
                <div class="fs-3 fw-semibold">@Model.ItemsCount</div>
                <a class="small text-decoration-none" asp-controller="Items" asp-action="Index">Open Items →</a>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="text-muted small">Customers</div>
                <div class="fs-3 fw-semibold">@Model.CustomersCount</div>
                <a class="small text-decoration-none" asp-controller="Customers" asp-action="Index">Open Customers →</a>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="text-muted small">Employees</div>
                <div class="fs-3 fw-semibold">@Model.EmployeesCount</div>
                <a class="small text-decoration-none" asp-controller="Employees" asp-action="Index">Open Employees →</a>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="text-muted small">Warehouses</div>
                <div class="fs-3 fw-semibold">@Model.WarehousesCount</div>
                <a class="small text-decoration-none" asp-controller="Warehouses" asp-action="Index">Open Warehouses →</a>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Quick Actions</h5>
                    <span class="text-muted small">Role-based shortcuts</span>
                </div>

                <div class="d-flex flex-wrap gap-2">
                    @if (User.IsInRole("Admin") || User.IsInRole("Manager") || User.IsInRole("Cashier"))
                    {
                        <a class="btn btn-outline-primary" asp-controller="Invoices" asp-action="Index">Invoices</a>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("Manager") || User.IsInRole("Inventory"))
                    {
                        <a class="btn btn-outline-primary" asp-controller="Items" asp-action="Index">Items</a>
                        <a class="btn btn-outline-primary" asp-controller="Stocks" asp-action="Index">Stock</a>
                        <a class="btn btn-outline-primary" asp-controller="StockTransfers" asp-action="Create">Transfer</a>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                    {
                        <a class="btn btn-outline-primary" asp-controller="Warehouses" asp-action="Index">Warehouses</a>
                        <a class="btn btn-outline-primary" asp-controller="Customers" asp-action="Index">Customers</a>
                        <a class="btn btn-outline-primary" asp-controller="Reports" asp-action="Sales">Reports</a>
                    }

                    @if (User.IsInRole("Admin"))
                    {
                        <a class="btn btn-outline-primary" asp-controller="AdminUsers" asp-action="Index">Users</a>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                    {
                        <a class="btn btn-outline-primary" asp-controller="Audit" asp-action="Index">Audit Log</a>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("Manager") || User.IsInRole("Inventory"))
                    {
                        <a class="btn btn-outline-primary" asp-controller="Items" asp-action="LowStock">Low Stock</a>
                    }
                </div>

                <div class="text-muted small mt-3">
                    Tip: Use “Low Stock” for reorder decisions, and “Audit Log” to track invoice posting and stock changes.
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h5 class="mb-2">What to do next</h5>

                <ul class="text-muted small mb-0">
                    @if (User.IsInRole("Cashier"))
                    {
                        <li>Create draft invoice → add lines → post invoice.</li>
                        <li>Use Reports (if enabled) to verify posted totals.</li>
                    }
                    else if (User.IsInRole("Inventory"))
                    {
                        <li>Maintain stock rows, adjust stock with reason.</li>
                        <li>Transfer stock between warehouses when required.</li>
                        <li>Check Low Stock list for reorder planning.</li>
                    }
                    else
                    {
                        <li>Maintain master data (Items, Warehouses, Customers).</li>
                        <li>Review Audit Log for critical actions.</li>
                        <li>Use Sales Report for daily/weekly summary.</li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>