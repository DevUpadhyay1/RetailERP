@model RetailERP.Models.DashboardVm
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-3">
    <div>
        <h2 class="mb-0">Dashboard</h2>
        <div class="text-muted small">@DateTime.Now.ToString("dddd, dd MMM yyyy") &mdash; Overview of operations</div>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-primary btn-sm" asp-controller="Invoices" asp-action="Create"><i class="bi bi-plus-lg me-1"></i>New Invoice</a>
        <a class="btn btn-outline-primary btn-sm" asp-controller="Stocks" asp-action="Create"><i class="bi bi-plus-lg me-1"></i>Add Stock</a>
        <a class="btn btn-outline-secondary btn-sm" asp-controller="Items" asp-action="Create"><i class="bi bi-plus-lg me-1"></i>Add Item</a>
        <a class="btn btn-outline-secondary btn-sm" asp-controller="Customers" asp-action="Create"><i class="bi bi-plus-lg me-1"></i>Add Customer</a>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card shadow-sm border-0">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="d-flex align-items-center justify-content-center rounded-3" style="width:48px;height:48px;background:#dbeafe;color:#3b82f6;font-size:1.25rem;flex-shrink:0;">
                    <i class="bi bi-box-seam"></i>
                </div>
                <div>
                    <div class="text-muted small">Items</div>
                    <div class="fs-4 fw-semibold">@Model.ItemsCount</div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0">
                <a class="small text-decoration-none" asp-controller="Items" asp-action="Index">Open Items <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card shadow-sm border-0">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="d-flex align-items-center justify-content-center rounded-3" style="width:48px;height:48px;background:#dcfce7;color:#16a34a;font-size:1.25rem;flex-shrink:0;">
                    <i class="bi bi-people"></i>
                </div>
                <div>
                    <div class="text-muted small">Customers</div>
                    <div class="fs-4 fw-semibold">@Model.CustomersCount</div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0">
                <a class="small text-decoration-none" asp-controller="Customers" asp-action="Index">Open Customers <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card shadow-sm border-0">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="d-flex align-items-center justify-content-center rounded-3" style="width:48px;height:48px;background:#fef3c7;color:#d97706;font-size:1.25rem;flex-shrink:0;">
                    <i class="bi bi-person-badge"></i>
                </div>
                <div>
                    <div class="text-muted small">Employees</div>
                    <div class="fs-4 fw-semibold">@Model.EmployeesCount</div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0">
                <a class="small text-decoration-none" asp-controller="Employees" asp-action="Index">Open Employees <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card shadow-sm border-0">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="d-flex align-items-center justify-content-center rounded-3" style="width:48px;height:48px;background:#e0e7ff;color:#4f46e5;font-size:1.25rem;flex-shrink:0;">
                    <i class="bi bi-building"></i>
                </div>
                <div>
                    <div class="text-muted small">Warehouses</div>
                    <div class="fs-4 fw-semibold">@Model.WarehousesCount</div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0">
                <a class="small text-decoration-none" asp-controller="Warehouses" asp-action="Index">Open Warehouses <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-12 col-lg-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <div class="text-muted small">Invoices</div>
                <div class="d-flex justify-content-between align-items-center mt-2">
                    <div>
                        <div class="fs-5 fw-semibold">@Model.DraftInvoicesCount</div>
                        <div class="text-muted small">Draft</div>
                    </div>
                    <div class="text-end">
                        <div class="fs-5 fw-semibold">@Model.PostedLast7DaysCount</div>
                        <div class="text-muted small">Posted (7 days)</div>
                    </div>
                </div>

                <hr class="my-3" />

                <div class="d-flex justify-content-between">
                    <div class="text-muted small">Sales (7 days)</div>
                    <div class="fw-semibold">@Model.SalesLast7Days.ToString("0.00")</div>
                </div>

                <div class="mt-3">
                    <a class="btn btn-sm btn-outline-primary" asp-controller="Invoices" asp-action="Index">Invoice Register</a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-8">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white fw-semibold">Recent invoices</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Invoice</th>
                                <th>Date</th>
                                <th>Customer</th>
                                <th>Warehouse</th>
                                <th class="text-end">Total</th>
                                <th>Status</th>
                                <th class="text-end"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.RecentInvoices.Any())
                            {
                                <tr>
                                    <td colspan="7" class="p-4 text-muted">
                                        No invoices yet. Create your first invoice to see activity here.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                foreach (var inv in Model.RecentInvoices)
                                {
                                    <tr>
                                        <td class="fw-semibold">@inv.InvoiceNo</td>
                                        <td>@inv.InvoiceDate.ToString("yyyy-MM-dd")</td>
                                        <td>@inv.CustomerName</td>
                                        <td>@inv.WarehouseName</td>
                                        <td class="text-end">@inv.TotalAmount.ToString("0.00")</td>
                                        <td>
                                            @if (inv.Status == 1)
                                            {
                                                <span class="badge bg-secondary">Draft</span>
                                            }
                                            else if (inv.Status == 2)
                                            {
                                                <span class="badge bg-success">Posted</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark">Other</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <a class="btn btn-sm btn-outline-primary" asp-controller="Invoices" asp-action="Edit" asp-route-id="@inv.InvoiceId">
                                                Open
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-12">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white fw-semibold">Low stock alerts</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>SKU</th>
                                <th>Item</th>
                                <th>Warehouse</th>
                                <th class="text-end">Qty</th>
                                <th class="text-end">Reorder</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.LowStock.Any())
                            {
                                <tr>
                                    <td colspan="5" class="p-4 text-muted">
                                        No low-stock items right now.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                foreach (var row in Model.LowStock)
                                {
                                    <tr>
                                        <td class="fw-semibold">@row.ItemSku</td>
                                        <td>@row.ItemName</td>
                                        <td>@row.WarehouseName</td>
                                        <td class="text-end">@row.Quantity</td>
                                        <td class="text-end">@row.ReorderLevel</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer bg-white d-flex justify-content-end">
                <a class="btn btn-sm btn-outline-primary" asp-controller="Stocks" asp-action="Index">Open Stock On Hand</a>
            </div>
        </div>
    </div>
</div>