 @{
    ViewData["Title"] = "The All-in-One Retail Management Platform";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RetailERP — Multi-Tenant Retail Hub</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #4F46E5;
            --primary-dark: #3730A3;
            --secondary: #0ea5e9;
            --dark: #0f172a;
            --glass-bg: rgba(255, 255, 255, 0.08);
            --glass-border: rgba(255, 255, 255, 0.15);
        }
        
        body { 
            font-family: 'Inter', sans-serif; 
            color: #334155;
            background: #f8fafc;
            -webkit-font-smoothing: antialiased;
        }

        h1, h2, h3, h4, h5, h6, .brand-font {
            font-family: 'Outfit', sans-serif;
        }

        /* Navbar */
        .landing-header { 
            background: rgba(255, 255, 255, 0.85); 
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(0,0,0,0.05); 
            transition: all 0.3s;
        }
        
        /* Hero Section */
        .hero-section {
            position: relative;
            background: #0f172a;
            color: #fff;
            padding: 120px 0 100px;
            overflow: hidden;
        }

        /* Abstract Gradient Orbs */
        .hero-section::before {
            content: '';
            position: absolute;
            top: -10%; left: -5%;
            width: 400px; height: 400px;
            background: var(--primary);
            filter: blur(120px);
            border-radius: 50%;
            opacity: 0.4;
            z-index: 0;
            animation: float 8s ease-in-out infinite;
        }
        .hero-section::after {
            content: '';
            position: absolute;
            bottom: -20%; right: -5%;
            width: 500px; height: 500px;
            background: var(--secondary);
            filter: blur(140px);
            border-radius: 50%;
            opacity: 0.3;
            z-index: 0;
            animation: float 10s ease-in-out infinite reverse;
        }

        @@keyframes float {
            0% { transform: translateY(0px) scale(1); }
            50% { transform: translateY(20px) scale(1.05); }
            100% { transform: translateY(0px) scale(1); }
        }

        .hero-content { position: relative; z-index: 1; }
        
        .hero-section h1 { 
            font-weight: 800; 
            font-size: 3.5rem;
            line-height: 1.1; 
            letter-spacing: -0.03em; 
            background: linear-gradient(135deg, #fff 30%, #94a3b8 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .hero-section .lead { 
            color: #94a3b8; 
            font-size: 1.25rem; 
            font-family: 'Outfit', sans-serif;
            font-weight: 300;
        }

        /* Buttons */
        .btn-premium {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: #fff;
            border: none;
            border-radius: 8px;
            font-weight: 500;
            box-shadow: 0 4px 15px rgba(79, 70, 229, 0.4);
            transition: all 0.3s;
        }
        .btn-premium:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(79, 70, 229, 0.5);
            color: #fff;
        }
        .btn-glass {
            background: rgba(255,255,255,0.1);
            color: #fff;
            border: 1px solid rgba(255,255,255,0.2);
            backdrop-filter: blur(10px);
            border-radius: 8px;
            font-weight: 500;
            transition: all 0.3s;
        }
        .btn-glass:hover {
            background: rgba(255,255,255,0.2);
            color: #fff;
            transform: translateY(-2px);
        }

        /* Glass Widget (Right col) */
        .glass-panel {
            background: var(--glass-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--glass-border);
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.3);
            transform: perspective(1000px) rotateY(-5deg) translateY(-10px);
            transition: transform 0.5s ease;
        }
        .glass-panel:hover {
            transform: perspective(1000px) rotateY(0deg) translateY(-15px);
        }

        .glass-item {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 12px;
            padding: 16px;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .glass-item:hover {
            background: rgba(255, 255, 255, 0.08);
            border-color: rgba(255, 255, 255, 0.15);
            transform: translateX(5px);
        }

        .glass-icon {
            width: 48px; height: 48px; 
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem; flex-shrink: 0;
            background: rgba(255,255,255,0.1);
            color: #38bdf8;
        }

        /* Features Section */
        .features-section { padding: 100px 0; }
        .section-sub { color: var(--primary); font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; font-size: 0.85rem;}
        
        .feature-card {
            background: #fff;
            border-radius: 16px;
            padding: 32px;
            height: 100%;
            border: 1px solid #f1f5f9;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.03);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }
        .feature-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05);
            border-color: #e2e8f0;
        }
        .feature-card::before {
            content: "";
            position: absolute;
            top: 0; left: 0; width: 100%; height: 4px;
            background: linear-gradient(90deg, var(--primary), var(--secondary));
            opacity: 0; transition: opacity 0.3s;
        }
        .feature-card:hover::before { opacity: 1; }

        .feature-icon-lg {
            width: 60px; height: 60px;
            border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.75rem;
            margin-bottom: 20px;
        }

        /* Analytics Preview */
        .analytics-preview {
            background: #fff;
            border-radius: 24px;
            padding: 80px 0;
            margin: 40px 0;
        }
        .dash-mockup {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.1);
            overflow: hidden;
        }
        .dash-header { height: 12px; background: #cbd5e1; width: 100%; display: flex; align-items: center; padding: 0 16px; gap: 6px; }
        .dash-dot { width: 8px; height: 8px; border-radius: 50%; background: #ef4444; }
        .dash-dot:nth-child(2) { background: #f59e0b; }
        .dash-dot:nth-child(3) { background: #10b981; }

        /* CTA */
        .cta-section { 
            padding: 100px 0; 
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: #fff;
            text-align: center;
        }

        .landing-footer { background: #0f172a; color: #94a3b8; padding: 40px 0; font-size: 0.9rem; }
        .landing-footer a { color: #94a3b8; text-decoration: none; transition: 0.2s; }
        .landing-footer a:hover { color: #fff; }
    </style>
</head>
<body>
    <!-- ═══ HEADER ═══ -->
    <header class="landing-header sticky-top py-3">
        <div class="container-xxl d-flex align-items-center justify-content-between">
            <a class="text-decoration-none d-flex align-items-center gap-2" href="/">
                <div class="d-flex align-items-center justify-content-center rounded-3 shadow-sm"
                     style="width:40px;height:40px;background:var(--primary);color:#fff;font-size:1.1rem;">
                    <i class="bi bi-layers-half"></i>
                </div>
                <span class="fs-4 brand-font font-weight-bold" style="color:var(--dark); font-weight:800;">RetailERP</span>
            </a>
            <div class="d-flex align-items-center gap-3">
                <a class="text-decoration-none text-dark fw-medium d-none d-md-block" href="#features">Features</a>
                <a class="text-decoration-none text-dark fw-medium d-none d-md-block" href="#benefits">Benefits</a>
                <a class="btn btn-outline-dark px-4 fw-medium" asp-area="Identity" asp-page="/Account/Login" style="border-radius:8px;">Sign In</a>
                @if (ViewBag.RegistrationOpen == true)
                {
                    <a class="btn btn-premium px-4" asp-area="Identity" asp-page="/Account/Register">Get Started</a>
                }
            </div>
        </div>
    </header>

    <!-- ═══ HERO ═══ -->
    <section class="hero-section">
        <div class="container-xxl hero-content">
            <div class="row align-items-center g-5">
                <div class="col-lg-6 pe-lg-5">
                    <div class="d-inline-flex align-items-center gap-2 mb-4 px-3 py-2 rounded-pill" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);">
                        @* <span class="badge text-bg-primary rounded-pill">v2.0</span> *@
                        <span class="text-white-50 small fw-medium">The ultimate multi-tenant platform</span>
                    </div>
                    <h1 class="mb-4">Scale your retail business with precision.</h1>
                    <p class="lead mb-5">Unify your Point of Sale, multi-warehouse inventory, suppliers, and actionable analytics in one seamless cloud platform designed for modern retailers.</p>
                    <div class="d-flex flex-wrap gap-3">
                        <a class="btn btn-premium btn-lg px-5 py-3 fs-6" asp-area="Identity" asp-page="/Account/Login">
                            Access Workspace <i class="bi bi-arrow-right ms-2 opacity-75"></i>
                        </a>
                        @if (ViewBag.RegistrationOpen == true)
                        {
                            <a class="btn btn-glass btn-lg px-5 py-3 fs-6" asp-area="Identity" asp-page="/Account/Register">Register Now</a>
                        }
                    </div>

                </div>
                
                <div class="col-lg-6 d-none d-lg-block">
                    <div class="glass-panel">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="m-0 fw-semibold text-white">System Capabilities</h5>
                            <i class="bi bi-stars text-warning"></i>
                        </div>
                        
                        <div class="vstack gap-3">
                            <div class="glass-item">
                                <div class="glass-icon"><i class="bi bi-display"></i></div>
                                <div>
                                    <div class="fw-semibold text-white">Lightning-Fast POS</div>
                                    <div class="text-white-50 small">Offline-ready billing with barcode scanning</div>
                                </div>
                            </div>
                            <div class="glass-item">
                                <div class="glass-icon" style="color: #a78bfa;"><i class="bi bi-box-seam"></i></div>
                                <div>
                                    <div class="fw-semibold text-white">Live Inventory Ledger</div>
                                    <div class="text-white-50 small">Multi-warehouse stock tracking in real-time</div>
                                </div>
                            </div>
                            <div class="glass-item">
                                <div class="glass-icon" style="color: #f472b6;"><i class="bi bi-graph-up-arrow"></i></div>
                                <div>
                                    <div class="fw-semibold text-white">Predictive Analytics</div>
                                    <div class="text-white-50 small">Automated EOD reports and sales forecasting</div>
                                </div>
                            </div>
                            <div class="glass-item">
                                <div class="glass-icon" style="color: #34d399;"><i class="bi bi-award"></i></div>
                                <div>
                                    <div class="fw-semibold text-white">Loyalty & CRM</div>
                                    <div class="text-white-50 small">Card management, tier progression and coupons</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ FEATURES ═══ -->
    <section id="features" class="features-section">
        <div class="container-xxl">
            <div class="row mb-5 justify-content-center">
                <div class="col-lg-6 text-center">
                    <div class="section-sub mb-2">Platform Features</div>
                    <h2 class="display-6 fw-bold mb-4">Everything you need to run your empire</h2>
                    <p class="text-muted lead fs-6">Replace 5 different software tools with a single, synchronized hub that connects your storefront to your warehouse.</p>
                </div>
            </div>
            
            <div class="row g-4">
                <div class="col-md-6 col-lg-4">
                    <div class="feature-card">
                        <div class="feature-icon-lg" style="background:#e0e7ff;color:var(--primary);"><i class="bi bi-cart4"></i></div>
                        <h4 class="fw-semibold mb-3 fs-5">Dynamic POS Billing</h4>
                        <p class="text-muted mb-0">Experience sub-second checkout speeds. Auto-swap payments, redeem loyalty points dynamically, and handle hold/unhook seamlessly.</p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="feature-card">
                        <div class="feature-icon-lg" style="background:#dcfce7;color:#059669;"><i class="bi bi-receipt"></i></div>
                        <h4 class="fw-semibold mb-3 fs-5">B2B Invoicing</h4>
                        <p class="text-muted mb-0">Generate GST-compliant tax invoices. Automated stock deduction prevents overselling. Multi-tax class support built-in.</p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="feature-card">
                        <div class="feature-icon-lg" style="background:#fef3c7;color:#d97706;"><i class="bi bi-arrow-left-right"></i></div>
                        <h4 class="fw-semibold mb-3 fs-5">Multi-Warehouse Transfers</h4>
                        <p class="text-muted mb-0">Command your supply chain. Transfer inventory seamlessly across unlimited locations with strict dual-entry audit logging.</p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="feature-card">
                        <div class="feature-icon-lg" style="background:#fce7f3;color:#db2777;"><i class="bi bi-shield-lock"></i></div>
                        <h4 class="fw-semibold mb-3 fs-5">Enterprise Role Control</h4>
                        <p class="text-muted mb-0">Assign strict boundaries. Cashiers can't void old bills, Inventory staff can't see revenues. Full security via JWT claims.</p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="feature-card">
                        <div class="feature-icon-lg" style="background:#f3e8ff;color:#7c3aed;"><i class="bi bi-star"></i></div>
                        <h4 class="fw-semibold mb-3 fs-5">Tiered Loyalty Engine</h4>
                        <p class="text-muted mb-0">Retain customers effortlessly. Automatic tier upgrades, point calculation schemas, and targeted coupon code generation.</p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="feature-card">
                        <div class="feature-icon-lg" style="background:#e0f2fe;color:#0284c7;"><i class="bi bi-pie-chart"></i></div>
                        <h4 class="fw-semibold mb-3 fs-5">Real-time Analytics</h4>
                        <p class="text-muted mb-0">Make decisions with live data. Configurable dashboards powered by Redis caching and SignalR websockets.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ CTA ═══ -->
    <section class="cta-section">
        <div class="container-xxl">
            <h2 class="display-5 fw-bold mb-4">Elevate your retail operations today</h2>
            <p class="lead mb-5 opacity-75" style="max-width: 600px; margin: 0 auto;">Join forward-thinking businesses powered by RetailERP. Experience a platform built for speed, accuracy, and scaling.</p>
            <div class="d-flex justify-content-center gap-3">
                <a class="btn btn-light btn-lg px-5 py-3 fw-bold text-primary" asp-area="Identity" asp-page="/Account/Login" style="border-radius: 8px;">
                    Enter Dashboard
                </a>
            </div>
        </div>
    </section>

    <!-- ═══ FOOTER ═══ -->
    <footer class="landing-footer">
        <div class="container-xxl">
            <div class="row align-items-center">
                <div class="col-md-4 mb-4 mb-md-0">
                    <div class="d-flex align-items-center gap-2 mb-2 brand-font fs-5 text-white">
                        <i class="bi bi-layers-half text-primary"></i>
                        RetailERP
                    </div>
                    <div>Modern retail architecture for ambitious growth.</div>
                </div>
                <div class="col-md-8 text-md-end">
                    <a asp-controller="Home" asp-action="Privacy" class="me-4 text-decoration-none">Privacy Policy</a>
                    <a href="#" class="me-4 text-decoration-none">Terms of Service</a>
                    <a asp-area="Identity" asp-page="/Account/Login" class="text-decoration-none">Sign in to Platform</a>
                </div>
            </div>
            <div class="mt-4 pt-4 border-top border-secondary text-center" style="opacity: 0.5;">
                &copy; @DateTime.Now.Year RetailERP. All rights reserved.
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>