@{ ViewData["Title"] = "Quick Send"; }

<h4 class="mb-3"><i class="bi bi-send"></i> Quick Send Notification</h4>

<form asp-action="Send" method="post" class="card p-4" style="max-width:600px;">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label">Channel</label>
        <select name="channel" class="form-select" required>
            <option value="Sms">SMS</option>
            <option value="WhatsApp">WhatsApp</option>
            <option value="Email">Email</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Recipient</label>
        <input name="recipient" class="form-control" required placeholder="Phone number or email address" />
    </div>

    <div class="mb-3">
        <label class="form-label">Subject <small class="text-muted">(Email only)</small></label>
        <input name="subject" class="form-control" placeholder="e.g. Your RetailERP Notification" />
    </div>

    <div class="mb-3">
        <label class="form-label">Message</label>
        <textarea name="body" class="form-control" rows="5" required placeholder="Type your message here..."></textarea>
    </div>

    <div class="d-flex gap-2">
        <button class="btn btn-primary"><i class="bi bi-send"></i> Send</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>
