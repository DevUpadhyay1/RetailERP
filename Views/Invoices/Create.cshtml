@model RetailERP.Controllers.InvoicesController.InvoiceCreateVm

<h2 class="mb-3">New Invoice (Draft)</h2>

<form asp-action="Create" method="post" class="card">
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Document Type</label>
                <select class="form-select" asp-for="DocumentType" asp-items="ViewBag.DocumentTypes"></select>
                <span asp-validation-for="DocumentType" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label">Customer</label>
                <select class="form-select" asp-for="CustomerId" asp-items="ViewBag.Customers">
                    <option value="" disabled selected>-- Select Customer --</option>
                </select>
                <span asp-validation-for="CustomerId" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label class="form-label">Warehouse</label>
                <select class="form-select" asp-for="WarehouseId" asp-items="ViewBag.Warehouses">
                    <option value="" disabled selected>-- Select Warehouse --</option>
                </select>
                <span asp-validation-for="WarehouseId" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <label class="form-label">Invoice Date</label>
                <input class="form-control" asp-for="InvoiceDate" type="date" max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="InvoiceDate" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <label class="form-label">Due Date (Optional)</label>
                <input class="form-control" asp-for="DueDate" type="date" />
                <span asp-validation-for="DueDate" class="text-danger"></span>
            </div>

            <div class="col-md-4">
                <label class="form-label">Reference Invoice No (Optional)</label>
                <input class="form-control" asp-for="ReferenceInvoiceNo" placeholder="Required for Credit/Debit notes" />
                <span asp-validation-for="ReferenceInvoiceNo" class="text-danger"></span>
            </div>

            <div class="col-md-8">
                <label class="form-label">Employee (Optional)</label>
                <select class="form-select" asp-for="EmployeeId" asp-items="ViewBag.Employees">
                    <option value="">-</option>
                </select>
            </div>
        </div>
    </div>
    <div class="card-footer d-flex gap-2">
        <button class="btn btn-primary" type="submit">Create Draft</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
