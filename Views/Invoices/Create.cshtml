@model RetailERP.Controllers.InvoicesController.InvoiceCreateVm

<h2 class="mb-3">New Invoice (Draft)</h2>

<form asp-action="Create" method="post" class="card">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Customer</label>
                <select class="form-select" asp-for="CustomerId" asp-items="ViewBag.Customers"></select>
            </div>

            <div class="col-md-6">
                <label class="form-label">Warehouse</label>
                <select class="form-select" asp-for="WarehouseId" asp-items="ViewBag.Warehouses"></select>
            </div>

            <div class="col-md-4">
                <label class="form-label">Invoice Date</label>
                <input class="form-control" asp-for="InvoiceDate" type="date" />
            </div>
        </div>
    </div>
    <div class="card-footer d-flex gap-2">
        <button class="btn btn-primary" type="submit">Create Draft</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
    </div>
</form>