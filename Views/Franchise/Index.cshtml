@model List<RetailERP.Data.Entities.FranchiseAgreement>
@{
    ViewData["Title"] = "Franchise Agreements";
    var q = ViewData["q"] as string ?? "";
    var status = ViewData["status"] as byte?;
    var total = (int)(ViewData["total"] ?? 0);
    var page = (int)(ViewData["page"] ?? 1);
    var pageSize = (int)(ViewData["pageSize"] ?? 25);
    var totalPages = (int)(ViewData["totalPages"] ?? 1);
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h2 class="mb-0">Franchise Agreements</h2>
        <div class="text-muted small">@total agreement(s)</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary btn-sm" asp-action="RoyaltyDashboard"><i class="bi bi-graph-up-arrow me-1"></i>Royalty Dashboard</a>
        <a class="btn btn-primary btn-sm" asp-action="Create"><i class="bi bi-plus-lg me-1"></i>New Agreement</a>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <input name="q" value="@q" class="form-control form-control-sm" placeholder="Search code, company, territory…" />
            </div>
            <div class="col-md-3">
                <select name="status" class="form-select form-select-sm">
                    <option value="">All Statuses</option>
                    <option value="1" selected="@(status == 1)">Active</option>
                    <option value="2" selected="@(status == 2)">Expired</option>
                    <option value="3" selected="@(status == 3)">Terminated</option>
                </select>
            </div>
            <div class="col-auto">
                <button class="btn btn-primary btn-sm" type="submit">Filter</button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Code</th>
                        <th>Franchisor</th>
                        <th>Franchisee</th>
                        <th>Territory</th>
                        <th class="text-end">Royalty %</th>
                        <th class="text-center">Status</th>
                        <th>Start</th>
                        <th>End</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="9" class="text-center text-muted py-4">No agreements found.</td></tr>
                    }
                    else
                    {
                        @foreach (var a in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@a.AgreementCode</td>
                                <td>@a.FranchisorCompany?.Name</td>
                                <td>@a.FranchiseeCompany?.Name</td>
                                <td>@a.Territory</td>
                                <td class="text-end">@a.RoyaltyPercent.ToString("0.##")%</td>
                                <td class="text-center">
                                    @switch (a.Status)
                                    {
                                        case 1: <span class="badge bg-success">Active</span> break;
                                        case 2: <span class="badge bg-secondary">Expired</span> break;
                                        case 3: <span class="badge bg-danger">Terminated</span> break;
                                    }
                                </td>
                                <td>@a.StartDate.ToString("dd-MMM-yyyy")</td>
                                <td>@(a.EndDate?.ToString("dd-MMM-yyyy") ?? "—")</td>
                                <td>
                                    <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@a.FranchiseAgreementId"><i class="bi bi-eye"></i></a>
                                    <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@a.FranchiseAgreementId"><i class="bi bi-pencil"></i></a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (totalPages > 1)
    {
        <div class="card-footer d-flex justify-content-between align-items-center">
            <span class="text-muted small">Page @(page) of @totalPages</span>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(page <= 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-q="@q" asp-route-status="@status" asp-route-page="@(page - 1)">Prev</a>
                    </li>
                    @for (var p = Math.Max(1, page - 2); p <= Math.Min(totalPages, page + 2); p++)
                    {
                        <li class="page-item @(p == page ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-q="@q" asp-route-status="@status" asp-route-page="@p">@p</a>
                        </li>
                    }
                    <li class="page-item @(page >= totalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-q="@q" asp-route-status="@status" asp-route-page="@(page + 1)">Next</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
