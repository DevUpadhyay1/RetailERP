@model IEnumerable<RetailERP.Data.Entities.FranchiseMappingRequest>
@{
    ViewData["Title"] = "Franchise Mapping Requests";

    var isSuperAdmin = (ViewBag.IsSuperAdmin as bool?) ?? false;
    var canSubmitRequest = (ViewBag.CanSubmitRequest as bool?) ?? false;
    var requestBlockReason = ViewBag.RequestBlockReason as string;
    var requestingCompanyName = ViewBag.RequestingCompanyName as string;
    var operatorOptions = ViewBag.OperatorCompanyOptions as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new();
    var createCompanyUrl = (ViewBag.CreateCompanyUrl as string) ?? Url.Action("Create", "Companies");
    var companyIndexUrl = (ViewBag.CompanyIndexUrl as string) ?? Url.Action("Index", "Companies");

    string StatusText(byte status) => status switch
    {
        1 => "Pending",
        2 => "Approved",
        3 => "Rejected",
        4 => "Cancelled",
        _ => "Unknown"
    };

    string StatusClass(byte status) => status switch
    {
        1 => "warning",
        2 => "success",
        3 => "danger",
        4 => "secondary",
        _ => "secondary"
    };
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h2 class="mb-0">@ViewData["Title"]</h2>
        <div class="text-muted small">Submit and review company-to-franchise mapping requests</div>
    </div>
    @if (!isSuperAdmin)
    {
        <a asp-action="Create" class="btn btn-outline-primary">New Agreement</a>
    }
</div>

@if (TempData["Ok"] is string ok)
{
    <div class="alert alert-success">@ok</div>
}
@if (TempData["Err"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

@if (!isSuperAdmin)
{
    <div class="card shadow-sm mb-3">
        <div class="card-header">
            <strong>Request SuperAdmin for Operator Mapping</strong>
            @if (!string.IsNullOrWhiteSpace(requestingCompanyName))
            {
                <span class="text-muted">- @requestingCompanyName</span>
            }
        </div>
        <div class="card-body">
            @if (!canSubmitRequest)
            {
                <div class="alert alert-warning mb-0">@(requestBlockReason ?? "You are not allowed to submit mapping requests.")</div>
            }
            else
            {
                <form asp-action="SubmitMappingRequest" method="post" class="row g-3">
                    @Html.AntiForgeryToken()

                    <div class="col-md-4">
                        <label class="form-label">Requested Operator Name</label>
                        <input name="RequestedOperatorName" class="form-control" maxlength="200" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Requested Operator Code</label>
                        <input name="RequestedOperatorCode" class="form-control" maxlength="50" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">City</label>
                        <input name="RequestedOperatorCity" class="form-control" maxlength="100" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">State</label>
                        <input name="RequestedOperatorState" class="form-control" maxlength="100" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Request Note</label>
                        <textarea name="RequestNote" class="form-control" rows="2" maxlength="500" placeholder="Explain why mapping is needed"></textarea>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary">Submit Request</button>
                    </div>
                </form>
            }
        </div>
    </div>
}

@if (isSuperAdmin)
{
    <div class="alert alert-info d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2">
        <div>
            <strong>SuperAdmin Flow:</strong> 1) Create franchise company in Companies, assign admin credentials, and select main company if needed. 2) Return here and approve the pending mapping request by selecting that franchise company.
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-sm btn-outline-primary" href="@companyIndexUrl">Open Companies</a>
            <a class="btn btn-sm btn-primary" href="@createCompanyUrl">Create Company</a>
        </div>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="p-4 text-muted">No mapping requests found.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Requested At</th>
                            <th>Brand Owner</th>
                            <th>Requested Operator</th>
                            <th>Status</th>
                            <th>Review</th>
                            <th style="width: 340px;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model)
                        {
                            <tr>
                                <td>@r.RequestedAtUtc.ToLocalTime().ToString("dd-MMM-yyyy HH:mm")</td>
                                <td>@(r.RequestingCompany?.Code ?? "-") - @(r.RequestingCompany?.Name ?? "-")</td>
                                <td>
                                    <div><strong>@r.RequestedOperatorName</strong></div>
                                    <div class="small text-muted">
                                        @if (!string.IsNullOrWhiteSpace(r.RequestedOperatorCode))
                                        {
                                            <span>Code: @r.RequestedOperatorCode</span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(r.RequestedOperatorCity) || !string.IsNullOrWhiteSpace(r.RequestedOperatorState))
                                        {
                                            <span class="ms-2">@r.RequestedOperatorCity @r.RequestedOperatorState</span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(r.RequestNote))
                                    {
                                        <div class="small mt-1 text-muted">@r.RequestNote</div>
                                    }
                                    @if (r.MappedOperatorCompany != null)
                                    {
                                        <div class="small mt-1 text-success">Mapped: @r.MappedOperatorCompany.Code - @r.MappedOperatorCompany.Name</div>
                                    }
                                </td>
                                <td><span class="badge bg-@StatusClass(r.Status)">@StatusText(r.Status)</span></td>
                                <td>
                                    @if (r.ReviewedAtUtc.HasValue)
                                    {
                                        <div class="small">@r.ReviewedAtUtc.Value.ToLocalTime().ToString("dd-MMM-yyyy HH:mm")</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(r.ReviewNote))
                                    {
                                        <div class="small text-muted">@r.ReviewNote</div>
                                    }
                                </td>
                                <td>
                                    @if (isSuperAdmin && r.Status == 1)
                                    {
                                        var rowOperatorOptions = operatorOptions.Where(o => o.Value != r.RequestingCompanyId.ToString()).ToList();

                                        @if (!rowOperatorOptions.Any())
                                        {
                                            <div class="small text-warning mb-2">No eligible franchise company found. Create franchise company in Companies module first.</div>
                                            <a class="btn btn-sm btn-outline-primary mb-2" href="@createCompanyUrl">Create Company</a>
                                        }
                                        else
                                        {
                                            <form asp-action="ApproveMappingRequest" method="post" class="vstack gap-2 mb-2">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@r.FranchiseMappingRequestId" />
                                                <select name="mappedOperatorCompanyId" class="form-select form-select-sm" required>
                                                    <option value="">Select franchise company to map</option>
                                                    @foreach (var opt in rowOperatorOptions)
                                                    {
                                                        <option value="@opt.Value">@opt.Text</option>
                                                    }
                                                </select>
                                                <input name="reviewNote" class="form-control form-control-sm" maxlength="500" placeholder="Optional approval note" />
                                                <button type="submit" class="btn btn-sm btn-outline-success">Approve &amp; Map</button>
                                            </form>
                                        }

                                        <form asp-action="RejectMappingRequest" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@r.FranchiseMappingRequestId" />
                                            <input name="reviewNote" class="form-control form-control-sm mb-2" maxlength="500" placeholder="Rejection note" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Reject</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">No action</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
