@model RetailERP.Data.Entities.FranchiseAgreement
@{
    ViewData["Title"] = $"Agreement — {Model.AgreementCode}";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h2 class="mb-0">@Model.AgreementCode</h2>
        <div class="text-muted small">
            @Model.FranchisorCompany?.Name → @Model.FranchiseeCompany?.Name
        </div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary btn-sm" asp-action="Edit" asp-route-id="@Model.FranchiseAgreementId"><i class="bi bi-pencil me-1"></i>Edit</a>
        <a class="btn btn-outline-primary btn-sm" asp-action="CalculateRoyalty" asp-route-agreementId="@Model.FranchiseAgreementId"><i class="bi bi-calculator me-1"></i>Calculate Royalty</a>
        <a class="btn btn-outline-secondary btn-sm" asp-action="Index">Back to List</a>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="card shadow-sm text-center">
            <div class="card-body py-2">
                <div class="text-muted small">Status</div>
                @switch (Model.Status)
                {
                    case 1: <span class="badge bg-success fs-6">Active</span> break;
                    case 2: <span class="badge bg-secondary fs-6">Expired</span> break;
                    case 3: <span class="badge bg-danger fs-6">Terminated</span> break;
                }
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm text-center">
            <div class="card-body py-2">
                <div class="text-muted small">Royalty Rate</div>
                <div class="fs-4 fw-bold text-primary">@Model.RoyaltyPercent.ToString("0.##")%</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm text-center">
            <div class="card-body py-2">
                <div class="text-muted small">Monthly Flat Fee</div>
                <div class="fs-5 fw-bold">₹@Model.MonthlyFlatFee.ToString("N2")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm text-center">
            <div class="card-body py-2">
                <div class="text-muted small">Min Monthly</div>
                <div class="fs-5 fw-bold">₹@Model.MinMonthlyRoyalty.ToString("N2")</div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-header fw-semibold">Agreement Details</div>
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-4"><strong>Franchisor:</strong> @Model.FranchisorCompany?.Name</div>
            <div class="col-md-4"><strong>Franchisee:</strong> @Model.FranchiseeCompany?.Name</div>
            <div class="col-md-4"><strong>Territory:</strong> @(string.IsNullOrWhiteSpace(Model.Territory) ? "—" : Model.Territory)</div>
            <div class="col-md-4"><strong>Start:</strong> @Model.StartDate.ToString("dd-MMM-yyyy")</div>
            <div class="col-md-4"><strong>End:</strong> @(Model.EndDate?.ToString("dd-MMM-yyyy") ?? "Open-ended")</div>
            <div class="col-md-4"><strong>Created:</strong> @Model.CreatedAtUtc.ToString("dd-MMM-yyyy HH:mm")</div>
            @if (!string.IsNullOrWhiteSpace(Model.Notes))
            {
                <div class="col-12"><strong>Notes:</strong> @Model.Notes</div>
            }
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Royalty Payment History</span>
        <form asp-action="GeneratePayment" method="post" class="d-flex gap-2 align-items-end">
            <input type="hidden" name="agreementId" value="@Model.FranchiseAgreementId" />
            <input type="number" name="year" value="@DateTime.UtcNow.Year" class="form-control form-control-sm" style="width:90px" min="2020" max="2099" />
            <input type="number" name="month" value="@DateTime.UtcNow.Month" class="form-control form-control-sm" style="width:70px" min="1" max="12" />
            <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-plus-lg me-1"></i>Generate</button>
        </form>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Period</th>
                        <th class="text-end">Gross Sales</th>
                        <th class="text-end">Royalty</th>
                        <th class="text-end">Flat Fee</th>
                        <th class="text-end">Total Due</th>
                        <th class="text-end">Paid</th>
                        <th class="text-center">Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.RoyaltyPayments.Any())
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">No royalty payments yet. Generate one above.</td></tr>
                    }
                    else
                    {
                        @foreach (var p in Model.RoyaltyPayments)
                        {
                            <tr class="@(p.Status == 3 ? "table-danger" : p.Status == 1 ? "table-warning" : "")">
                                <td class="fw-semibold">@p.PeriodYear/@p.PeriodMonth.ToString("D2")</td>
                                <td class="text-end">₹@p.GrossSales.ToString("N2")</td>
                                <td class="text-end">₹@p.RoyaltyAmount.ToString("N2")</td>
                                <td class="text-end">₹@p.FlatFeeAmount.ToString("N2")</td>
                                <td class="text-end fw-semibold">₹@p.TotalDue.ToString("N2")</td>
                                <td class="text-end">₹@p.AmountPaid.ToString("N2")</td>
                                <td class="text-center">
                                    @switch (p.Status)
                                    {
                                        case 1: <span class="badge bg-warning text-dark">Pending</span> break;
                                        case 2: <span class="badge bg-success">Paid</span> break;
                                        case 3: <span class="badge bg-danger">Overdue</span> break;
                                        case 4: <span class="badge bg-secondary">Waived</span> break;
                                    }
                                </td>
                                <td>
                                    @if (p.Status == 1 || p.Status == 3)
                                    {
                                        <form asp-action="RecordPayment" method="post" class="d-flex gap-1 align-items-center">
                                            <input type="hidden" name="paymentId" value="@p.RoyaltyPaymentId" />
                                            <input type="hidden" name="agreementId" value="@Model.FranchiseAgreementId" />
                                            <input type="number" name="amountPaid" value="@p.TotalDue" step="0.01" class="form-control form-control-sm" style="width:110px" />
                                            <button type="submit" class="btn btn-sm btn-success" title="Mark Paid"><i class="bi bi-check2"></i></button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
