@model List<RetailERP.Data.Entities.EodReport>
@{
    ViewData["Title"] = "EOD Reports";
    var sort = (string)ViewBag.Sort;
    var dir = (string)ViewBag.Dir;
    var page = (int)ViewBag.Page;
    var totalPages = (int)ViewBag.TotalPages;
    string Toggle(string col) => sort == col && dir == "asc" ? "desc" : "asc";
    string Arrow(string col) => sort == col ? (dir == "asc" ? "▲" : "▼") : "";
}

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show">@msg <button class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h4 class="mb-0"><i class="bi bi-calendar-check me-2"></i>EOD Reports</h4>
    <a class="btn btn-primary" asp-action="Generate"><i class="bi bi-plus-lg me-1"></i>Generate Report</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <select name="storeId" class="form-select form-select-sm">
            <option value="">All Stores</option>
            @foreach (var item in (SelectList)ViewBag.Stores)
            {
                <option value="@item.Value" selected="@item.Selected">@item.Text</option>
            }
        </select>
    </div>
    <div class="col-auto"><button class="btn btn-sm btn-outline-primary">Filter</button></div>
</form>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th><a asp-action="Index" asp-route-sort="ReportDate" asp-route-dir="@Toggle("ReportDate")">Date @Arrow("ReportDate")</a></th>
                <th><a asp-action="Index" asp-route-sort="Store" asp-route-dir="@Toggle("Store")">Store @Arrow("Store")</a></th>
                <th class="text-end">Bills</th>
                <th class="text-end"><a asp-action="Index" asp-route-sort="NetSales" asp-route-dir="@Toggle("NetSales")">Net Sales @Arrow("NetSales")</a></th>
                <th class="text-end">Cash Sales</th>
                <th class="text-end">Variance</th>
                <th><a asp-action="Index" asp-route-sort="Status" asp-route-dir="@Toggle("Status")">Status @Arrow("Status")</a></th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.ReportDate.ToString("dd MMM yyyy")</td>
                    <td>@r.Store?.Name</td>
                    <td class="text-end">@r.BillCount</td>
                    <td class="text-end fw-bold">₹@r.NetSales.ToString("N2")</td>
                    <td class="text-end">₹@r.TotalCashSales.ToString("N2")</td>
                    <td class="text-end @(r.Variance < 0 ? "text-danger" : r.Variance > 0 ? "text-warning" : "")">
                        @if (r.Status == 2) { @($"₹{r.Variance:N2}") } else { <span class="text-muted">—</span> }
                    </td>
                    <td>
                        @if (r.Status == 1) { <span class="badge bg-warning text-dark">Pending</span> }
                        else { <span class="badge bg-success">Closed</span> }
                    </td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@r.EodReportId">View</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (totalPages > 1)
{
    <nav>
        <ul class="pagination pagination-sm justify-content-center">
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == page ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-sort="@sort" asp-route-dir="@dir" asp-route-page="@i">@i</a>
                </li>
            }
        </ul>
    </nav>
}
