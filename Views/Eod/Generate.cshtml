@{
    ViewData["Title"] = "Generate EOD Report";
}

@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger alert-dismissible fade show">@err <button class="btn-close" data-bs-dismiss="alert"></button></div>
}

<h4 class="mb-3"><i class="bi bi-calendar-check me-2"></i>Generate EOD Report</h4>

<div class="card shadow-sm" style="max-width:500px;">
    <div class="card-body">
        <form method="post" asp-action="Generate">
            <div class="mb-3">
                <label class="form-label">Store</label>
                <select name="storeId" class="form-select" required>
                    <option value="">— Select store —</option>
                    @foreach (var item in (SelectList)ViewBag.Stores)
                    {
                        <option value="@item.Value">@item.Text</option>
                    }
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Report Date</label>
                <input name="reportDate" type="date" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Opening Cash (₹)</label>
                <input name="openingCash" type="number" step="0.01" min="0" class="form-control" value="0" required />
                <div class="form-text">Cash in drawer at start of day.</div>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Generate</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
            </div>
        </form>
    </div>
</div>
