@model RetailERP.Controllers.CompaniesController.CreateCompanyVm
@using RetailERP.Data.Entities
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "New Company";
    var mainCompanyOptions = ViewBag.MainCompanyOptions as List<SelectListItem> ?? new List<SelectListItem>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0">New Company</h2>
        <div class="text-muted">Register a new tenant with its admin account</div>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <h6 class="text-muted fw-semibold mb-3"><i class="bi bi-building me-1"></i>Company Identity</h6>
            <div class="row g-3">
                <div class="col-md-3">
                    <label asp-for="Code" class="form-label"></label>
                    <input asp-for="Code" class="form-control" placeholder="e.g., COMP001" />
                    <span asp-validation-for="Code" class="text-danger"></span>
                </div>
                <div class="col-md-5">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" placeholder="Company name" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="BusinessType" class="form-label">Business Type</label>
                    <select asp-for="BusinessType" class="form-select"
                            asp-items="@(new SelectList(Enum.GetValues<BusinessType>().Select(b => new { Value = (int)b, Text = b.ToString() }), "Value", "Text"))">
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="MainCompanyId" class="form-label"></label>
                    <select asp-for="MainCompanyId" class="form-select" asp-items="mainCompanyOptions"></select>
                    <span asp-validation-for="MainCompanyId" class="text-danger"></span>
                    <div class="form-text">For franchise onboarding, select the requested main company.</div>
                </div>
            </div>

            <hr class="my-4" />
            <h6 class="text-muted fw-semibold mb-3"><i class="bi bi-geo-alt me-1"></i>Address & Contact</h6>
            <div class="row g-3">
                <div class="col-md-12">
                    <label asp-for="Address" class="form-label"></label>
                    <input asp-for="Address" class="form-control" placeholder="Street address" />
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="City" class="form-label"></label>
                    <input asp-for="City" class="form-control" placeholder="City" />
                </div>
                <div class="col-md-4">
                    <label asp-for="State" class="form-label"></label>
                    <input asp-for="State" class="form-control" placeholder="State" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Pincode" class="form-label"></label>
                    <input asp-for="Pincode" class="form-control" type="tel" maxlength="6" pattern="\d{6}" placeholder="e.g. 560001" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Phone" class="form-label"></label>
                    <input asp-for="Phone" class="form-control" type="tel" maxlength="10" pattern="[6-9]\d{9}" placeholder="e.g. 9876543210" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" type="email" placeholder="Email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Website" class="form-label"></label>
                    <input asp-for="Website" class="form-control" placeholder="https://..." />
                </div>
            </div>

            <hr class="my-4" />
            <h6 class="text-muted fw-semibold mb-3"><i class="bi bi-file-earmark-text me-1"></i>Tax & Compliance</h6>
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="GstNo" class="form-label">GST Number</label>
                    <input asp-for="GstNo" class="form-control" maxlength="15" placeholder="e.g. 22AAAAA0000A1Z5" style="text-transform:uppercase" />
                    <span asp-validation-for="GstNo" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="PanNo" class="form-label">PAN Number</label>
                    <input asp-for="PanNo" class="form-control" maxlength="10" placeholder="e.g. ABCDE1234F" style="text-transform:uppercase" />
                    <span asp-validation-for="PanNo" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="CinNo" class="form-label">CIN Number</label>
                    <input asp-for="CinNo" class="form-control" placeholder="Optional" />
                </div>
            </div>

            <hr class="my-4" />
            <h6 class="text-muted fw-semibold mb-3"><i class="bi bi-sliders me-1"></i>Tenant Limits & Status</h6>
            <div class="row g-3">
                <div class="col-md-3">
                    <label asp-for="MaxUsers" class="form-label">Max Users</label>
                    <input asp-for="MaxUsers" class="form-control" type="number" min="0" />
                    <div class="form-text">0 = unlimited</div>
                </div>
                <div class="col-md-3">
                    <label asp-for="MaxStores" class="form-label">Max Stores</label>
                    <input asp-for="MaxStores" class="form-control" type="number" min="0" />
                    <div class="form-text">0 = unlimited</div>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Status</label>
                    <div class="form-check mt-2">
                        <input class="form-check-input" asp-for="IsActive" />
                        <label class="form-check-label" asp-for="IsActive">Active</label>
                    </div>
                </div>
            </div>

            <hr class="my-4" />
            <h6 class="text-muted fw-semibold mb-3"><i class="bi bi-person-badge me-1"></i>Company Admin Account</h6>
            <div class="alert alert-info py-2 small">
                <i class="bi bi-info-circle me-1"></i>An admin user will be created for this company. They can log in and manage the company independently.
            </div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="AdminDisplayName" class="form-label"></label>
                    <input asp-for="AdminDisplayName" class="form-control" placeholder="e.g., MedPlus Admin" />
                    <span asp-validation-for="AdminDisplayName" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="AdminEmail" class="form-label"></label>
                    <input asp-for="AdminEmail" class="form-control" type="email" placeholder="admin@company.com" />
                    <span asp-validation-for="AdminEmail" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="AdminPassword" class="form-label"></label>
                    <input asp-for="AdminPassword" class="form-control" />
                    <span asp-validation-for="AdminPassword" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="AdminConfirmPassword" class="form-label"></label>
                    <input asp-for="AdminConfirmPassword" class="form-control" />
                    <span asp-validation-for="AdminConfirmPassword" class="text-danger"></span>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Create Company</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
