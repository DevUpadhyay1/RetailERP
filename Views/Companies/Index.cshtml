@model List<RetailERP.Data.Entities.Company>
@{
    ViewData["Title"] = "Companies (Tenants)";
    var q = (ViewData["q"] as string) ?? "";
    var active = (ViewData["active"] as bool?);
    var sort = (ViewData["sort"] as string) ?? "code";
    var dir = (ViewData["dir"] as string) ?? "asc";
    var pageNumber = (ViewData["page"] as int?) ?? 1;
    var pageSize = (ViewData["pageSize"] as int?) ?? 20;
    var total = (ViewData["total"] as int?) ?? 0;
    var from = (ViewData["from"] as int?) ?? 0;
    var to = (ViewData["to"] as int?) ?? 0;
    var totalPages = (ViewData["totalPages"] as int?) ?? 1;

    string ToggleDir(string nextSort)
    {
        if (!string.Equals(sort, nextSort, StringComparison.OrdinalIgnoreCase)) return "asc";
        return string.Equals(dir, "asc", StringComparison.OrdinalIgnoreCase) ? "desc" : "asc";
    }
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0"><i class="bi bi-building me-2"></i>Companies (Tenants)</h2>
        <div class="text-muted">Showing @from–@to of @total</div>
    </div>
    <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-lg me-1"></i>New Company</a>
</div>

@if (TempData["Ok"] is string ok)
{
    <div class="alert alert-success">@ok</div>
}

<form method="get" class="mb-3">
    <div class="row g-2 align-items-center">
        <div class="col-12 col-md-6 col-lg-5">
            <input class="form-control" name="q" value="@q" placeholder="Search code or name" />
        </div>
        <div class="col-12 col-md-4 col-lg-3">
            <select class="form-select" name="active">
                <option value="" selected="@(active is null)">All statuses</option>
                <option value="true" selected="@(active is true)">Active</option>
                <option value="false" selected="@(active is false)">Inactive</option>
            </select>
        </div>
        <input type="hidden" name="sort" value="@sort" />
        <input type="hidden" name="dir" value="@dir" />
        <input type="hidden" name="pageSize" value="@pageSize" />
        <div class="col-auto"><button class="btn btn-outline-secondary" type="submit">Apply</button></div>
        <div class="col-auto"><a class="btn btn-outline-dark" asp-action="Index">Reset</a></div>
    </div>
</form>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th style="width:140px;">
                        <a class="text-decoration-none" asp-action="Index" asp-route-q="@q" asp-route-active="@active" asp-route-sort="code" asp-route-dir="@ToggleDir("code")" asp-route-page="1" asp-route-pageSize="@pageSize">Code</a>
                    </th>
                    <th>
                        <a class="text-decoration-none" asp-action="Index" asp-route-q="@q" asp-route-active="@active" asp-route-sort="name" asp-route-dir="@ToggleDir("name")" asp-route-page="1" asp-route-pageSize="@pageSize">Name</a>
                    </th>
                    <th>Email</th>
                    <th>Business Type</th>
                    <th>Phone</th>
                    <th class="text-center" style="width:90px;">
                        <a class="text-decoration-none" asp-action="Index" asp-route-q="@q" asp-route-active="@active" asp-route-sort="status" asp-route-dir="@ToggleDir("status")" asp-route-page="1" asp-route-pageSize="@pageSize">Active</a>
                    </th>
                    <th class="text-end" style="width:200px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (total == 0)
                {
                    <tr><td colspan="7" class="p-4 text-muted">No companies found.</td></tr>
                }
                @foreach (var c in Model)
                {
                    <tr>
                        <td><code>@c.Code</code></td>
                        <td>@c.Name</td>
                        <td>@c.Email</td>
                        <td><span class="badge bg-light text-dark border">@c.BusinessType</span></td>
                        <td>@c.Phone</td>
                        <td class="text-center">
                            @if (c.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@c.CompanyId"><i class="bi bi-eye"></i></a>
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@c.CompanyId"><i class="bi bi-pencil"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center mb-0">
            @for (var p = 1; p <= totalPages; p++)
            {
                <li class="page-item @(p == pageNumber ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-q="@q" asp-route-active="@active" asp-route-sort="@sort" asp-route-dir="@dir" asp-route-page="@p" asp-route-pageSize="@pageSize">@p</a>
                </li>
            }
        </ul>
    </nav>
}
