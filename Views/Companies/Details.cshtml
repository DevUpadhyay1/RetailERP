@model RetailERP.Data.Entities.Company
@{
    ViewData["Title"] = $"Company – {Model.Name}";
    var userCount = (ViewData["UserCount"] as int?) ?? 0;
    var storeCount = (ViewData["StoreCount"] as int?) ?? 0;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0"><i class="bi bi-building me-2"></i>@Model.Name</h2>
        <div class="text-muted">Code: @Model.Code</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@Model.CompanyId"><i class="bi bi-pencil me-1"></i>Edit</a>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Code</dt>
                    <dd class="col-sm-8"><code>@Model.Code</code></dd>

                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Model.Name</dd>

                    <dt class="col-sm-4">Business Type</dt>
                    <dd class="col-sm-8"><span class="badge bg-light text-dark border">@Model.BusinessType</span></dd>

                    <dt class="col-sm-4">Address</dt>
                    <dd class="col-sm-8">@(Model.Address ?? "—")</dd>

                    <dt class="col-sm-4">City / State / Pin</dt>
                    <dd class="col-sm-8">@(Model.City ?? "—"), @(Model.State ?? "—") @(Model.Pincode ?? "")</dd>

                    <dt class="col-sm-4">Phone</dt>
                    <dd class="col-sm-8">@(Model.Phone ?? "—")</dd>

                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@(Model.Email ?? "—")</dd>

                    <dt class="col-sm-4">Website</dt>
                    <dd class="col-sm-8">@(Model.Website ?? "—")</dd>

                    <dt class="col-sm-4">GST No</dt>
                    <dd class="col-sm-8">@(Model.GstNo ?? "—")</dd>

                    <dt class="col-sm-4">PAN No</dt>
                    <dd class="col-sm-8">@(Model.PanNo ?? "—")</dd>

                    <dt class="col-sm-4">CIN No</dt>
                    <dd class="col-sm-8">@(Model.CinNo ?? "—")</dd>

                    <dt class="col-sm-4">Max Users</dt>
                    <dd class="col-sm-8">@(Model.MaxUsers == 0 ? "Unlimited" : Model.MaxUsers.ToString())</dd>

                    <dt class="col-sm-4">Max Stores</dt>
                    <dd class="col-sm-8">@(Model.MaxStores == 0 ? "Unlimited" : Model.MaxStores.ToString())</dd>

                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactive</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Created</dt>
                    <dd class="col-sm-8">@Model.CreatedAtUtc.ToString("dd MMM yyyy HH:mm") UTC</dd>

                    <dt class="col-sm-4">Last Updated</dt>
                    <dd class="col-sm-8">@Model.UpdatedAtUtc.ToString("dd MMM yyyy HH:mm") UTC</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-center mb-3">
            <div class="card-body">
                <div class="display-6 fw-bold text-primary">@userCount</div>
                <div class="text-muted">Users</div>
            </div>
        </div>
        <div class="card text-center">
            <div class="card-body">
                <div class="display-6 fw-bold text-success">@storeCount</div>
                <div class="text-muted">Stores</div>
            </div>
        </div>
    </div>
</div>
