@model RetailERP.Models.StockAdjustVm
@{
    ViewData["Title"] = "Adjust Stock";
    var canApplyDirect = (ViewData["CanApplyDirect"] as bool?) ?? false;
}

<div class="vstack gap-3" style="max-width:720px;">
    <div class="d-flex align-items-center justify-content-between">
        <h2 class="mb-0">Adjust Stock</h2>
        <a class="btn btn-outline-secondary btn-sm" href="@(Model.ReturnUrl ?? Url.Action("Index")!)"><i class="bi bi-arrow-left me-1"></i>Back</a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="text-muted small mb-3">
                <div><strong>Item:</strong> @Model.ItemLabel</div>
                <div><strong>Warehouse:</strong> @Model.WarehouseName</div>
                <div><strong>Current Qty:</strong> @Model.CurrentQty</div>
            </div>

            @if (canApplyDirect)
            {
                <div class="alert alert-info py-2">
                    You are applying a direct stock adjustment. This will post immediately to stock ledger.
                </div>
            }
            else
            {
                <div class="alert alert-warning py-2">
                    Direct stock edits are restricted. This submission will create an approval request for Admin.
                </div>
            }

            <form method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="StockId" />
                <input type="hidden" asp-for="ReturnUrl" />
                <input type="hidden" asp-for="ItemLabel" />
                <input type="hidden" asp-for="WarehouseName" />
                <input type="hidden" asp-for="CurrentQty" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="DeltaQty" class="form-label">Delta Qty (+ add / - remove)</label>
                    <input asp-for="DeltaQty" class="form-control" />
                    <span asp-validation-for="DeltaQty" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Reason" class="form-label">Reason</label>
                    <input asp-for="Reason" class="form-control" />
                    <span asp-validation-for="Reason" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>@(canApplyDirect ? "Apply Adjustment" : "Submit Request")</button>
                    <a class="btn btn-outline-secondary" href="@(Model.ReturnUrl ?? Url.Action("Index")!)">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}