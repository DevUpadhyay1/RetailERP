@model RetailERP.Data.Entities.Stock

@{
    ViewData["Title"] = "Stock Details";
}

<div class="vstack gap-3" style="max-width:720px;">
    <div class="d-flex align-items-center justify-content-between">
        <h2 class="mb-0">Stock Details</h2>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back to List
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <dl class="row mb-0">
                <dt class="col-sm-3 text-muted">Item</dt>
                <dd class="col-sm-9">@(Model.Item?.Name ?? "—")</dd>
                <dt class="col-sm-3 text-muted">Warehouse</dt>
                <dd class="col-sm-9">@(Model.Warehouse?.Name ?? "—")</dd>
                <dt class="col-sm-3 text-muted">Quantity</dt>
                <dd class="col-sm-9 mb-0">@Html.DisplayFor(model => model.Quantity)</dd>
            </dl>
        </div>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Adjust" asp-route-id="@Model?.StockId" asp-route-returnUrl="@Url.Action("Index")" class="btn btn-primary btn-sm"><i class="bi bi-sliders me-1"></i>Adjust</a>
        <a asp-action="Delete" asp-route-id="@Model?.StockId" class="btn btn-outline-danger btn-sm"><i class="bi bi-trash me-1"></i>Delete</a>
    </div>
</div>
