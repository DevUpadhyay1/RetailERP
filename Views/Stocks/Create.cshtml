@model RetailERP.Data.Entities.Stock
@{
    ViewData["Title"] = "Create Stock Row";
}

<div class="vstack gap-3" style="max-width:720px;">
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <h2 class="mb-0">Create Stock Row</h2>
            <div class="text-muted small">Link an item to a warehouse. If opening quantity is entered, an audit ledger entry is created automatically.</div>
        </div>
        <a class="btn btn-outline-secondary btn-sm" asp-action="Index"><i class="bi bi-arrow-left me-1"></i>Back to List</a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="ItemId" class="form-label">Item</label>
                        <select asp-for="ItemId" class="form-select" asp-items="ViewBag.ItemId">
                            <option value="" disabled selected>-- Select Item --</option>
                        </select>
                        <span asp-validation-for="ItemId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="WarehouseId" class="form-label">Warehouse</label>
                        <select asp-for="WarehouseId" class="form-select" asp-items="ViewBag.WarehouseId">
                            <option value="" disabled selected>-- Select Warehouse --</option>
                        </select>
                        <span asp-validation-for="WarehouseId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Quantity" class="form-label"></label>
                        <input asp-for="Quantity" class="form-control" type="number" min="0" step="0.01" />
                        <span asp-validation-for="Quantity" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Create</button>
                    <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
