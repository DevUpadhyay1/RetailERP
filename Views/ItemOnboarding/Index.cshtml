@model RetailERP.Controllers.ItemOnboardingController.OnboardingPageVm
@{
    ViewData["Title"] = "Data Migration Onboarding";
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h2 class="mb-0">Data Migration Onboarding</h2>
        <div class="text-muted small">Switch-ready import for Items, Customers, and Suppliers</div>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-primary btn-sm" asp-action="DownloadTemplate" asp-route-type="standard">Item Template</a>
        <a class="btn btn-outline-secondary btn-sm" asp-action="DownloadTemplate" asp-route-type="supplier">Supplier Item Template</a>
        <a class="btn btn-outline-success btn-sm" asp-action="DownloadCustomerTemplate">Customer Template</a>
        <a class="btn btn-outline-dark btn-sm" asp-action="DownloadSupplierTemplate">Supplier Template</a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.GeneralError))
{
    <div class="alert alert-danger">@Model.GeneralError</div>
}

<div class="row g-3">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-header">Import Items (CSV)</div>
            <div class="card-body">
                <form asp-action="ImportCsv" method="post" enctype="multipart/form-data" class="vstack gap-3">
                    @Html.AntiForgeryToken()

                    <div>
                        <label class="form-label">CSV File</label>
                        <input class="form-control" type="file" name="file" accept=".csv" required />
                        <div class="form-text">Supports optional columns: OpeningStock, WarehouseName, BatchNumber, ExpiryDate.</div>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="updateExisting" name="updateExisting" value="true" checked="@Model.UpdateExisting" />
                        <input type="hidden" name="updateExisting" value="false" />
                        <label class="form-check-label" for="updateExisting">Update existing items when SKU already exists</label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="createMissingLookups" name="createMissingLookups" value="true" checked="@Model.CreateMissingLookups" />
                        <input type="hidden" name="createMissingLookups" value="false" />
                        <label class="form-check-label" for="createMissingLookups">Auto-create missing Units/Categories/Warehouse</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button class="btn btn-primary" type="submit">Import Items</button>
                        <a class="btn btn-outline-dark" asp-action="Index">Reset</a>
                    </div>
                </form>
            </div>
        </div>

        @if (Model.ImportResult is not null)
        {
            var r = Model.ImportResult;
            <div class="card shadow-sm mt-3">
                <div class="card-header">Item Import Result - @r.SourceName</div>
                <div class="card-body">
                    <div class="row g-2 mb-3">
                        <div class="col-6 col-md-3"><div class="border rounded p-2"><div class="text-muted small">Rows</div><div class="fw-semibold">@r.TotalRows</div></div></div>
                        <div class="col-6 col-md-3"><div class="border rounded p-2"><div class="text-muted small">Inserted</div><div class="fw-semibold text-success">@r.Inserted</div></div></div>
                        <div class="col-6 col-md-3"><div class="border rounded p-2"><div class="text-muted small">Updated</div><div class="fw-semibold text-primary">@r.Updated</div></div></div>
                        <div class="col-6 col-md-3"><div class="border rounded p-2"><div class="text-muted small">Skipped</div><div class="fw-semibold text-secondary">@r.Skipped</div></div></div>
                    </div>

                    @if (r.Errors.Any())
                    {
                        <div class="alert alert-warning mb-2">Found @r.Errors.Count row issues. Review below.</div>
                        <div class="table-responsive">
                            <table class="table table-sm table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width:90px;">Row</th>
                                        <th style="width:160px;">SKU</th>
                                        <th>Issue</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var e in r.Errors.Take(200))
                                    {
                                        <tr>
                                            <td>@e.RowNumber</td>
                                            <td>@(string.IsNullOrWhiteSpace(e.Sku) ? "-" : e.Sku)</td>
                                            <td>@e.Message</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-success mb-0">Item import completed without row errors.</div>
                    }
                </div>
            </div>
        }

        <div class="card shadow-sm mt-3">
            <div class="card-header">Import Customers (CSV)</div>
            <div class="card-body">
                @if (!string.IsNullOrWhiteSpace(Model.CustomerError))
                {
                    <div class="alert alert-danger">@Model.CustomerError</div>
                }
                <form asp-action="ImportCustomers" method="post" enctype="multipart/form-data" class="vstack gap-3">
                    @Html.AntiForgeryToken()

                    <div>
                        <label class="form-label">Customer CSV File</label>
                        <input class="form-control" type="file" name="file" accept=".csv" required />
                        <div class="form-text">Columns: Name, Phone, Email, Address, GSTIN, OpeningBalance</div>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="updateExistingCustomers" name="updateExistingCustomers" value="true" checked="@Model.CustomerUpdateExisting" />
                        <input type="hidden" name="updateExistingCustomers" value="false" />
                        <label class="form-check-label" for="updateExistingCustomers">Update existing customers by name</label>
                    </div>

                    <div>
                        <button class="btn btn-success" type="submit">Import Customers</button>
                    </div>
                </form>
            </div>
        </div>

        @if (Model.CustomerImportResult is not null)
        {
            var c = Model.CustomerImportResult;
            <div class="card shadow-sm mt-3">
                <div class="card-header">Customer Import Result - @c.SourceName</div>
                <div class="card-body">
                    <div class="row g-2 mb-3">
                        <div class="col-6 col-md-3"><div class="border rounded p-2"><div class="text-muted small">Rows</div><div class="fw-semibold">@c.TotalRows</div></div></div>
                        <div class="col-6 col-md-3"><div class="border rounded p-2"><div class="text-muted small">Inserted</div><div class="fw-semibold text-success">@c.Inserted</div></div></div>
                        <div class="col-6 col-md-3"><div class="border rounded p-2"><div class="text-muted small">Updated</div><div class="fw-semibold text-primary">@c.Updated</div></div></div>
                        <div class="col-6 col-md-3"><div class="border rounded p-2"><div class="text-muted small">Skipped</div><div class="fw-semibold text-secondary">@c.Skipped</div></div></div>
                    </div>
                    @if (c.Errors.Any())
                    {
                        <div class="alert alert-warning mb-2">Found @c.Errors.Count row issues. Review below.</div>
                        <ul class="mb-0">
                            @foreach (var e in c.Errors.Take(100))
                            {
                                <li>Row @e.RowNumber - @e.Message</li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="alert alert-success mb-0">Customer import completed without row errors.</div>
                    }
                </div>
            </div>
        }

        <div class="card shadow-sm mt-3">
            <div class="card-header">Import Suppliers (CSV)</div>
            <div class="card-body">
                @if (!string.IsNullOrWhiteSpace(Model.SupplierError))
                {
                    <div class="alert alert-danger">@Model.SupplierError</div>
                }
                <form asp-action="ImportSuppliers" method="post" enctype="multipart/form-data" class="vstack gap-3">
                    @Html.AntiForgeryToken()

                    <div>
                        <label class="form-label">Supplier CSV File</label>
                        <input class="form-control" type="file" name="file" accept=".csv" required />
                        <div class="form-text">Columns: Name, ContactPerson, Phone, Email, GSTIN, Address, OpeningBalance</div>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="updateExistingSuppliers" name="updateExistingSuppliers" value="true" checked="@Model.SupplierUpdateExisting" />
                        <input type="hidden" name="updateExistingSuppliers" value="false" />
                        <label class="form-check-label" for="updateExistingSuppliers">Update existing suppliers by name</label>
                    </div>

                    <div>
                        <button class="btn btn-dark" type="submit">Import Suppliers</button>
                    </div>
                </form>
            </div>
        </div>

        @if (Model.SupplierImportResult is not null)
        {
            var s = Model.SupplierImportResult;
            <div class="card shadow-sm mt-3">
                <div class="card-header">Supplier Import Result - @s.SourceName</div>
                <div class="card-body">
                    <div class="row g-2 mb-3">
                        <div class="col-6 col-md-3"><div class="border rounded p-2"><div class="text-muted small">Rows</div><div class="fw-semibold">@s.TotalRows</div></div></div>
                        <div class="col-6 col-md-3"><div class="border rounded p-2"><div class="text-muted small">Inserted</div><div class="fw-semibold text-success">@s.Inserted</div></div></div>
                        <div class="col-6 col-md-3"><div class="border rounded p-2"><div class="text-muted small">Updated</div><div class="fw-semibold text-primary">@s.Updated</div></div></div>
                        <div class="col-6 col-md-3"><div class="border rounded p-2"><div class="text-muted small">Skipped</div><div class="fw-semibold text-secondary">@s.Skipped</div></div></div>
                    </div>
                    @if (s.Errors.Any())
                    {
                        <div class="alert alert-warning mb-2">Found @s.Errors.Count row issues. Review below.</div>
                        <ul class="mb-0">
                            @foreach (var e in s.Errors.Take(100))
                            {
                                <li>Row @e.RowNumber - @e.Message</li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="alert alert-success mb-0">Supplier import completed without row errors.</div>
                    }
                </div>
            </div>
        }
    </div>

    <div class="col-lg-5">
        <div class="card shadow-sm">
            <div class="card-header">Apply Starter Pack</div>
            <div class="card-body">
                <form asp-action="ApplyStarterPack" method="post" class="vstack gap-3">
                    @Html.AntiForgeryToken()
                    <div>
                        <label class="form-label">Business Type</label>
                        <select class="form-select" name="businessType">
                            @foreach (var bt in Model.BusinessTypes)
                            {
                                <option value="@bt.Value" selected="@(bt.Value == Model.SelectedBusinessType)">@bt.Label</option>
                            }
                        </select>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="updateExistingPack" name="updateExistingPack" value="true" checked="@Model.UpdateExistingPack" />
                        <input type="hidden" name="updateExistingPack" value="false" />
                        <label class="form-check-label" for="updateExistingPack">Update existing items if SKU already exists</label>
                    </div>

                    <button class="btn btn-outline-primary" type="submit">Apply Pack</button>
                </form>
            </div>
        </div>

        @if (Model.StarterPackResult is not null)
        {
            var s = Model.StarterPackResult;
            <div class="card shadow-sm mt-3">
                <div class="card-header">Starter Pack Result</div>
                <div class="card-body">
                    <div class="mb-2"><span class="text-muted">Business Type:</span> <strong>@s.BusinessType</strong></div>
                    <div class="row g-2">
                        <div class="col-6"><div class="border rounded p-2"><div class="text-muted small">Pack Rows</div><div class="fw-semibold">@s.TotalItems</div></div></div>
                        <div class="col-6"><div class="border rounded p-2"><div class="text-muted small">Inserted</div><div class="fw-semibold text-success">@s.Inserted</div></div></div>
                        <div class="col-6"><div class="border rounded p-2"><div class="text-muted small">Updated</div><div class="fw-semibold text-primary">@s.Updated</div></div></div>
                        <div class="col-6"><div class="border rounded p-2"><div class="text-muted small">Skipped</div><div class="fw-semibold text-secondary">@s.Skipped</div></div></div>
                    </div>

                    @if (s.Warnings.Any())
                    {
                        <div class="alert alert-warning mt-3 mb-0">
                            @foreach (var w in s.Warnings)
                            {
                                <div>@w</div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>
