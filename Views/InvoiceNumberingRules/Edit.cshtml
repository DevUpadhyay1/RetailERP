@model RetailERP.Controllers.InvoiceNumberingRulesController.UpsertVm
@{
    ViewData["Title"] = "Edit Numbering Rule";
}

<h2 class="mb-3">Edit Numbering Rule</h2>

<form asp-action="Edit" asp-route-id="@Model.InvoiceNumberingRuleId" method="post" class="card">
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
        <input asp-for="InvoiceNumberingRuleId" type="hidden" />
        <partial name="_Form" model="Model" />
    </div>
    <div class="card-footer d-flex gap-2">
        <button type="submit" class="btn btn-primary">Update Rule</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
