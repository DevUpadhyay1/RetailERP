@model RetailERP.Services.PortalService.SupplierPortalVm
@{
    ViewData["Title"] = "Supplier Portal";
    var token = (ViewBag.Token as string) ?? "";
    DateTime? exp = ViewBag.ExpiresAtUtc as DateTime?;
}

<div class="container-xxl py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-0">Supplier Self-Service Portal</h2>
            <div class="text-muted small">@Model.SupplierName</div>
        </div>
        <div class="text-end small text-muted">
            <div>Phone: @(Model.Phone ?? "-")</div>
            <div>Email: @(Model.Email ?? "-")</div>
            <div>Link Expires (UTC): @(exp?.ToString("yyyy-MM-dd HH:mm") ?? "-")</div>
        </div>
    </div>

    @if (TempData["Ok"] is string ok)
    {
        <div class="alert alert-success">@ok</div>
    }
    @if (TempData["Err"] is string err)
    {
        <div class="alert alert-danger">@err</div>
    }

    <div class="card shadow-sm">
        <div class="card-header fw-semibold">Purchase Orders</div>
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th>PO No</th>
                        <th>Date</th>
                        <th>Warehouse</th>
                        <th>Lines</th>
                        <th>Total</th>
                        <th>PO Status</th>
                        <th>Supplier Response</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.PurchaseOrders.Count == 0)
                    {
                        <tr><td colspan="7" class="text-center text-muted py-3">No purchase orders found.</td></tr>
                    }
                    else
                    {
                        @foreach (var p in Model.PurchaseOrders)
                        {
                            <tr>
                                <td>@p.PurchaseNo</td>
                                <td>@p.PurchaseDate.ToString("yyyy-MM-dd")</td>
                                <td>@p.WarehouseName</td>
                                <td>@p.LineCount</td>
                                <td>₹@p.TotalAmount.ToString("0.##")</td>
                                <td>
                                    <span class="badge @(p.PurchaseStatus == 2 ? "bg-success" : "bg-warning text-dark")">
                                        @(p.PurchaseStatus == 2 ? "Received" : "Draft")
                                    </span>
                                </td>
                                <td style="min-width: 360px;">
                                    @if (p.PurchaseStatus == 2)
                                    {
                                        <span class="text-muted small">PO already received by store.</span>
                                    }
                                    else
                                    {
                                        <form asp-action="RespondPo" method="post" class="row g-1">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="token" value="@token" />
                                            <input type="hidden" name="purchaseId" value="@p.PurchaseId" />
                                            <div class="col-md-4">
                                                <select class="form-select form-select-sm" name="responseStatus">
                                                    <option value="2" selected="@(p.ResponseStatus == 2)">Accept</option>
                                                    <option value="3" selected="@(p.ResponseStatus == 3)">Reject</option>
                                                </select>
                                            </div>
                                            <div class="col-md-4">
                                                <input class="form-control form-control-sm" type="date" name="expectedDeliveryDate" value="@p.ExpectedDeliveryDate?.ToString("yyyy-MM-dd")" />
                                            </div>
                                            <div class="col-md-4 d-grid">
                                                <button class="btn btn-sm btn-outline-primary">Submit</button>
                                            </div>
                                            <div class="col-12">
                                                <input class="form-control form-control-sm" name="supplierNote" maxlength="500" placeholder="Note for store team" value="@p.SupplierNote" />
                                            </div>
                                            @if (p.RespondedAtUtc is not null)
                                            {
                                                <div class="col-12 small text-muted">Last response UTC: @p.RespondedAtUtc?.ToString("yyyy-MM-dd HH:mm")</div>
                                            }
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
