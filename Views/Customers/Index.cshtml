@model IEnumerable<RetailERP.Data.Entities.Customer>

@{
    ViewData["Title"] = "Customers";
    var q = (ViewData["q"] as string) ?? "";
    var count = Model?.Count() ?? 0;
}

<div class="container-fluid py-3">

    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h2 class="mb-0">@ViewData["Title"]</h2>
            <div class="text-muted small">Total: @count record(s)</div>
        </div>

        <a class="btn btn-primary" asp-action="Create">
            + Add Customer
        </a>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <form method="get" class="row g-2 align-items-center">
                <div class="col-md-6">
                    <input name="q" value="@q" class="form-control"
                           placeholder="Search by Name, Phone, or Email..." />
                </div>

                <div class="col-auto">
                    <button class="btn btn-outline-secondary" type="submit">Search</button>
                </div>

                <div class="col-auto">
                    <a class="btn btn-outline-dark" asp-action="Index">Reset</a>
                </div>

                <div class="col-auto ms-auto">
                    <span class="badge text-bg-light border">
                        Updated: @DateTime.Now.ToString("dd-MMM-yyyy")
                    </span>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (count == 0)
            {
                <div class="p-4">
                    <div class="alert alert-warning mb-0">
                        No customers found.
                        <a asp-action="Create" class="alert-link">Create your first customer</a>.
                    </div>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Phone</th>
                                <th>Email</th>
                                <th class="text-end" style="width: 170px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@c.Name</td>
                                    <td>@(string.IsNullOrWhiteSpace(c.Phone) ? "-" : c.Phone)</td>
                                    <td>@(string.IsNullOrWhiteSpace(c.Email) ? "-" : c.Email)</td>
                                    <td class="text-end">
                                        <div class="btn-group">
                                            <a class="btn btn-sm btn-outline-primary"
                                               asp-action="Edit" asp-route-id="@c.CustomerId">Edit</a>
                                            <a class="btn btn-sm btn-outline-secondary"
                                               asp-action="Details" asp-route-id="@c.CustomerId">View</a>
                                            <a class="btn btn-sm btn-outline-danger"
                                               asp-action="Delete" asp-route-id="@c.CustomerId">Delete</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

</div>