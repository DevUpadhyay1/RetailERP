@model RetailERP.Data.Entities.Customer

@{
    ViewData["Title"] = "Edit Customer";
}

<div class="vstack gap-3" style="max-width:720px;">
    <div class="d-flex align-items-center justify-content-between">
        <h2 class="mb-0">Edit Customer</h2>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back to List
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="CustomerId" />
                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Phone" class="form-label"></label>
                        <input asp-for="Phone" class="form-control" type="tel" maxlength="10" pattern="[6-9]\d{9}" placeholder="e.g. 9876543210" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" type="email" placeholder="e.g. name@example.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Gstin" class="form-label">GSTIN</label>
                        <input asp-for="Gstin" class="form-control" maxlength="15" placeholder="e.g. 29ABCDE1234F1Z5" style="text-transform:uppercase" />
                        <span asp-validation-for="Gstin" class="text-danger"></span>
                    </div>
                    <div class="col-md-8">
                        <label asp-for="Address" class="form-label">Address</label>
                        <input asp-for="Address" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="City" class="form-label">City</label>
                        <input asp-for="City" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="State" class="form-label">State</label>
                        <input asp-for="State" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="PinCode" class="form-label">Pin Code</label>
                        <input asp-for="PinCode" class="form-control" type="tel" maxlength="6" pattern="\d{6}" placeholder="e.g. 560001" />
                    </div>
                    <div class="col-12">
                        <hr class="my-1" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Save</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
