@model RetailERP.Controllers.ForecastController.ForecastAnomalyVm
@{
    ViewData["Title"] = "Sales Anomalies";

    string ToggleDir(string nextSort)
    {
        if (!string.Equals(Model.Sort, nextSort, StringComparison.OrdinalIgnoreCase)) return "asc";
        return string.Equals(Model.Dir, "asc", StringComparison.OrdinalIgnoreCase) ? "desc" : "asc";
    }
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h2 class="mb-0">Sales Anomalies</h2>
        <div class="text-muted small">Showing @Model.FromRow-@Model.ToRow of @Model.Total anomaly rows</div>
    </div>
    <a class="btn btn-outline-secondary btn-sm"
       asp-action="Index"
       asp-route-from="@Model.From.ToString("yyyy-MM-dd")"
       asp-route-to="@Model.To.ToString("yyyy-MM-dd")"
       asp-route-warehouseId="@Model.WarehouseId">Forecast Dashboard</a>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label mb-1">From</label>
                <input type="date" name="from" class="form-control" value="@Model.From.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-2">
                <label class="form-label mb-1">To</label>
                <input type="date" name="to" class="form-control" value="@Model.To.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-2">
                <label class="form-label mb-1">Warehouse</label>
                <select name="warehouseId" class="form-select">
                    <option value="">All Warehouses</option>
                    @foreach (var w in Model.Warehouses)
                    {
                        <option value="@w.WarehouseId" selected="@(Model.WarehouseId == w.WarehouseId)">@w.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label mb-1">Severity</label>
                <select name="severity" class="form-select">
                    <option value="">All</option>
                    <option value="Critical" selected="@(string.Equals(Model.Severity, "Critical", StringComparison.OrdinalIgnoreCase))">Critical</option>
                    <option value="High" selected="@(string.Equals(Model.Severity, "High", StringComparison.OrdinalIgnoreCase))">High</option>
                    <option value="Medium" selected="@(string.Equals(Model.Severity, "Medium", StringComparison.OrdinalIgnoreCase))">Medium</option>
                    <option value="Low" selected="@(string.Equals(Model.Severity, "Low", StringComparison.OrdinalIgnoreCase))">Low</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label mb-1">Direction</label>
                <select name="direction" class="form-select">
                    <option value="">All</option>
                    <option value="Spike" selected="@(string.Equals(Model.Direction, "Spike", StringComparison.OrdinalIgnoreCase))">Spike</option>
                    <option value="Drop" selected="@(string.Equals(Model.Direction, "Drop", StringComparison.OrdinalIgnoreCase))">Drop</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label mb-1">Search</label>
                <input name="q" value="@Model.Q" class="form-control" placeholder="SKU / item / warehouse" />
            </div>
            <div class="col-md-2">
                <label class="form-label mb-1">Rows</label>
                <select name="pageSize" class="form-select">
                    <option value="10" selected="@(Model.PageSize == 10)">10</option>
                    <option value="25" selected="@(Model.PageSize == 25)">25</option>
                    <option value="50" selected="@(Model.PageSize == 50)">50</option>
                    <option value="100" selected="@(Model.PageSize == 100)">100</option>
                </select>
            </div>
            <input type="hidden" name="sort" value="@Model.Sort" />
            <input type="hidden" name="dir" value="@Model.Dir" />
            <input type="hidden" name="page" value="1" />
            <div class="col-md-2 d-grid">
                <button class="btn btn-primary" type="submit">Apply</button>
            </div>
        </form>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="card text-center border-danger shadow-sm">
            <div class="card-body py-2">
                <div class="fs-4 fw-bold text-danger">@Model.CriticalOrHigh</div>
                <small class="text-muted">Critical/High</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-dark shadow-sm">
            <div class="card-body py-2">
                <div class="fs-4 fw-bold">@Model.Total</div>
                <small class="text-muted">Total</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-warning shadow-sm">
            <div class="card-body py-2">
                <div class="fs-4 fw-bold text-warning">@Model.Spikes</div>
                <small class="text-muted">Spikes</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-info shadow-sm">
            <div class="card-body py-2">
                <div class="fs-4 fw-bold text-info">@Model.Drops</div>
                <small class="text-muted">Drops</small>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:120px;">
                            <a class="text-decoration-none" asp-action="Anomalies" asp-route-from="@Model.From.ToString("yyyy-MM-dd")" asp-route-to="@Model.To.ToString("yyyy-MM-dd")" asp-route-warehouseId="@Model.WarehouseId" asp-route-q="@Model.Q" asp-route-severity="@Model.Severity" asp-route-direction="@Model.Direction" asp-route-sort="date" asp-route-dir="@ToggleDir("date")" asp-route-page="1" asp-route-pageSize="@Model.PageSize">Date</a>
                        </th>
                        <th style="width:120px;">
                            <a class="text-decoration-none" asp-action="Anomalies" asp-route-from="@Model.From.ToString("yyyy-MM-dd")" asp-route-to="@Model.To.ToString("yyyy-MM-dd")" asp-route-warehouseId="@Model.WarehouseId" asp-route-q="@Model.Q" asp-route-severity="@Model.Severity" asp-route-direction="@Model.Direction" asp-route-sort="sku" asp-route-dir="@ToggleDir("sku")" asp-route-page="1" asp-route-pageSize="@Model.PageSize">SKU</a>
                        </th>
                        <th>
                            <a class="text-decoration-none" asp-action="Anomalies" asp-route-from="@Model.From.ToString("yyyy-MM-dd")" asp-route-to="@Model.To.ToString("yyyy-MM-dd")" asp-route-warehouseId="@Model.WarehouseId" asp-route-q="@Model.Q" asp-route-severity="@Model.Severity" asp-route-direction="@Model.Direction" asp-route-sort="item" asp-route-dir="@ToggleDir("item")" asp-route-page="1" asp-route-pageSize="@Model.PageSize">Item</a>
                        </th>
                        <th style="width:180px;">
                            <a class="text-decoration-none" asp-action="Anomalies" asp-route-from="@Model.From.ToString("yyyy-MM-dd")" asp-route-to="@Model.To.ToString("yyyy-MM-dd")" asp-route-warehouseId="@Model.WarehouseId" asp-route-q="@Model.Q" asp-route-severity="@Model.Severity" asp-route-direction="@Model.Direction" asp-route-sort="warehouse" asp-route-dir="@ToggleDir("warehouse")" asp-route-page="1" asp-route-pageSize="@Model.PageSize">Warehouse</a>
                        </th>
                        <th class="text-end" style="width:110px;">Expected</th>
                        <th class="text-end" style="width:110px;">Actual</th>
                        <th class="text-end" style="width:110px;">
                            <a class="text-decoration-none" asp-action="Anomalies" asp-route-from="@Model.From.ToString("yyyy-MM-dd")" asp-route-to="@Model.To.ToString("yyyy-MM-dd")" asp-route-warehouseId="@Model.WarehouseId" asp-route-q="@Model.Q" asp-route-severity="@Model.Severity" asp-route-direction="@Model.Direction" asp-route-sort="deviation" asp-route-dir="@ToggleDir("deviation")" asp-route-page="1" asp-route-pageSize="@Model.PageSize">Deviation %</a>
                        </th>
                        <th class="text-end" style="width:90px;">
                            <a class="text-decoration-none" asp-action="Anomalies" asp-route-from="@Model.From.ToString("yyyy-MM-dd")" asp-route-to="@Model.To.ToString("yyyy-MM-dd")" asp-route-warehouseId="@Model.WarehouseId" asp-route-q="@Model.Q" asp-route-severity="@Model.Severity" asp-route-direction="@Model.Direction" asp-route-sort="zscore" asp-route-dir="@ToggleDir("zscore")" asp-route-page="1" asp-route-pageSize="@Model.PageSize">Z</a>
                        </th>
                        <th class="text-center" style="width:110px;">
                            <a class="text-decoration-none" asp-action="Anomalies" asp-route-from="@Model.From.ToString("yyyy-MM-dd")" asp-route-to="@Model.To.ToString("yyyy-MM-dd")" asp-route-warehouseId="@Model.WarehouseId" asp-route-q="@Model.Q" asp-route-severity="@Model.Severity" asp-route-direction="@Model.Direction" asp-route-sort="severity" asp-route-dir="@ToggleDir("severity")" asp-route-page="1" asp-route-pageSize="@Model.PageSize">Severity</a>
                        </th>
                        <th class="text-center" style="width:100px;">Direction</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Rows.Any())
                    {
                        <tr><td colspan="10" class="text-center text-muted py-4">No anomalies found for the selected filters.</td></tr>
                    }
                    else
                    {
                        @foreach (var a in Model.Rows)
                        {
                            <tr>
                                <td class="text-muted">@a.Date.ToString("dd-MMM-yyyy")</td>
                                <td class="fw-semibold">@a.ItemSku</td>
                                <td>@a.ItemName</td>
                                <td>@a.WarehouseName</td>
                                <td class="text-end">@a.ExpectedQty.ToString("0.##")</td>
                                <td class="text-end">@a.ActualQty.ToString("0.##")</td>
                                <td class="text-end">@a.DeviationPercent.ToString("0.0")%</td>
                                <td class="text-end">@a.ZScore.ToString("0.00")</td>
                                <td class="text-center">
                                    @if (string.Equals(a.Severity, "Critical", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge bg-danger">Critical</span>
                                    }
                                    else if (string.Equals(a.Severity, "High", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge bg-warning text-dark">High</span>
                                    }
                                    else if (string.Equals(a.Severity, "Medium", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge bg-info text-dark">Medium</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Low</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (string.Equals(a.Direction, "Spike", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="badge bg-warning text-dark">Spike</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary">Drop</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="card-footer">
            <nav>
                <ul class="pagination pagination-sm mb-0 justify-content-center">
                    <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Anomalies" asp-route-from="@Model.From.ToString("yyyy-MM-dd")" asp-route-to="@Model.To.ToString("yyyy-MM-dd")" asp-route-warehouseId="@Model.WarehouseId" asp-route-q="@Model.Q" asp-route-severity="@Model.Severity" asp-route-direction="@Model.Direction" asp-route-sort="@Model.Sort" asp-route-dir="@Model.Dir" asp-route-page="@(Model.Page-1)" asp-route-pageSize="@Model.PageSize">Prev</a>
                    </li>
                    @for (var p = Math.Max(1, Model.Page - 2); p <= Math.Min(Model.TotalPages, Model.Page + 2); p++)
                    {
                        <li class="page-item @(p == Model.Page ? "active" : "")">
                            <a class="page-link" asp-action="Anomalies" asp-route-from="@Model.From.ToString("yyyy-MM-dd")" asp-route-to="@Model.To.ToString("yyyy-MM-dd")" asp-route-warehouseId="@Model.WarehouseId" asp-route-q="@Model.Q" asp-route-severity="@Model.Severity" asp-route-direction="@Model.Direction" asp-route-sort="@Model.Sort" asp-route-dir="@Model.Dir" asp-route-page="@p" asp-route-pageSize="@Model.PageSize">@p</a>
                        </li>
                    }
                    <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="Anomalies" asp-route-from="@Model.From.ToString("yyyy-MM-dd")" asp-route-to="@Model.To.ToString("yyyy-MM-dd")" asp-route-warehouseId="@Model.WarehouseId" asp-route-q="@Model.Q" asp-route-severity="@Model.Severity" asp-route-direction="@Model.Direction" asp-route-sort="@Model.Sort" asp-route-dir="@Model.Dir" asp-route-page="@(Model.Page+1)" asp-route-pageSize="@Model.PageSize">Next</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
