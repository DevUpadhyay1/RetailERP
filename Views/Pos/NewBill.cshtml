@using Microsoft.AspNetCore.Mvc.Rendering
@using RetailERP.Data.Entities
@{
    ViewData["Title"] = "New POS Bill";
    var hasDefaults = ViewBag.HasValidDefaults as bool? == true;
    var selWh = ViewBag.SelectedWarehouseId as Guid?;
    var whRows = ViewBag.WarehouseRows as IEnumerable<Warehouse> ?? Enumerable.Empty<Warehouse>();
}

<div class="vstack gap-3" style="max-width:720px;">
    <div>
        <h2 class="mb-1"><i class="bi bi-cart-plus me-2"></i>New POS Bill</h2>
        <p class="text-muted mb-0">Select store and warehouse to start. Save defaults once to open POS in one click next time.</p>
    </div>

    @if (TempData["Info"] is string info)
    {
        <div class="alert alert-info py-2 mb-0"><i class="bi bi-info-circle me-1"></i>@info</div>
    }
    @if (TempData["Err"] is string err2)
    {
        <div class="alert alert-danger py-2 mb-0">@err2</div>
    }

    @if (hasDefaults)
    {
        <div class="card border-success shadow-sm">
            <div class="card-body d-flex flex-wrap align-items-center justify-content-between gap-2 py-3">
                <div>
                    <div class="fw-semibold text-success"><i class="bi bi-lightning-charge-fill me-1"></i>Quick start</div>
                    <div class="small text-muted mb-0">Use your saved store &amp; warehouse (no form).</div>
                </div>
                <a class="btn btn-success" asp-action="StartQuick"><i class="bi bi-play-fill me-1"></i>Start POS now</a>
            </div>
        </div>
    }

    <form asp-action="NewBill" method="post">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-medium" for="storeId">Store</label>
                        <select class="form-select" name="storeId" id="storeId" required>
                            <option value="">— Select store —</option>
                            @foreach (SelectListItem s in (ViewBag.Stores as SelectList)!)
                            {
                                if (s.Selected)
                                {
                                    <option value="@s.Value" selected="selected">@s.Text</option>
                                }
                                else
                                {
                                    <option value="@s.Value">@s.Text</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-medium" for="warehouseId">Warehouse</label>
                        <select class="form-select" name="warehouseId" id="warehouseId" required>
                            <option value="">— Select warehouse —</option>
                            @foreach (var w in whRows)
                            {
                                var selected = selWh.HasValue && selWh.Value == w.WarehouseId;
                                var ds = w.StoreId?.ToString() ?? "";
                                if (selected)
                                {
                                    <option value="@w.WarehouseId" selected="selected" data-store="@ds">@w.Name</option>
                                }
                                else
                                {
                                    <option value="@w.WarehouseId" data-store="@ds">@w.Name</option>
                                }
                            }
                        </select>
                        <div class="form-text">Only warehouses for the selected store are shown (plus company-wide warehouses).</div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-medium">Customer <span class="text-muted fw-normal">(optional, walk-in)</span></label>
                        <select class="form-select" name="customerId">
                            <option value="">Walk-in Customer</option>
                            @foreach (SelectListItem c in (ViewBag.Customers as SelectList)!)
                            {
                                <option value="@c.Value">@c.Text</option>
                            }
                        </select>
                    </div>

                    <div class="col-12">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="saveAsDefault" value="true" id="saveAsDefault" />
                            <label class="form-check-label" for="saveAsDefault">
                                Save as my default for POS <span class="text-muted">(sidebar “POS Billing” will open a new bill immediately)</span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-play-fill me-1"></i>Start billing</button>
                <a class="btn btn-outline-secondary" asp-action="Index"><i class="bi bi-x-lg me-1"></i>Cancel</a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        (function () {
            var store = document.getElementById('storeId');
            var wh = document.getElementById('warehouseId');
            if (!store || !wh) return;

            function filterWarehouses() {
                var sid = store.value;
                var firstVisible = '';
                for (var i = 0; i < wh.options.length; i++) {
                    var o = wh.options[i];
                    if (!o.value) { o.hidden = false; continue; }
                    var ds = o.getAttribute('data-store') || '';
                    // Empty data-store = company-wide → always visible
                    var ok = !ds || ds === sid;
                    o.hidden = !ok;
                    if (ok && !firstVisible) firstVisible = o.value;
                }
                var cur = wh.options[wh.selectedIndex];
                if (cur && cur.hidden) wh.value = firstVisible || '';
            }

            store.addEventListener('change', filterWarehouses);
            filterWarehouses();
        })();
    </script>
}
