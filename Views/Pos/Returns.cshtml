@model List<RetailERP.Data.Entities.PosReturn>
@{
    ViewData["Title"] = "POS Returns";
    var q = (ViewData["q"] as string) ?? "";
    var statusFilter = ViewData["status"] as byte?;
    var sort = (ViewData["sort"] as string) ?? "date";
    var dir = (ViewData["dir"] as string) ?? "desc";
    var pageNumber = (ViewData["page"] as int?) ?? 1;
    var pageSize = (ViewData["pageSize"] as int?) ?? 20;
    var total = (ViewData["total"] as int?) ?? 0;
    var from = (ViewData["from"] as int?) ?? 0;
    var to = (ViewData["to"] as int?) ?? 0;
    var totalPages = (ViewData["totalPages"] as int?) ?? 1;

    string ToggleDir(string s) =>
        string.Equals(sort, s, StringComparison.OrdinalIgnoreCase) && string.Equals(dir, "asc", StringComparison.OrdinalIgnoreCase) ? "desc" : "asc";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0"><i class="bi bi-arrow-return-left me-2"></i>POS Returns</h2>
        <div class="text-muted small">Showing @from–@to of @total</div>
    </div>
</div>

@if (TempData["Ok"] is string ok) { <div class="alert alert-success py-2">@ok</div> }
@if (TempData["Err"] is string err) { <div class="alert alert-danger py-2">@err</div> }

<form method="get" class="card shadow-sm border-0 mb-3">
    <div class="card-body py-2">
        <div class="row g-2 align-items-center">
            <div class="col-md-5">
                <input class="form-control" name="q" value="@q" placeholder="Search return# or bill#…" />
            </div>
            <div class="col-md-3">
                <select class="form-select" name="status">
                    <option value="">All statuses</option>
                    <option value="1" selected="@(statusFilter == 1)">Pending</option>
                    <option value="2" selected="@(statusFilter == 2)">Processed</option>
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-primary w-100" type="submit"><i class="bi bi-funnel me-1"></i>Filter</button>
            </div>
        </div>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th><a href="?q=@q&status=@statusFilter&sort=no&dir=@ToggleDir("no")&page=1&pageSize=@pageSize" class="text-decoration-none">Return #</a></th>
                <th><a href="?q=@q&status=@statusFilter&sort=date&dir=@ToggleDir("date")&page=1&pageSize=@pageSize" class="text-decoration-none">Date</a></th>
                <th>Original Bill</th>
                <th>Store</th>
                <th>Customer</th>
                <th class="text-end"><a href="?q=@q&status=@statusFilter&sort=refund&dir=@ToggleDir("refund")&page=1&pageSize=@pageSize" class="text-decoration-none">Refund</a></th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td class="fw-medium">@r.ReturnNo</td>
                    <td>@r.ReturnDate.ToString("dd MMM yyyy")</td>
                    <td><a asp-action="Bill" asp-route-id="@r.OriginalBillId">@r.OriginalBill?.BillNo</a></td>
                    <td>@r.Store?.Name</td>
                    <td>@(r.Customer?.Name ?? "Walk-in")</td>
                    <td class="text-end fw-medium text-danger">₹@r.TotalRefund.ToString("N2")</td>
                    <td>
                        @if (r.Status == 2)
                        {
                            <span class="badge bg-success text-white">Processed</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Pending</span>
                        }
                    </td>
                    <td>
                        <a class="btn btn-outline-primary btn-sm" asp-action="ReturnDetails" asp-route-id="@r.PosReturnId"><i class="bi bi-eye"></i></a>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="8" class="text-center text-muted py-4">No returns found.</td></tr>
            }
        </tbody>
    </table>
</div>

@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination pagination-sm justify-content-center mb-0">
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == pageNumber ? "active" : "")">
                    <a class="page-link" href="?q=@q&status=@statusFilter&sort=@sort&dir=@dir&page=@i&pageSize=@pageSize">@i</a>
                </li>
            }
        </ul>
    </nav>
}
