@model List<RetailERP.Data.Entities.PosBill>
@{
    ViewData["Title"] = "POS Bills";
    var q = (ViewData["q"] as string) ?? "";
    var statusFilter = ViewData["status"] as byte?;
    var dateFromStr = (ViewData["dateFrom"] as string) ?? "";
    var dateToStr = (ViewData["dateTo"] as string) ?? "";
    var sort = (ViewData["sort"] as string) ?? "date";
    var dir = (ViewData["dir"] as string) ?? "desc";
    var pageNumber = (ViewData["page"] as int?) ?? 1;
    var pageSize = (ViewData["pageSize"] as int?) ?? 20;
    var total = (ViewData["total"] as int?) ?? 0;
    var from = (ViewData["from"] as int?) ?? 0;
    var to = (ViewData["to"] as int?) ?? 0;
    var totalPages = (ViewData["totalPages"] as int?) ?? 1;

    var today = DateTime.Today;
    var thisMonthStart = new DateTime(today.Year, today.Month, 1);
    var thisMonthEnd = thisMonthStart.AddMonths(1).AddDays(-1);
    var lastMonthStart = thisMonthStart.AddMonths(-1);
    var lastMonthEnd = thisMonthStart.AddDays(-1);

    string ToggleDir(string s)
    {
        if (!string.Equals(sort, s, StringComparison.OrdinalIgnoreCase)) return "asc";
        return string.Equals(dir, "asc", StringComparison.OrdinalIgnoreCase) ? "desc" : "asc";
    }

    string Q(string? sortOverride = null, string? dirOverride = null, int? pageOverride = null)
    {
        var s = sortOverride ?? sort;
        var d = dirOverride ?? dir;
        var p = pageOverride ?? pageNumber;
        var st = statusFilter.HasValue ? statusFilter.Value.ToString() : "";
        return $"?q={Uri.EscapeDataString(q)}&status={st}&dateFrom={Uri.EscapeDataString(dateFromStr)}&dateTo={Uri.EscapeDataString(dateToStr)}&sort={Uri.EscapeDataString(s)}&dir={Uri.EscapeDataString(d)}&page={p}&pageSize={pageSize}";
    }

    string StatusBadge(byte s) => s switch
    {
        1 => "<span class='badge bg-warning text-dark px-3 py-2'><i class='bi bi-clock me-1'></i>Open</span>",
        2 => "<span class='badge bg-success text-white px-3 py-2'><i class='bi bi-check-circle me-1'></i>Completed</span>",
        3 => "<span class='badge bg-secondary text-white px-3 py-2'><i class='bi bi-x-circle me-1'></i>Cancelled</span>",
        _ => "<span class='badge bg-light text-dark px-3 py-2'>Unknown</span>"
    };
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h2 class="mb-0"><i class="bi bi-cart3 me-2"></i>POS Bills</h2>
        <div class="text-muted small">Showing @from–@to of @total</div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-outline-primary" asp-action="NewBill"><i class="bi bi-sliders me-1"></i>Choose store…</a>
        <a class="btn btn-primary" asp-action="StartQuick"><i class="bi bi-play-fill me-1"></i>New bill</a>
    </div>
</div>

@if (TempData["Ok"] is string ok) { <div class="alert alert-success py-2">@ok</div> }
@if (TempData["Err"] is string err) { <div class="alert alert-danger py-2">@err</div> }

<form method="get" class="card shadow-sm border-0 mb-3">
    <div class="card-body py-3">
        <div class="row g-2 align-items-end">
            <div class="col-lg-3 col-md-6">
                <label class="form-label small text-muted mb-0">Search</label>
                <input class="form-control" name="q" value="@q" placeholder="Bill # or customer…" />
            </div>
            <div class="col-lg-2 col-md-6">
                <label class="form-label small text-muted mb-0">Status</label>
                <select class="form-select" name="status">
                    @if (statusFilter is null)
                    {
                        <option value="" selected="selected">All statuses</option>
                    }
                    else
                    {
                        <option value="">All statuses</option>
                    }
                    @if (statusFilter == 1)
                    {
                        <option value="1" selected="selected">Open</option>
                    }
                    else
                    {
                        <option value="1">Open</option>
                    }
                    @if (statusFilter == 2)
                    {
                        <option value="2" selected="selected">Completed</option>
                    }
                    else
                    {
                        <option value="2">Completed</option>
                    }
                    @if (statusFilter == 3)
                    {
                        <option value="3" selected="selected">Cancelled</option>
                    }
                    else
                    {
                        <option value="3">Cancelled</option>
                    }
                </select>
            </div>
            <div class="col-lg-2 col-md-6">
                <label class="form-label small text-muted mb-0">From date</label>
                <input class="form-control" type="date" name="dateFrom" value="@dateFromStr" />
            </div>
            <div class="col-lg-2 col-md-6">
                <label class="form-label small text-muted mb-0">To date</label>
                <input class="form-control" type="date" name="dateTo" value="@dateToStr" />
            </div>
            <div class="col-lg-3 col-md-12 d-flex flex-wrap gap-2 align-items-end">
                <button class="btn btn-outline-primary" type="submit"><i class="bi bi-funnel me-1"></i>Apply</button>
                <a class="btn btn-outline-secondary btn-sm" href="?q=@Uri.EscapeDataString(q)&status=@(statusFilter?.ToString() ?? "")&dateFrom=@thisMonthStart.ToString("yyyy-MM-dd")&dateTo=@thisMonthEnd.ToString("yyyy-MM-dd")&sort=@sort&dir=@dir&page=1&pageSize=@pageSize">This month</a>
                <a class="btn btn-outline-secondary btn-sm" href="?q=@Uri.EscapeDataString(q)&status=@(statusFilter?.ToString() ?? "")&dateFrom=@lastMonthStart.ToString("yyyy-MM-dd")&dateTo=@lastMonthEnd.ToString("yyyy-MM-dd")&sort=@sort&dir=@dir&page=1&pageSize=@pageSize">Last month</a>
            </div>
        </div>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th><a href="@Q(sortOverride: "no", dirOverride: ToggleDir("no"), pageOverride: 1)" class="text-decoration-none">Bill #</a></th>
                <th><a href="@Q(sortOverride: "date", dirOverride: ToggleDir("date"), pageOverride: 1)" class="text-decoration-none">Date</a></th>
                <th>Store</th>
                <th>Customer</th>
                <th class="text-end"><a href="@Q(sortOverride: "total", dirOverride: ToggleDir("total"), pageOverride: 1)" class="text-decoration-none">Total</a></th>
                <th><a href="@Q(sortOverride: "status", dirOverride: ToggleDir("status"), pageOverride: 1)" class="text-decoration-none">Status</a></th>
                <th>Cashier</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var b in Model)
            {
                <tr>
                    <td class="fw-medium"><a asp-action="Bill" asp-route-id="@b.PosBillId">@b.BillNo</a></td>
                    <td>@b.BillDate.ToString("dd MMM yyyy")</td>
                    <td>@b.Store?.Name</td>
                    <td>@(b.Customer?.Name ?? "Walk-in")</td>
                    <td class="text-end fw-medium">₹@b.GrandTotal.ToString("N2")</td>
                    <td>@Html.Raw(StatusBadge(b.Status))</td>
                    <td class="small text-muted">@(b.CashierUser?.DisplayName ?? b.CashierUser?.Email)</td>
                    <td>
                        <div class="btn-group btn-group-sm">
                            @if (b.Status == 1)
                            {
                                <a class="btn btn-outline-primary" asp-action="Bill" asp-route-id="@b.PosBillId"><i class="bi bi-pencil"></i></a>
                            }
                            @if (b.Status == 2)
                            {
                                <a class="btn btn-outline-success" asp-action="Receipt" asp-route-id="@b.PosBillId"><i class="bi bi-printer"></i></a>
                                <a class="btn btn-outline-warning" asp-action="NewReturn" asp-route-billId="@b.PosBillId"><i class="bi bi-arrow-return-left"></i></a>
                            }
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="8" class="text-center text-muted py-4">No POS bills match your filters. <a asp-action="StartQuick">Start a new bill</a> or <a asp-action="NewBill">choose store &amp; warehouse</a>.</td></tr>
            }
        </tbody>
    </table>
</div>

@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination pagination-sm justify-content-center mb-0">
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == pageNumber ? "active" : "")">
                    <a class="page-link" href="@Q(pageOverride: i)">@i</a>
                </li>
            }
        </ul>
    </nav>
}
