@model RetailERP.Controllers.ReportsController.SalesReportVm
@{
    ViewData["Title"] = "Sales Report";
}

<div class="container py-4">
    <h3 class="mb-3">Sales Report</h3>

    <form method="get" class="row g-2 align-items-end mb-3">
        <div class="col-sm-3">
            <label class="form-label">From</label>
            <input type="date" name="from" class="form-control" value="@Model.From.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-sm-3">
            <label class="form-label">To</label>
            <input type="date" name="to" class="form-control" value="@Model.To.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-sm-3">
            <button class="btn btn-primary">Run</button>
        </div>
    </form>

    <div class="row g-3 mb-3">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">Posted Invoices</div>
                    <div class="fs-4 fw-semibold">@Model.TotalInvoices</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">Total Sales</div>
                    <div class="fs-4 fw-semibold">@Model.TotalSales.ToString("0.00")</div>
                </div>
            </div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Invoice No</th>
                    <th style="width:200px;">Posted At (UTC)</th>
                    <th style="width:160px;" class="text-end">Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.Rows)
                {
                    <tr>
                        <td>@r.InvoiceNo</td>
                        <td class="text-muted">@r.PostedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="text-end">@r.TotalAmount.ToString("0.00")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>