@model RetailERP.Data.Entities.Supplier
@{
    ViewData["Title"] = "Supplier";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0">@Model.Name</h2>
        <div class="text-muted">Supplier details</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.SupplierId">Edit</a>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Phone</dt>
            <dd class="col-sm-9">@Model.Phone</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Address</dt>
            <dd class="col-sm-9">@Model.Address</dd>

            <dt class="col-sm-3">Active</dt>
            <dd class="col-sm-9">@(Model.IsActive ? "Yes" : "No")</dd>
        </dl>
    </div>
</div>
