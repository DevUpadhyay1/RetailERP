@model ErrorViewModel
@{
    ViewData["Title"] = Model.Title ?? "Request Status";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 p-md-5 text-center">
                    <div class="display-6 fw-bold mb-2">
                        @(Model.StatusCode?.ToString() ?? "Error")
                    </div>
                    <h1 class="h4 mb-2">@(Model.Title ?? "Request could not be completed")</h1>
                    <p class="text-muted mb-4">@(Model.Message ?? "Please try again.")</p>

                    <div class="d-flex flex-wrap justify-content-center gap-2 mb-3">
                        <a class="btn btn-primary" asp-controller="Home" asp-action="Index">Go Home</a>
                        <a class="btn btn-outline-secondary" href="javascript:history.back()">Go Back</a>
                    </div>

                    @if (Model.ShowRequestId)
                    {
                        <div class="small text-muted">
                            Request ID: <code>@Model.RequestId</code>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
