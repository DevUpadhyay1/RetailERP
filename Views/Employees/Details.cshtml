@model RetailERP.Data.Entities.Employee

@{
    ViewData["Title"] = "Employee Details";
}

<div class="d-flex justify-content-between align-items-end mb-3">
    <div>
        <h2 class="mb-0">Employee Details</h2>
        <div class="text-muted">@Model.EmployeeCode • @Model.FirstName @Model.LastName</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.EmployeeId">Edit</a>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Employee Code</dt>
            <dd class="col-sm-9">@Model.EmployeeCode</dd>

            <dt class="col-sm-3">First Name</dt>
            <dd class="col-sm-9">@Model.FirstName</dd>

            <dt class="col-sm-3">Last Name</dt>
            <dd class="col-sm-9">@Model.LastName</dd>

            <dt class="col-sm-3">Join Date</dt>
            <dd class="col-sm-9">@Model.JoinDate.ToString("dd-MMM-yyyy")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>
        </dl>
    </div>
</div>
