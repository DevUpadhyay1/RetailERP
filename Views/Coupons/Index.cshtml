@model List<RetailERP.Data.Entities.Coupon>
@{
    ViewData["Title"] = "Coupons";
    var q = ViewBag.Q as string;
    var sort = (string)ViewBag.Sort;
    var dir = (string)ViewBag.Dir;
    var page = (int)ViewBag.Page;
    var totalPages = (int)ViewBag.TotalPages;
    string Toggle(string col) => sort == col && dir == "asc" ? "desc" : "asc";
    string Arrow(string col) => sort == col ? (dir == "asc" ? "▲" : "▼") : "";
}

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show">@msg <button class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h4 class="mb-0"><i class="bi bi-tag me-2"></i>Coupons</h4>
    <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-lg me-1"></i>New Coupon</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <input name="q" value="@q" class="form-control form-control-sm" placeholder="Search code / description…" style="min-width:250px;" />
    </div>
    <div class="col-auto"><button class="btn btn-sm btn-outline-primary">Search</button></div>
    @if (!string.IsNullOrEmpty(q))
    {
        <div class="col-auto"><a class="btn btn-sm btn-outline-secondary" asp-action="Index">Clear</a></div>
    }
</form>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th><a asp-action="Index" asp-route-q="@q" asp-route-sort="Code" asp-route-dir="@Toggle("Code")">Code @Arrow("Code")</a></th>
                <th>Description</th>
                <th><a asp-action="Index" asp-route-q="@q" asp-route-sort="DiscountType" asp-route-dir="@Toggle("DiscountType")">Type @Arrow("DiscountType")</a></th>
                <th class="text-end">Value</th>
                <th class="text-end">Min Bill</th>
                <th>Valid</th>
                <th class="text-end"><a asp-action="Index" asp-route-q="@q" asp-route-sort="UsedCount" asp-route-dir="@Toggle("UsedCount")">Uses @Arrow("UsedCount")</a></th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                var expired = c.ValidTo < DateTime.Today;
                <tr class="@(expired ? "table-light text-muted" : "")">
                    <td><code class="fw-bold">@c.Code</code></td>
                    <td>@(c.Description?.Length > 40 ? c.Description[..37] + "…" : c.Description)</td>
                    <td><span class="badge bg-info text-dark">@c.DiscountType</span></td>
                    <td class="text-end">@(c.DiscountType == "Percent" ? $"{c.DiscountValue}%" : $"₹{c.DiscountValue:N2}")</td>
                    <td class="text-end">₹@c.MinBillAmount.ToString("N2")</td>
                    <td class="small">@c.ValidFrom.ToString("dd MMM") – @c.ValidTo.ToString("dd MMM yyyy")</td>
                    <td class="text-end">@c.UsedCount / @(c.MaxUses == 0 ? "∞" : c.MaxUses.ToString())</td>
                    <td>
                        @if (!c.IsActive) { <span class="badge bg-secondary">Inactive</span> }
                        else if (expired) { <span class="badge bg-danger">Expired</span> }
                        else { <span class="badge bg-success">Active</span> }
                    </td>
                    <td>
                        <div class="btn-group btn-group-sm">
                            <a class="btn btn-outline-primary" asp-action="Details" asp-route-id="@c.CouponId">View</a>
                            <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@c.CouponId">Edit</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (totalPages > 1)
{
    <nav>
        <ul class="pagination pagination-sm justify-content-center">
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == page ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-q="@q" asp-route-sort="@sort" asp-route-dir="@dir" asp-route-page="@i">@i</a>
                </li>
            }
        </ul>
    </nav>
}
