@model RetailERP.Controllers.AdminUsersController.IndexVm
@{
    ViewData["Title"] = "User Management";
}

<div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-3">
    <div>
        <h2 class="mb-0">User Management</h2>
        <div class="text-muted">Assign roles to users</div>
    </div>

    <form method="get" class="d-flex gap-2">
        <input class="form-control" name="q" value="@Model.Query" placeholder="Search email/username..." />
        <button class="btn btn-outline-primary" type="submit">Search</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Reset</a>
    </form>
</div>

@if (TempData["Ok"] is string ok)
{
    <div class="alert alert-success">@ok</div>
}
@if (TempData["Err"] is string err)
{
    <div class="alert alert-danger">@err</div>
}

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>User</th>
                        <th>Current role(s)</th>
                        <th style="width: 360px;">Set role</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Users.Any())
                    {
                        <tr><td colspan="3" class="p-4 text-muted">No users found.</td></tr>
                    }
                    else
                    {
                        foreach (var u in Model.Users)
                        {
                            <tr>
                                <td class="fw-semibold">@u.Email</td>
                                <td>
                                    @if (!u.Roles.Any())
                                    {
                                        <span class="badge bg-secondary">None</span>
                                    }
                                    else
                                    {
                                        foreach (var r in u.Roles)
                                        {
                                            <span class="badge bg-primary me-1">@r</span>
                                        }
                                    }
                                </td>
                                <td>
                                    <form asp-action="SetRole" method="post" class="d-flex gap-2">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@u.UserId" />
                                        <select class="form-select" name="role">
                                            @foreach (var role in Model.Roles)
                                            {
                                                <option value="@role">@role</option>
                                            }
                                        </select>
                                        <button class="btn btn-primary" type="submit">Update</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>