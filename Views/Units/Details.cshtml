@model RetailERP.Data.Entities.Unit
@{
    ViewData["Title"] = "Unit Details";
    var itemCount = (ViewData["ItemCount"] as int?) ?? 0;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0">@Model.Name</h2>
        <div class="text-muted">@Model.Symbol</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.UnitId">Edit</a>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="text-muted">Name</div>
                <div class="fw-semibold">@Model.Name</div>
            </div>
            <div class="col-md-4">
                <div class="text-muted">Symbol</div>
                <div class="fw-semibold">@Model.Symbol</div>
            </div>
            <div class="col-md-4">
                <div class="text-muted">Status</div>
                <div class="fw-semibold">@(Model.IsActive ? "Active" : "Inactive")</div>
            </div>
            <div class="col-md-4">
                <div class="text-muted">Linked Items</div>
                <div class="fw-semibold">@itemCount</div>
            </div>
        </div>
    </div>
</div>
