@model RetailERP.Data.Entities.Store
@{
    ViewData["Title"] = "Store Details";
    var warehouseCount = (ViewData["WarehouseCount"] as int?) ?? 0;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0">@Model.Name</h2>
        <div class="text-muted">@Model.StoreCode</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.StoreId">Edit</a>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="text-muted">Store Code</div>
                <div class="fw-semibold">@Model.StoreCode</div>
            </div>
            <div class="col-md-4">
                <div class="text-muted">Phone</div>
                <div class="fw-semibold">@(string.IsNullOrWhiteSpace(Model.Phone) ? "-" : Model.Phone)</div>
            </div>
            <div class="col-md-4">
                <div class="text-muted">City</div>
                <div class="fw-semibold">@Model.City</div>
            </div>
            <div class="col-md-4">
                <div class="text-muted">State</div>
                <div class="fw-semibold">@Model.State</div>
            </div>

            <div class="col-12">
                <div class="text-muted">Address</div>
                <div class="fw-semibold">@Model.Address</div>
            </div>

            <div class="col-md-4">
                <div class="text-muted">GST No</div>
                <div class="fw-semibold">@Model.GstNo</div>
            </div>
            <div class="col-md-4">
                <div class="text-muted">PAN No</div>
                <div class="fw-semibold">@Model.PanNo</div>
            </div>
            <div class="col-md-4">
                <div class="text-muted">Status</div>
                <div class="fw-semibold">@(Model.IsActive ? "Active" : "Inactive")</div>
            </div>

            <div class="col-md-4">
                <div class="text-muted">Linked Warehouses</div>
                <div class="fw-semibold">@warehouseCount</div>
            </div>
        </div>
    </div>
</div>
