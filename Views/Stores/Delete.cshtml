@model RetailERP.Data.Entities.Store
@{
    ViewData["Title"] = "Delete Store";
    var warehouseCount = (ViewData["WarehouseCount"] as int?) ?? 0;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0">Delete Store</h2>
        <div class="text-muted">This action cannot be undone</div>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
</div>

<div class="card border-danger">
    <div class="card-body">
        <div class="alert alert-warning mb-3">
            You are about to delete <span class="fw-semibold">@Model.Name</span> (@Model.StoreCode).
        </div>

        @if (warehouseCount > 0)
        {
            <div class="alert alert-danger">
                Cannot delete this store because <span class="fw-semibold">@warehouseCount</span> warehouse(s) are linked.
                Unlink warehouses first.
            </div>
        }

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="StoreId" />

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger" @(warehouseCount > 0 ? "disabled" : "")>Delete</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
