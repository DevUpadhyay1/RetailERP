@model RetailERP.Data.Entities.Promotion
@{
    ViewData["Title"] = "Promotion Details";
    var isExpired = Model.ValidTo < DateTime.Today;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-info-circle me-2"></i>Promotion Details</h4>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.PromotionId" class="btn btn-outline-primary btn-sm"><i class="bi bi-pencil me-1"></i>Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to List</a>
    </div>
</div>

<div class="row">
    <!-- Main Info -->
    <div class="col-md-8">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-light fw-semibold">Basic Information</div>
            <div class="card-body">
                <div class="row mb-2">
                    <div class="col-sm-3 text-muted">Name</div>
                    <div class="col-sm-9 fw-semibold">@Model.Name</div>
                </div>
                <div class="row mb-2">
                    <div class="col-sm-3 text-muted">Type</div>
                    <div class="col-sm-9"><span class="badge bg-info text-dark">@Model.PromoType</span></div>
                </div>
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="row mb-2">
                        <div class="col-sm-3 text-muted">Description</div>
                        <div class="col-sm-9">@Model.Description</div>
                    </div>
                }
                <div class="row mb-2">
                    <div class="col-sm-3 text-muted">Status</div>
                    <div class="col-sm-9">
                        @if (!Model.IsActive) { <span class="badge bg-secondary">Inactive</span> }
                        else if (isExpired) { <span class="badge bg-danger">Expired</span> }
                        else { <span class="badge bg-success">Active</span> }
                    </div>
                </div>
            </div>
        </div>

        <!-- Discount details -->
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-light fw-semibold">Discount Configuration</div>
            <div class="card-body">
                @if (Model.PromoType is "FlatPercent" or "HappyHour")
                {
                    <div class="row mb-2">
                        <div class="col-sm-3 text-muted">Discount %</div>
                        <div class="col-sm-9">@Model.DiscountPercent%</div>
                    </div>
                }
                @if (Model.PromoType == "FlatAmount")
                {
                    <div class="row mb-2">
                        <div class="col-sm-3 text-muted">Discount Amount</div>
                        <div class="col-sm-9">₹@Model.DiscountAmount.ToString("N2")</div>
                    </div>
                }
                @if (Model.PromoType is "BOGO" or "BuyXGetY")
                {
                    <div class="row mb-2">
                        <div class="col-sm-3 text-muted">Buy Qty</div>
                        <div class="col-sm-9">@Model.BuyQty</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-sm-3 text-muted">Get Qty Free</div>
                        <div class="col-sm-9">@Model.GetQty</div>
                    </div>
                    @if (Model.FreeItem is not null)
                    {
                        <div class="row mb-2">
                            <div class="col-sm-3 text-muted">Free Item</div>
                            <div class="col-sm-9">@Model.FreeItem.Name</div>
                        </div>
                    }
                }
                @if (Model.PromoType == "ComboDiscount")
                {
                    <div class="row mb-2">
                        <div class="col-sm-3 text-muted">Combo Items</div>
                        <div class="col-sm-9"><code>@Model.ComboItemIds</code></div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-sm-3 text-muted">Combo Price</div>
                        <div class="col-sm-9">₹@Model.ComboPrice.ToString("N2")</div>
                    </div>
                }
                @if (Model.PromoType == "HappyHour")
                {
                    <div class="row mb-2">
                        <div class="col-sm-3 text-muted">Happy Hour Window</div>
                        <div class="col-sm-9">@Model.HappyHourStart?.ToString(@"hh\:mm") — @Model.HappyHourEnd?.ToString(@"hh\:mm")</div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Side Info -->
    <div class="col-md-4">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-light fw-semibold">Scope</div>
            <div class="card-body">
                <div class="mb-2">
                    <small class="text-muted d-block">Item</small>
                    @(Model.Item?.Name ?? "All Items")
                </div>
                <div class="mb-2">
                    <small class="text-muted d-block">Category</small>
                    @(Model.Category?.Name ?? "All Categories")
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-3">
            <div class="card-header bg-light fw-semibold">Validity</div>
            <div class="card-body">
                <div class="mb-2">
                    <small class="text-muted d-block">From</small>
                    @Model.ValidFrom.ToString("dd-MMM-yyyy")
                </div>
                <div class="mb-2">
                    <small class="text-muted d-block">To</small>
                    @Model.ValidTo.ToString("dd-MMM-yyyy")
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-3">
            <div class="card-header bg-light fw-semibold">Constraints</div>
            <div class="card-body">
                <div class="mb-2">
                    <small class="text-muted d-block">Min Bill Amount</small>
                    ₹@Model.MinBillAmount.ToString("N2")
                </div>
                <div class="mb-2">
                    <small class="text-muted d-block">Max Uses</small>
                    @(Model.MaxUsesTotal == 0 ? "Unlimited" : Model.MaxUsesTotal.ToString())
                </div>
                <div class="mb-2">
                    <small class="text-muted d-block">Used</small>
                    @Model.UsedCount times
                </div>
                <div class="mb-2">
                    <small class="text-muted d-block">Priority</small>
                    @Model.Priority
                </div>
                <div class="mb-2">
                    <small class="text-muted d-block">Exclusive</small>
                    @(Model.IsExclusive ? "Yes" : "No")
                </div>
            </div>
        </div>
    </div>
</div>
