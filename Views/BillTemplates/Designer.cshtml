@model RetailERP.Data.Entities.BillTemplate
@{
    ViewData["Title"] = $"Designer — {Model.TemplateName}";
    Layout = "_Layout";
    var company = ViewBag.Company as RetailERP.Data.Entities.Company;
}

<!-- Top bar -->
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h4 class="mb-0"><i class="bi bi-brush me-2"></i>@Model.TemplateName</h4>
        <small class="text-muted">@(Model.TemplateType == 1 ? "POS Receipt" : "Invoice") &bull; @Model.PaperSize</small>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <select id="presetSelect" class="form-select form-select-sm" style="width:auto;">
            <option value="modern">Modern Preset</option>
            <option value="classic">Classic Stylish Preset</option>
        </select>
        <button id="btnApplyPreset" class="btn btn-outline-primary btn-sm"><i class="bi bi-stars me-1"></i>Apply Preset</button>
        <button id="btnSave" class="btn btn-primary btn-sm"><i class="bi bi-save me-1"></i>Save</button>
        <a asp-action="@(Model.TemplateType == 2 ? "PreviewInvoice" : "PreviewReceipt")" asp-route-id="@Model.BillTemplateId" class="btn btn-outline-info btn-sm" target="_blank"><i class="bi bi-file-pdf me-1"></i>Preview PDF</a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back</a>
    </div>
</div>
@if (TempData["Ok"] is string ok){<div class="alert alert-success alert-dismissible fade show py-2">@ok<button class="btn-close" data-bs-dismiss="alert"></button></div>}
@if (TempData["Err"] is string err){<div class="alert alert-danger alert-dismissible fade show py-2">@err<button class="btn-close" data-bs-dismiss="alert"></button></div>}

<div class="row g-3" style="min-height:82vh;">
    <!-- ═══ LEFT: Toolbox + Logo ═══ -->
    <div class="col-12 col-lg-2 order-2 order-lg-1">
        <div class="card shadow-sm mb-3">
            <div class="card-header py-2 fw-semibold bg-primary text-white"><i class="bi bi-plus-circle me-1"></i>Add Component</div>
            <div class="card-body p-2" id="toolbox">
                <div class="tb-section">Receipt Blocks</div>
                <div class="tb-item" data-type="logo"><i class="bi bi-image"></i> Logo</div>
                <div class="tb-item" data-type="store_header"><i class="bi bi-shop"></i> Store Header</div>
                <div class="tb-item" data-type="bill_info"><i class="bi bi-info-circle"></i> Bill Info</div>
                <div class="tb-item" data-type="items_table"><i class="bi bi-table"></i> Items Table</div>
                <div class="tb-item" data-type="totals"><i class="bi bi-calculator"></i> Totals</div>
                <div class="tb-item" data-type="payments"><i class="bi bi-credit-card"></i> Payments</div>
                <div class="tb-item" data-type="tax_summary"><i class="bi bi-receipt"></i> Tax Summary</div>
                <div class="tb-item" data-type="footer"><i class="bi bi-chat-text"></i> Footer</div>
                <div class="tb-section mt-2">Custom Elements</div>
                <div class="tb-item" data-type="header_row"><i class="bi bi-layout-three-columns"></i> Header Row (L/C/R)</div>
                <div class="tb-item" data-type="social_row"><i class="bi bi-share"></i> Social / Contact Row</div>
                <div class="tb-item" data-type="text_block"><i class="bi bi-fonts"></i> Text Block</div>
                <div class="tb-item" data-type="separator"><i class="bi bi-dash-lg"></i> Separator</div>
                <div class="tb-item" data-type="spacer"><i class="bi bi-arrows-expand"></i> Spacer</div>
            </div>
        </div>
        <div class="card shadow-sm">
            <div class="card-header py-2 fw-semibold"><i class="bi bi-image me-1"></i>Company Logo</div>
            <div class="card-body p-2">
                @if (!string.IsNullOrEmpty(company?.LogoPath)){
                    <img id="logoImg" src="~/@company.LogoPath" class="img-fluid border rounded d-block mx-auto mb-2" style="max-height:50px;" />
                } else {
                    <div id="logoImg" class="text-muted small text-center mb-2">No logo uploaded</div>
                }
                <input type="file" id="logoFile" accept=".png,.jpg,.jpeg,.webp" class="form-control form-control-sm mb-1" />
                <button id="btnUploadLogo" class="btn btn-sm btn-outline-primary w-100"><i class="bi bi-upload me-1"></i>Upload</button>
            </div>
        </div>
        <div class="card shadow-sm mt-3">
            <div class="card-header py-2 fw-semibold"><i class="bi bi-pen me-1"></i>Signature / Stamp</div>
            <div class="card-body p-2">
                <label class="form-label small mb-1">Signature</label>
                @if (!string.IsNullOrEmpty(company?.SignaturePath))
                {
                    <img src="~/@company.SignaturePath" class="img-fluid border rounded d-block mx-auto mb-2" style="max-height:55px;" />
                }
                <input type="file" id="signatureFile" accept=".png,.jpg,.jpeg,.webp" class="form-control form-control-sm mb-1" />
                <button id="btnUploadSignature" class="btn btn-sm btn-outline-primary w-100 mb-2"><i class="bi bi-upload me-1"></i>Upload Signature</button>

                <label class="form-label small mb-1">Stamp</label>
                @if (!string.IsNullOrEmpty(company?.StampPath))
                {
                    <img src="~/@company.StampPath" class="img-fluid border rounded d-block mx-auto mb-2" style="max-height:55px;" />
                }
                <input type="file" id="stampFile" accept=".png,.jpg,.jpeg,.webp" class="form-control form-control-sm mb-1" />
                <button id="btnUploadStamp" class="btn btn-sm btn-outline-primary w-100"><i class="bi bi-upload me-1"></i>Upload Stamp</button>
            </div>
        </div>
    </div>

    <!-- ═══ CENTER: WYSIWYG Canvas ═══ -->
    <div class="col-12 col-lg-6 order-1 order-lg-2">
        <div class="card shadow-sm h-100">
            <div class="card-header py-2 d-flex justify-content-between align-items-center">
                <span class="fw-semibold"><i class="bi bi-easel me-1"></i>Receipt Preview <small class="text-muted">(click to select, drag to reorder)</small></span>
                <select id="paperSize" class="form-select form-select-sm" style="width:auto;font-size:12px;">
                    @{ var sizes = new[]{("Thermal58mm","58mm"),("Thermal80mm","80mm"),("A4","A4"),("A5","A5")};
                       foreach(var(val,lbl)in sizes){
                           if(Model.PaperSize==val){<text><option value="@val" selected="selected">@lbl</option></text>}
                           else{<text><option value="@val">@lbl</option></text>}
                       }
                    }
                </select>
            </div>
            <div class="card-body p-0 d-flex justify-content-center" style="background:#d0d0d0;overflow-y:auto;">
                <div id="canvasWrap">
                    <div id="canvas"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- ═══ RIGHT: Properties ═══ -->
    <div class="col-12 col-lg-4 order-3">
        <div class="card shadow-sm" id="propCard">
            <div class="card-header py-2 fw-semibold bg-dark text-white"><i class="bi bi-sliders me-1"></i>Properties</div>
            <div class="card-body" id="propPanel">
                <div class="text-center text-muted py-4">
                    <i class="bi bi-cursor-fill d-block" style="font-size:28px;opacity:.3"></i>
                    <span class="small">Click any block on the receipt to edit its properties</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
<style>
/* ─── Toolbox ─── */
.tb-section{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;padding:4px 6px 2px}
.tb-item{cursor:grab;padding:5px 8px;margin-bottom:3px;background:var(--bs-body-bg,#fff);border:1px solid var(--bs-border-color,#dee2e6);border-radius:5px;font-size:12px;font-weight:500;transition:all .12s;display:flex;align-items:center;gap:5px;color:var(--bs-body-color,#212529)}
.tb-item:hover{border-color:#0d6efd;background:#e7f1ff;color:#212529;transform:translateX(2px)}
.tb-item.sortable-chosen{opacity:.5}
.tb-item i{font-size:13px;color:#6c757d;width:16px;text-align:center}

/* ─── Canvas: ALWAYS light mode (receipt = white paper) ─── */
#canvasWrap{background:#fff!important;color:#000!important;color-scheme:light;box-shadow:0 2px 12px rgba(0,0,0,.15);margin:16px 0;transition:width .2s}
#canvas{min-height:200px;padding:0;font-family:'Consolas','Courier New',monospace;font-size:11px;color:#000!important;background:#fff!important}
#canvas *{color:inherit}

/* ─── Canvas Items (WYSIWYG) ─── */
.cv-block{position:relative;border:2px solid transparent;transition:border-color .12s,box-shadow .12s;cursor:pointer;padding:0;color:#000}
.cv-block:hover{border-color:#adb5bd50}
.cv-block.cv-sel{border-color:#0d6efd;box-shadow:0 0 0 2px rgba(13,110,253,.2)}
.cv-block .cv-overlay{position:absolute;top:0;left:0;right:0;bottom:0;display:none;align-items:flex-start;justify-content:space-between;padding:2px 4px;z-index:2}
.cv-block:hover .cv-overlay,.cv-block.cv-sel .cv-overlay{display:flex}
.cv-overlay .cv-tag{background:#0d6efd;color:#fff;font-size:9px;padding:1px 5px;border-radius:0 0 4px 0;font-family:system-ui;cursor:grab;font-weight:600;letter-spacing:.3px;line-height:1.4}
.cv-overlay .cv-del{background:#dc3545;color:#fff;width:18px;height:18px;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:10px;border:none;padding:0;line-height:1}
.cv-overlay .cv-del:hover{background:#a71d2a}
.cv-block.sortable-ghost{opacity:.2;border:2px dashed #0d6efd}

/* ─── Inner content padding ─── */
.cv-inner{padding:6px 14px;color:#000}
.cv-inner hr{border-style:dashed;border-color:#ccc;margin:3px 0}
.cv-inner .r{display:flex;justify-content:space-between;gap:4px}
.cv-inner .b{font-weight:bold}
.cv-inner .c{text-align:center}
.cv-inner .l{text-align:left}
.cv-inner .rr{text-align:right}
.cv-inner .sm{font-size:9px}
.cv-inner .md{font-size:10px}
.cv-inner .hc{display:flex;align-items:center;gap:8px}
.cv-inner .hc .cell{flex:1;min-width:0}

/* ─── Properties panel (dark-mode safe) ─── */
#propPanel .pg{margin-bottom:10px}
#propPanel .pl{font-size:11px;font-weight:600;color:var(--bs-body-color,#495057);margin-bottom:3px}
.field-badge{display:inline-block;background:var(--bs-tertiary-bg,#e9ecef);border:1px solid var(--bs-border-color,#ced4da);border-radius:3px;padding:0 5px;font-size:10px;color:var(--bs-body-color,#495057);font-weight:600;cursor:pointer;margin:1px}
.field-badge:hover{background:var(--bs-secondary-bg,#d3d8de)}
#propPanel .btn-del-comp{margin-top:12px}
</style>
}

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.6/Sortable.min.js"></script>
<script>
(function(){
'use strict';
const TID='@Model.BillTemplateId';
const XSRF=document.querySelector('input[name="__RequestVerificationToken"]')?.value
    || (document.cookie.split(';').map(c=>c.trim()).find(c=>c.startsWith('XSRF-TOKEN='))?.split('=')[1])||'';
const CO={
    name:'@Html.Raw((company?.Name??"RetailERP").Replace("'","\\'"))',
    addr:'@Html.Raw((company?.Address??"").Replace("'","\\'"))',
    phone:'@Html.Raw((company?.Phone??"").Replace("'","\\'"))',
    gst:'@Html.Raw((company?.GstNo??"").Replace("'","\\'"))',
    logo:'@(company?.LogoPath??"")'
};

const DEFS={
    logo:{l:'Logo',s:true},store_header:{l:'Store',s:true},bill_info:{l:'Bill Info',s:true},
    items_table:{l:'Items',s:true},totals:{l:'Totals',s:true},payments:{l:'Payments',s:true},
    tax_summary:{l:'Tax',s:true},footer:{l:'Footer',s:true},
    header_row:{l:'Header Row',s:false},social_row:{l:'Social Row',s:false},
    text_block:{l:'Text',s:false},separator:{l:'Line',s:false},spacer:{l:'Space',s:false}
};

const PRESETS={
    modern:[
        {type:'logo',props:{maxHeight:50,align:'center'}},
        {type:'header_row',props:{leftText:'',centerMode:'logo',centerText:'',rightText:'',fontSize:9,logoHeight:28,showSeparator:false,marginTop:0,marginBottom:2}},
        {type:'store_header',props:{showAddress:true,showPhone:true,showGst:true,showTitle:true,showSeparator:true,headerText:''}},
        {type:'social_row',props:{instagram:'',whatsapp:'',facebook:'',xhandle:'',youtube:'',phone:'',email:'',website:'',align:'center',separator:' | ',fontSize:9,marginTop:0,marginBottom:2}},
        {type:'bill_info',props:{showInvoiceNo:true,showInvoiceDate:true,showDocumentType:true,showDueDate:true,showReferenceInvoice:true,showCustomerName:true,showCustomerPhone:true,showCustomerEmail:false,showWarehouse:true,showCashier:false,showSeparator:true}},
        {type:'items_table',props:{showSerial:true,showItem:true,showSku:false,showHsn:false,showQty:true,showRate:true,showDiscountColumn:false,showTaxPercent:true,showTaxAmount:false,showAmount:true,labelSerial:'#',labelItem:'Item',labelSku:'SKU',labelHsn:'HSN',labelQty:'Qty',labelRate:'Rate',labelDiscount:'Disc',labelTaxPercent:'Tax%',labelTaxAmount:'Tax Amt',labelAmount:'Amt',widthSerial:20,widthItem:4,widthSku:36,widthHsn:40,widthQty:30,widthRate:55,widthDiscount:48,widthTaxPercent:45,widthTaxAmount:52,widthAmount:65,showHeaderBackground:true,headerBgColor:'#f2f2f2',headerTextColor:'#111111',showGrid:false,gridColor:'#d9d9d9',zebraRows:false,zebraColor:'#fafafa',showDescriptionRow:true,showBottomSeparator:true}},
        {type:'totals',props:{showDiscount:true}},
        {type:'payments',props:{}},
        {type:'tax_summary',props:{}},
        {type:'footer',props:{text:'Thank you for shopping!',showItemCount:true,showTotalInWords:true,showComputerGenerated:true}}
    ],
    classic:[
        {type:'logo',props:{maxHeight:52,align:'center'}},
        {type:'header_row',props:{leftText:'',centerMode:'logo',centerText:'',rightText:'',fontSize:9,logoHeight:30,showSeparator:true,marginTop:0,marginBottom:2}},
        {type:'store_header',props:{showAddress:true,showPhone:true,showGst:true,showTitle:true,showSeparator:true,headerText:'RETAIL INVOICE'}},
        {type:'social_row',props:{instagram:'',whatsapp:'',facebook:'',xhandle:'',youtube:'',phone:'',email:'',website:'',align:'center',separator:' | ',fontSize:9,marginTop:0,marginBottom:2}},
        {type:'bill_info',props:{showInvoiceNo:true,showInvoiceDate:true,showDocumentType:true,showDueDate:true,showReferenceInvoice:true,showCustomerName:true,showCustomerPhone:true,showCustomerEmail:false,showWarehouse:true,showCashier:false,showSeparator:true}},
        {type:'separator',props:{style:'solid',thickness:1,color:'#555555'}},
        {type:'items_table',props:{showSerial:true,showItem:true,showSku:false,showHsn:true,showQty:true,showRate:true,showDiscountColumn:false,showTaxPercent:true,showTaxAmount:false,showAmount:true,labelSerial:'#',labelItem:'Item',labelSku:'SKU',labelHsn:'HSN',labelQty:'Qty',labelRate:'Rate',labelDiscount:'Disc',labelTaxPercent:'Tax%',labelTaxAmount:'Tax Amt',labelAmount:'Amt',widthSerial:20,widthItem:4,widthSku:36,widthHsn:40,widthQty:30,widthRate:55,widthDiscount:48,widthTaxPercent:45,widthTaxAmount:52,widthAmount:65,showHeaderBackground:true,headerBgColor:'#f2f2f2',headerTextColor:'#111111',showGrid:true,gridColor:'#d9d9d9',zebraRows:true,zebraColor:'#fafafa',showDescriptionRow:true,showBottomSeparator:true}},
        {type:'separator',props:{style:'solid',thickness:1,color:'#555555'}},
        {type:'totals',props:{showDiscount:true}},
        {type:'payments',props:{}},
        {type:'text_block',props:{text:'Net Amount: {{grand_total}}',fontSize:12,fontFamily:'serif',align:'right',bold:true,italic:false,color:'#111111'}},
        {type:'text_block',props:{text:'In Words: {{grand_total_words}}',fontSize:10,fontFamily:'serif',align:'left',bold:false,italic:false,color:'#333333'}},
        {type:'separator',props:{style:'dashed',thickness:1,color:'#999999'}},
        {type:'text_block',props:{text:'Terms & Conditions:\n1. Goods once sold will not be taken back.\n2. Keep this invoice for exchange/warranty as per policy.',fontSize:9,fontFamily:'sans-serif',align:'left',bold:false,italic:false,color:'#333333'}},
        {type:'spacer',props:{height:8}},
        {type:'text_block',props:{text:'Receiver Signature                                Authorised Signatory',fontSize:9,fontFamily:'sans-serif',align:'left',bold:false,italic:false,color:'#444444'}},
        {type:'footer',props:{text:'Thank you for your business!',showItemCount:true,showTotalInWords:true,showComputerGenerated:true}}
    ]
};

let comps=[], sel=null, uid=0;
const gid=()=>'c'+(++uid);

function dp(t){
    const styleBase={
        visibleWhen:'always',
        padding:0,
        backgroundColor:'#ffffff',
        borderWidth:0,
        borderColor:'#cccccc',
        borderStyle:'solid',
        marginTop:0,
        marginBottom:2
    };

    const m={
        logo:{maxHeight:50,align:'center'},
        store_header:{showAddress:true,showPhone:true,showGst:true,showTitle:true,showSeparator:true,headerText:''},
        bill_info:{showInvoiceNo:true,showInvoiceDate:true,showDocumentType:true,showDueDate:true,showReferenceInvoice:true,showCustomerName:true,showCustomerPhone:true,showCustomerEmail:false,showWarehouse:true,showCashier:false,showSeparator:true},
        items_table:{showSerial:true,showItem:true,showSku:false,showHsn:false,showQty:true,showRate:true,showDiscountColumn:false,showTaxPercent:true,showTaxAmount:false,showAmount:true,labelSerial:'#',labelItem:'Item',labelSku:'SKU',labelHsn:'HSN',labelQty:'Qty',labelRate:'Rate',labelDiscount:'Disc',labelTaxPercent:'Tax%',labelTaxAmount:'Tax Amt',labelAmount:'Amt',widthSerial:20,widthItem:4,widthSku:36,widthHsn:40,widthQty:30,widthRate:55,widthDiscount:48,widthTaxPercent:45,widthTaxAmount:52,widthAmount:65,showHeaderBackground:true,headerBgColor:'#f2f2f2',headerTextColor:'#111111',showGrid:false,gridColor:'#d9d9d9',zebraRows:false,zebraColor:'#fafafa',showDescriptionRow:true,showBottomSeparator:true},
        totals:{showDiscount:true},
        payments:{},
        tax_summary:{},
        footer:{text:'Thank you for shopping!',showItemCount:true,showTotalInWords:true,showComputerGenerated:true},
        header_row:{leftText:'',centerMode:'logo',centerText:'',rightText:'',fontSize:9,logoHeight:28,showSeparator:false},
        social_row:{instagram:'',whatsapp:'',facebook:'',xhandle:'',youtube:'',phone:'',email:'',website:'',align:'center',separator:' | ',fontSize:9},
        text_block:{text:'Your text here',fontSize:12,fontFamily:'sans-serif',align:'center',bold:false,italic:false,color:'#000000'},
        separator:{style:'dashed',thickness:1,color:'#999999'},
        spacer:{height:12,marginBottom:0}
    };
    return JSON.parse(JSON.stringify(Object.assign({}, styleBase, m[t]||{})));
}

// Load saved
try{
    const raw=@Html.Raw(Model.LayoutJson);
    if(Array.isArray(raw)&&raw.length)raw.forEach(c=>{
        const t=c.type||c.id||'text_block';
        comps.push({uid:gid(),type:t,props:Object.assign(dp(t),c.props||{})});
    });
}catch(e){console.warn('parse',e)}
if(!comps.length)['logo','header_row','store_header','social_row','bill_info','items_table','totals','payments','tax_summary','footer'].forEach(t=>comps.push({uid:gid(),type:t,props:dp(t)}));

const $c=document.getElementById('canvas'), $p=document.getElementById('propPanel');

// ── Toolbox sortable ──
new Sortable(document.getElementById('toolbox'),{
    group:{name:'bill',pull:'clone',put:false},sort:false,animation:120,
    filter:'.tb-section',
    onEnd:function(){}
});

// ── Canvas sortable ──
new Sortable($c,{
    group:{name:'bill',put:true},animation:120,handle:'.cv-tag',ghostClass:'sortable-ghost',
    onAdd(evt){
        const el=evt.item,t=el.dataset.type;
        if(!t){el.remove();return;}
        if(DEFS[t]&&DEFS[t].s&&comps.some(c=>c.type===t)){el.remove();toast(DEFS[t].l+' already added','warning');return;}
        const u=gid();
        comps.splice(evt.newIndex,0,{uid:u,type:t,props:dp(t)});
        el.remove();render();pick(u);
    },
    onSort(evt){
        if(evt.from!==evt.to)return;
        const uids=[...document.querySelectorAll('#canvas .cv-block')].map(e=>e.dataset.uid).filter(Boolean);
        const re=[];uids.forEach(u=>{const c=comps.find(x=>x.uid===u);if(c)re.push(c)});
        comps=re;
    }
});

// ═══ RENDER ═══
function render(){
    $c.innerHTML='';
    comps.forEach(comp=>{
        const d=DEFS[comp.type]||{l:comp.type};
        const blk=document.createElement('div');
        blk.className='cv-block'+(comp.uid===sel?' cv-sel':'');
        blk.dataset.uid=comp.uid;

        // Overlay (drag handle + delete)
        const ov=document.createElement('div');
        ov.className='cv-overlay';
        ov.innerHTML=`<span class="cv-tag">${esc(d.l)}</span><button class="cv-del" title="Remove">&times;</button>`;
        blk.appendChild(ov);

        // WYSIWYG inner content
        const inner=document.createElement('div');
        inner.className='cv-inner';
        const mt = parseInt(comp.props?.marginTop ?? 0, 10) || 0;
        const mb = parseInt(comp.props?.marginBottom ?? 0, 10) || 0;
        inner.style.marginTop = mt + 'px';
        inner.style.marginBottom = mb + 'px';
        inner.innerHTML=renderWysiwyg(comp);
        blk.appendChild(inner);

        blk.addEventListener('click',e=>{if(!e.target.classList.contains('cv-del'))pick(comp.uid)});
        ov.querySelector('.cv-del').addEventListener('click',e=>{
            e.stopPropagation();
            comps=comps.filter(c=>c.uid!==comp.uid);
            if(sel===comp.uid){sel=null;renderProps()}
            render();
        });
        $c.appendChild(blk);
    });
}

function renderWysiwyg(comp){
    const p=comp.props;
    switch(comp.type){
        case 'logo':
            if(CO.logo) return applySpacing(`<div style="text-align:${p.align||'center'}"><img src="/${CO.logo}?v=1" style="max-height:${p.maxHeight||50}px;max-width:90%"/></div>`, p);
            return applySpacing(`<div class="c" style="color:#bbb;padding:8px">[Company Logo]</div>`, p);
        case 'header_row':{
            const logoH = p.logoHeight || 28;
            const center = (p.centerMode||'logo') === 'text'
                ? `<div class="c" style="font-size:${p.fontSize||9}px">${esc(p.centerText||'')}</div>`
                : (CO.logo
                    ? `<div class="c"><img src="/${CO.logo}?v=1" style="max-height:${logoH}px;max-width:95%"/></div>`
                    : `<div class="c sm text-muted">[Logo]</div>`);
            let h = `<div class="hc">`
                + `<div class="cell l" style="font-size:${p.fontSize||9}px;white-space:pre-wrap">${esc(p.leftText||'')}</div>`
                + `<div class="cell">${center}</div>`
                + `<div class="cell rr" style="font-size:${p.fontSize||9}px;white-space:pre-wrap">${esc(p.rightText||'')}</div>`
                + `</div>`;
            if (p.showSeparator) h += `<hr/>`;
            return applySpacing(h, p);
        }
        case 'social_row':{
            const parts = renderSocialTokens(p);
            if (!parts.length) return applySpacing(`<div class="c sm text-muted">[Add Instagram / WhatsApp / Phone / Email in properties]</div>`, p);
            const ta = p.align || 'center';
            return applySpacing(`<div style="font-size:${p.fontSize||9}px;text-align:${ta};word-break:break-word">${esc(parts.join(p.separator || ' | '))}</div>`, p);
        }
        case 'store_header':{
            let h=`<div class="c b" style="font-size:13px">${esc(CO.name)}</div>`;
            if((p.showAddress ?? true) && CO.addr)h+=`<div class="c sm">${esc(CO.addr)}</div>`;
            if((p.showPhone ?? true) && CO.phone)h+=`<div class="c sm">Ph: ${esc(CO.phone)}</div>`;
            if((p.showGst ?? true)&&CO.gst)h+=`<div class="c sm">GSTIN: ${esc(CO.gst)}</div>`;
            if(p.showTitle !== false){
                h+=`<div class="c sm b">${esc(p.headerText || 'TAX INVOICE')}</div>`;
            }
            if(p.showSeparator !== false) h+='<hr/>';
            return applySpacing(h, p);
        }
        case 'bill_info':{
            let h='';
            if((p.showInvoiceNo ?? true) || (p.showInvoiceDate ?? true)){
                h+=`<div class="r md">`
                    + `<span>${(p.showInvoiceNo ?? true) ? 'Invoice#: <b>TAX-2026-0001</b>' : ''}</span>`
                    + `<span>${(p.showInvoiceDate ?? true) ? '08/03/2026' : ''}</span>`
                    + `</div>`;
            }
            if(p.showDocumentType ?? true) h+=`<div class="md">Document: TAX INVOICE</div>`;
            if(p.showDueDate ?? true) h+=`<div class="md">Due Date: 07/04/2026</div>`;
            if(p.showReferenceInvoice ?? true) h+=`<div class="md">Ref Invoice: TAX-2026-0000</div>`;
            if(p.showCustomerName ?? true) h+=`<div class="md">Customer: Walk-in</div>`;
            if(p.showCustomerPhone ?? true) h+=`<div class="md">Phone: 9000000000</div>`;
            if(p.showCustomerEmail) h+=`<div class="md">Email: customer@example.com</div>`;
            if(p.showWarehouse ?? true) h+=`<div class="md">Warehouse: Main Warehouse</div>`;
            if(p.showCashier) h+=`<div class="md">Cashier: Admin</div>`;
            if(p.showSeparator !== false) h+='<hr/>';
            return applySpacing(h, p);
        }
        case 'items_table':{
            const cols=[];
            if(p.showSerial !== false) cols.push({k:'serial',label:p.labelSerial||'#',align:'right'});
            cols.push({k:'item',label:p.labelItem||'Item',align:'left'});
            if(p.showSku) cols.push({k:'sku',label:p.labelSku||'SKU',align:'left'});
            if(p.showHsn) cols.push({k:'hsn',label:p.labelHsn||'HSN',align:'left'});
            if(p.showQty !== false) cols.push({k:'qty',label:p.labelQty||'Qty',align:'right'});
            if(p.showRate !== false) cols.push({k:'rate',label:p.labelRate||'Rate',align:'right'});
            if(p.showDiscountColumn) cols.push({k:'discount',label:p.labelDiscount||'Disc',align:'right'});
            if(p.showTaxPercent !== false) cols.push({k:'taxPercent',label:p.labelTaxPercent||'Tax%',align:'right'});
            if(p.showTaxAmount) cols.push({k:'taxAmount',label:p.labelTaxAmount||'Tax Amt',align:'right'});
            if(p.showAmount !== false) cols.push({k:'amount',label:p.labelAmount||'Amt',align:'right'});

            const rows=[
                {item:'Paracetamol 500mg',sku:'PCM-500',hsn:'30049099',qty:'2',rate:'₹25.00',discount:'₹0.00',taxPercent:'5%',taxAmount:'₹2.50',amount:'₹52.50'},
                {item:'Vitamin Syrup',sku:'VIT-SYR',hsn:'30041000',qty:'1',rate:'₹180.00',discount:'₹0.00',taxPercent:'12%',taxAmount:'₹21.60',amount:'₹201.60'}
            ];

            const showGrid = !!p.showGrid;
            const showHeaderBackground = p.showHeaderBackground !== false;
            const headerBgColor = p.headerBgColor || '#f2f2f2';
            const headerTextColor = p.headerTextColor || '#111111';
            const gridColor = p.gridColor || '#d9d9d9';
            const zebraRows = !!p.zebraRows;
            const zebraColor = p.zebraColor || '#fafafa';

            const cellStyle = (align, extra='') =>
                `padding:2px 4px;text-align:${align};${showGrid ? `border:1px solid ${gridColor};` : ''}${extra}`;

            let h='<table style="width:100%;border-collapse:collapse;font-size:10px">';
            h+='<thead><tr>';
            cols.forEach(c=>{
                const headBg = showHeaderBackground ? `background:${headerBgColor};` : '';
                h+=`<th style="${cellStyle(c.align, `${headBg}color:${headerTextColor};font-weight:700;`)}">${esc(c.label)}</th>`;
            });
            h+='</tr></thead><tbody>';

            rows.forEach((r,idx)=>{
                const rowBg = zebraRows && idx % 2 === 1 ? zebraColor : 'transparent';
                h+='<tr>';
                cols.forEach(c=>{
                    let val='';
                    switch(c.k){
                        case 'serial': val=String(idx+1); break;
                        case 'item': val=r.item; break;
                        case 'sku': val=r.sku; break;
                        case 'hsn': val=r.hsn; break;
                        case 'qty': val=r.qty; break;
                        case 'rate': val=r.rate; break;
                        case 'discount': val=r.discount; break;
                        case 'taxPercent': val=r.taxPercent; break;
                        case 'taxAmount': val=r.taxAmount; break;
                        case 'amount': val=r.amount; break;
                    }
                    h+=`<td style="${cellStyle(c.align, `background:${rowBg};`)}">${esc(val)}</td>`;
                });
                h+='</tr>';

                if((p.showDescriptionRow ?? true) && !p.showSku){
                    h+='<tr>';
                    cols.forEach(c=>{
                        const val = c.k === 'item' ? r.sku : '';
                        const color = c.k === 'item' ? 'color:#666;' : '';
                        h+=`<td style="${cellStyle(c.align, `background:${rowBg};${color}`)}">${esc(val)}</td>`;
                    });
                    h+='</tr>';
                }
            });

            h+='</tbody></table>';
            if(p.showBottomSeparator !== false) h+='<hr/>';
            return applySpacing(h, p);
        }
        case 'totals':{
            let h=`<div class="r md"><span>Sub Total</span><span>₹350.00</span></div>`;
            if(p.showDiscount)h+=`<div class="r md"><span>Discount</span><span>- ₹0.00</span></div>`;
            h+=`<div class="r md"><span>Tax (GST)</span><span>+ ₹21.00</span></div><hr/>`;
            h+=`<div class="r b" style="font-size:13px"><span>GRAND TOTAL</span><span>₹371.00</span></div><hr/>`;
            return applySpacing(h, p);
        }
        case 'payments':
            return `<div class="b md">Payments:</div><div class="r md"><span>Cash</span><span>₹400.00</span></div><div class="r b md"><span>Change</span><span>₹29.00</span></div><hr/>`;
        case 'tax_summary':
            return `<div class="b md">Tax Summary:</div><div class="r md"><span>GST 6%</span><span>₹21.00</span></div><hr/>`;
        case 'footer':{
            let h='';
            if(p.showItemCount)h+=`<div class="c sm">Items: 4 &bull; 08/03/2026 14:30</div>`;
            h+=`<div class="c sm">${esc(p.text||'Thank you!')}</div>`;
            if(p.showTotalInWords !== false) h+=`<div class="c sm">Total in words: Three Hundred Seventy One Rupees Only</div>`;
            if(p.showComputerGenerated !== false) h+=`<div class="c" style="font-size:8px">&mdash; RetailERP POS &mdash;</div>`;
            return applySpacing(h, p);
        }
        case 'text_block':{
            const ff=p.fontFamily||'sans-serif',fs=p.fontSize||12,fw=p.bold?'bold':'normal',fi=p.italic?'italic':'normal',cl=p.color||'#000',ta=p.align||'center';
            let txt=(p.text||'').replace(/\{\{company_name\}\}/g,CO.name).replace(/\{\{bill_no\}\}/g,'POS-0001').replace(/\{\{date\}\}/g,'08/03/2026').replace(/\{\{grand_total\}\}/g,'₹371.00').replace(/\{\{customer_name\}\}/g,'Walk-in');
            return applySpacing(`<div style="font-family:${ff};font-size:${fs}px;font-weight:${fw};font-style:${fi};color:${cl};text-align:${ta};white-space:pre-wrap">${esc(txt)}</div>`, p);
        }
        case 'separator':
            return applySpacing(`<hr style="border-style:${p.style||'dashed'};border-width:${p.thickness||1}px;border-color:${p.color||'#999'};margin:3px 0"/>`, p);
        case 'spacer':
            return applySpacing(`<div style="height:${p.height||12}px"></div>`, p);
        default:return '';
    }
}

function applySpacing(inner, props){
    const padding = parseInt(props?.padding ?? 0, 10) || 0;
    const borderWidth = parseInt(props?.borderWidth ?? 0, 10) || 0;
    const borderColor = props?.borderColor || '#cccccc';
    const borderStyle = props?.borderStyle || 'solid';
    const borderRadius = parseInt(props?.borderRadius ?? 0, 10) || 0;
    const backgroundColor = props?.backgroundColor || '';

    const styles = [];
    if (padding > 0) styles.push(`padding:${padding}px`);
    if (borderWidth > 0) styles.push(`border:${borderWidth}px ${borderStyle} ${borderColor}`);
    if (borderRadius > 0) styles.push(`border-radius:${borderRadius}px`);
    if (backgroundColor && backgroundColor.toLowerCase() !== '#ffffff') styles.push(`background:${backgroundColor}`);

    if (!styles.length) return inner;
    return `<div style="${styles.join(';')}">${inner}</div>`;
}

function renderSocialTokens(p){
    const parts=[];
    if((p.instagram||'').trim()) parts.push(`IG: ${(p.instagram||'').trim()}`);
    if((p.whatsapp||'').trim()) parts.push(`WA: ${(p.whatsapp||'').trim()}`);
    if((p.facebook||'').trim()) parts.push(`FB: ${(p.facebook||'').trim()}`);
    if((p.xhandle||'').trim()) parts.push(`X: ${(p.xhandle||'').trim()}`);
    if((p.youtube||'').trim()) parts.push(`YT: ${(p.youtube||'').trim()}`);
    if((p.phone||'').trim()) parts.push(`Ph: ${(p.phone||'').trim()}`);
    if((p.email||'').trim()) parts.push(`Email: ${(p.email||'').trim()}`);
    if((p.website||'').trim()) parts.push(`Web: ${(p.website||'').trim()}`);
    return parts;
}

function pick(u){
    sel=u;
    document.querySelectorAll('.cv-block').forEach(e=>e.classList.toggle('cv-sel',e.dataset.uid===u));
    renderProps();
}

