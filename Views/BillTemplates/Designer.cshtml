            if(blk)blk.innerHTML=renderWysiwyg(comp);
            ta.focus();ta.setSelectionRange(pos+b.textContent.length,pos+b.textContent.length);
        });
    });
}

// Prop helpers
function pTa(k,l,v){return `<div class="pg"><div class="pl">${l}</div><textarea data-prop="${k}" class="form-control form-control-sm" rows="2">${esc(v||'')}</textarea></div>`}
function pIn(k,l,v){return `<div class="pg"><div class="pl">${l}</div><input data-prop="${k}" class="form-control form-control-sm" value="${esc(v||'')}"/></div>`}
function pNum(k,l,v,mn,mx){return `<div class="pg"><div class="pl">${l}</div><input type="number" data-prop="${k}" class="form-control form-control-sm" value="${v}" min="${mn}" max="${mx}"/></div>`}
function pRange(k,l,v,mn,mx){return `<div class="pg"><div class="pl">${l}: <span class="rv">${v}</span></div><input type="range" data-prop="${k}" class="form-range" value="${v}" min="${mn}" max="${mx}"/></div>`}
function pSel(k,l,v,opts){let h=`<div class="pg"><div class="pl">${l}</div><select data-prop="${k}" class="form-select form-select-sm">`;opts.forEach(([o,t])=>{h+=`<option value="${o}"${o===v?' selected':''}>${t}</option>`});return h+'</select></div>'}
function pChk(k,l,v){return `<div class="pg"><div class="form-check"><input type="checkbox" data-prop="${k}" class="form-check-input"${v?' checked':''}/><label class="form-check-label small">${l}</label></div></div>`}
function pChkInline(k,l,v){return `<div class="form-check"><input type="checkbox" data-prop="${k}" class="form-check-input"${v?' checked':''}/><label class="form-check-label">${l}</label></div>`}
function pColor(k,l,v){return `<div class="pg">${l?'<div class="pl">'+l+'</div>':''}<input type="color" data-prop="${k}" class="form-control form-control-sm form-control-color" value="${v||'#000000'}" style="width:36px;height:28px;padding:2px"/></div>`}
function dynInfo(tags){return `<div class="pg"><small class="text-muted">Dynamic fields (auto-filled):</small><div class="mt-1">${tags.map(t=>`<span class="field-badge">${t}</span>`).join(' ')}</div></div>`}
function badge(t){return `<span class="field-badge">${t}</span> `}
function esc(s){const d=document.createElement('div');d.textContent=s;return d.innerHTML}
function toast(m,t){const d=document.createElement('div');d.className=`alert alert-${t||'info'} alert-dismissible fade show position-fixed`;d.style.cssText='top:12px;right:12px;z-index:9999;min-width:220px;font-size:13px';d.innerHTML=m+'<button class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>';document.body.appendChild(d);setTimeout(()=>d.remove(),3000)}

// Paper size
document.getElementById('paperSize').addEventListener('change',function(){
    const w={'Thermal58mm':220,'Thermal80mm':300,'A4':400,'A5':320}[this.value]||300;
    document.getElementById('canvasWrap').style.width=w+'px';
});
document.getElementById('paperSize').dispatchEvent(new Event('change'));

// ═══ SAVE ═══
document.getElementById('btnSave').addEventListener('click',async function(){
    const btn=this;btn.disabled=true;btn.innerHTML='<span class="spinner-border spinner-border-sm me-1"></span>Saving…';
    const arr=comps.map(c=>({type:c.type,props:c.props}));
    try{
        const res=await fetch('@Url.Action("SaveLayout")',{method:'POST',headers:{'Content-Type':'application/json','X-XSRF-TOKEN':XSRF,'RequestVerificationToken':XSRF},body:JSON.stringify({billTemplateId:TID,layoutJson:JSON.stringify(arr),paperSize:document.getElementById('paperSize').value})});
        const data=await res.json();
        if(data.success){btn.innerHTML='<i class="bi bi-check-lg me-1"></i>Saved!';btn.classList.replace('btn-primary','btn-success');setTimeout(()=>{btn.classList.replace('btn-success','btn-primary');btn.innerHTML='<i class="bi bi-save me-1"></i>Save';btn.disabled=false},1500)}
        else{toast('Save failed — '+JSON.stringify(data),'danger');btn.innerHTML='<i class="bi bi-save me-1"></i>Save';btn.disabled=false}
    }catch(e){toast('Network error','danger');btn.innerHTML='<i class="bi bi-save me-1"></i>Save';btn.disabled=false}
});

document.getElementById('btnApplyPreset')?.addEventListener('click', function(){
    const key = document.getElementById('presetSelect')?.value || 'modern';
    const preset = PRESETS[key];
    if(!preset || !Array.isArray(preset) || preset.length===0) return;
    if(!confirm('Replace current layout with selected preset? Unsaved changes will be lost.')) return;
    comps = preset.map(c => ({ uid: gid(), type: c.type, props: JSON.parse(JSON.stringify(c.props || {})) }));
    sel = null;
    render();
    renderProps();
    toast('Preset applied. Click Save to persist.', 'info');
});

// ═══ LOGO UPLOAD ═══
document.getElementById('btnUploadLogo').addEventListener('click',async function(){
    const file=document.getElementById('logoFile').files[0];
    if(!file){toast('Select a file first','warning');return}
    const form=new FormData();form.append('logo',file);
    const btn=this;btn.disabled=true;btn.innerHTML='<span class="spinner-border spinner-border-sm"></span>';
    try{
        const res=await fetch('@Url.Action("UploadLogo")',{method:'POST',headers:{'X-XSRF-TOKEN':XSRF,'RequestVerificationToken':XSRF},body:form});
        const data=await res.json();
        if(data.success){toast('Logo uploaded!','success');setTimeout(()=>location.reload(),600)}
        else toast(data.message||'Upload failed','danger');
    }catch(e){toast('Network error','danger')}
    btn.innerHTML='<i class="bi bi-upload me-1"></i>Upload';btn.disabled=false;
});

async function uploadAsset(fileInputId, buttonId, actionUrl, successText) {
    const input = document.getElementById(fileInputId);
    const file = input?.files?.[0];
    if(!file){toast('Select a file first','warning');return;}
    const form = new FormData();
    form.append(fileInputId.replace('File',''), file);

    const btn = document.getElementById(buttonId);
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
    try{
        const res = await fetch(actionUrl, { method:'POST', headers:{'X-XSRF-TOKEN':XSRF,'RequestVerificationToken':XSRF}, body:form });
        const data = await res.json();
        if(data.success){ toast(successText,'success'); setTimeout(()=>location.reload(),600); }
        else toast(data.message || 'Upload failed','danger');
    }catch(e){ toast('Network error','danger'); }
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-upload me-1"></i>' + (buttonId === 'btnUploadSignature' ? 'Upload Signature' : 'Upload Stamp');
}

document.getElementById('btnUploadSignature')?.addEventListener('click', () =>
    uploadAsset('signatureFile', 'btnUploadSignature', '@Url.Action("UploadSignature")', 'Signature uploaded!'));
document.getElementById('btnUploadStamp')?.addEventListener('click', () =>
    uploadAsset('stampFile', 'btnUploadStamp', '@Url.Action("UploadStamp")', 'Stamp uploaded!'));

render();
})();
</script>
}
